---
interface Props { title:string; verdict:string; evidenceLevel:string; summary:string; theme?:'lemon'|'vitamin'|'default'; brandLabel?:string; className?:string; showTitle?: boolean; }
const { title, verdict, evidenceLevel, summary, theme='default', brandLabel='本日有據 Evidence Today', className='', showTitle=true } = Astro.props;
---
<div class={`myth-visual ${theme} ${className}`} role='img' aria-label={`${title}，判讀${verdict}，證據強度${evidenceLevel}`}>
  <div class="decor" aria-hidden="true"><span class='shape s1'></span><span class='shape s2'></span><span class='shape s3'></span></div>
  <p class="brand">{brandLabel}</p>
  {showTitle && <h3>{title}</h3>}
  <div class="badges"><span class="pill verdict">判讀：{verdict}</span><span class="pill evidence">證據強度：{evidenceLevel}</span></div>
  <p class="summary">{summary}</p>
</div>
<style>.myth-visual{aspect-ratio:1/1;width:100%;position:relative;display:flex;flex-direction:column;justify-content:space-between;padding:clamp(20px,4vw,34px);border-radius:var(--radius-card);overflow:hidden;isolation:isolate;min-width:0;border:1px solid var(--color-fog);box-shadow:var(--shadow-card)}.decor{position:absolute;inset:0;z-index:-1}.shape{position:absolute;border-radius:999px;opacity:.35}.s1{width:35%;height:35%;right:-6%;top:-4%}.s2{width:18%;height:18%;left:8%;top:14%}.s3{width:26%;height:26%;right:10%;bottom:10%}.myth-visual.lemon .decor{background:linear-gradient(135deg,#fffdf4,#edf7f0)}.myth-visual.lemon .shape{background:#f4dd7c}.myth-visual.vitamin .decor{background:linear-gradient(135deg,#fff9f0,#fffdf7)}.myth-visual.vitamin .shape{background:#ffcc80}.myth-visual.default .decor{background:linear-gradient(135deg,#f8fafc,#eef2ff)}.myth-visual.default .shape{background:#bfd3ff}.brand{font-size:clamp(12px,1.1vw,15px);font-weight:700;color:color-mix(in oklch,var(--color-ink) 75%,transparent)}.myth-visual h3{font-size:clamp(24px,3vw,38px);line-height:1.15;margin:.45rem 0 .8rem;letter-spacing:.01em;word-break:keep-all;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}.badges{display:flex;flex-wrap:wrap;gap:.5rem}.pill{display:inline-flex;align-items:center;justify-content:center;gap:4px;padding:8px 14px;border-radius:999px;font-size:clamp(14px,1.3vw,16px);font-weight:700;line-height:1.2;white-space:nowrap}.verdict{background:#fff1db;color:#7a4b08}.evidence{background:#e7efff;color:#1e3a8a}.summary{font-size:clamp(14px,1.4vw,18px);line-height:1.5;margin-top:.8rem;color:color-mix(in oklch,var(--color-ink) 88%,transparent)}@media(max-width:640px){.myth-visual h3{font-size:clamp(22px,7vw,30px)}.summary{font-size:15px}}</style>
