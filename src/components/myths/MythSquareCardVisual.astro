---
const { title, verdict, evidenceLevel, summary, theme='default', className='', showTitle=true } = Astro.props;
---
<div class={`myth-visual ${theme} ${className}`} role='img' aria-label={`${title}，判讀${verdict}，證據強度${evidenceLevel}`}>
  <div class="decor" aria-hidden="true"><span class='shape s1'></span><span class='shape s2'></span><span class='shape s3'></span></div>
  <img src="/images/brand/logo-icon.png" alt="本日有據" class="brand" loading="lazy" decoding="async" />
  {showTitle && <div><h3 class="myth-square-card-title">{title}</h3></div>}
  <div class="badges"><span class="pill verdict">判讀：{verdict}</span><span class="pill evidence">證據強度：{evidenceLevel}</span></div>
  <div><p class="summary">{summary}</p></div>
</div>
<style>.myth-visual{aspect-ratio:1/1;width:100%;position:relative;display:flex;flex-direction:column;justify-content:space-between;padding:clamp(18px,4vw,30px);border-radius:var(--radius-card);overflow:hidden;isolation:isolate;min-width:0;border:1px solid var(--color-fog);box-shadow:var(--shadow-card)}.decor{position:absolute;inset:0;z-index:-1}.shape{position:absolute;border-radius:999px;opacity:.32}.s1{width:35%;height:35%;right:-6%;top:-4%}.s2{width:18%;height:18%;left:8%;top:14%}.s3{width:26%;height:26%;right:10%;bottom:10%}.myth-visual.lemon .decor{background:linear-gradient(135deg,var(--myth-lemon-grad-a),var(--myth-lemon-grad-b))}.myth-visual.lemon .shape{background:var(--myth-lemon-shape)}.myth-visual.vitamin .decor{background:linear-gradient(135deg,var(--myth-vitamin-grad-a),var(--myth-vitamin-grad-b))}.myth-visual.vitamin .shape{background:var(--myth-vitamin-shape)}.myth-visual.default .decor{background:linear-gradient(135deg,var(--myth-default-grad-a),var(--myth-default-grad-b))}.myth-visual.default .shape{background:var(--myth-default-shape)}.brand{width:auto;height:clamp(32px,5vw,44px);object-fit:contain}.label{margin:0 0 4px;font-size:var(--text-meta);font-weight:700;letter-spacing:.04em;color:color-mix(in oklch,var(--color-ink) 62%,transparent)}.myth-square-card-title{font-size:clamp(24px,5.8vw,34px);line-height:1.2;margin:.5rem 0 .7rem;max-width:100%;overflow-wrap:anywhere}.badges{display:flex;flex-wrap:wrap;gap:.5rem}.pill{display:inline-flex;align-items:center;justify-content:center;padding:8px 12px;border-radius:999px;font-size:clamp(14px,1.4vw,18px);font-weight:700;line-height:1.2}.verdict{background:var(--myth-verdict-bg);color:var(--myth-verdict-fg)}.evidence{background:var(--myth-evidence-bg);color:var(--myth-evidence-fg)}.summary{font-size:clamp(15px,1.5vw,19px);line-height:1.5;margin-top:.7rem;color:color-mix(in oklch,var(--color-ink) 88%,transparent)}@media(max-width:640px){.myth-square-card-title{font-size:clamp(23px,7vw,30px)}.brand{max-height:38px}.summary{font-size:var(--text-caption)}}</style>
