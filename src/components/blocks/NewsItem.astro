---
import { cleanNewsTitle } from '@/utils/news';

interface Props {
  title: string;
  source: string;
  date: string;
  summary: string;
  href: string;
  sourceUrl?: string;
  tags: string[];
}

const { title, source, date, summary, href, tags } = Astro.props;
const displayTitle = cleanNewsTitle(title);
const primaryTag = tags[0] ?? '';
---

<article class="news-item">
  <div class="news-item__header">
    {primaryTag && <span class="news-item__tag">{primaryTag}</span>}
    <time class="news-item__date">{date}</time>
  </div>
  <h3 class="news-item__title">
    <a href={href}>{displayTitle}</a>
  </h3>
  <p class="news-item__summary">{summary}</p>
</article>

<style>
  .news-item {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-fog);
  }

  .news-item:last-child {
    border-bottom: none;
  }

  .news-item__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.375rem;
  }

  .news-item__tag {
    display: inline-flex;
    align-items: center;
    padding: 0.1rem 0.45rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 600;
    white-space: nowrap;
    background-color: color-mix(in oklch, var(--color-cat-news) 14%, var(--color-paper));
    color: var(--color-cat-news);
  }

  .news-item__date {
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    color: color-mix(in oklch, var(--color-ink) 45%, transparent);
  }

  .news-item__title {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.4;
    margin-bottom: 0.375rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-item__title a {
    color: inherit;
    text-decoration: none;
  }

  .news-item__title a:hover {
    color: var(--color-teal);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .news-item__summary {
    font-size: var(--text-meta);
    color: color-mix(in oklch, var(--color-ink) 60%, transparent);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
