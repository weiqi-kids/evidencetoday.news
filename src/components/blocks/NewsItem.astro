---
import { cleanNewsTitle } from '@/utils/news';

interface Props {
  title: string;
  source: string;
  date: string;
  summary: string;
  href: string;
  sourceUrl?: string;
  tags: string[];
  image?: string;
  imageAlt?: string;
}

const { title, date, summary, href, tags, image, imageAlt } = Astro.props;
const displayTitle = cleanNewsTitle(title);
const primaryTag = tags[0] ?? '';
// 縮圖優先用外連圖庫圖；缺圖退品牌佔位，維持每格都有圖、不開天窗。
const thumb = typeof image === 'string' && image.trim() ? image.trim() : '/og-thumb/news.webp';
---

<article class="news-item">
  <a href={href} class="news-item__thumb-link" tabindex="-1" aria-hidden="true">
    <img class="news-item__thumb" src={thumb} alt={imageAlt || ''} loading="lazy" decoding="async" />
  </a>
  <div class="news-item__content">
    <div class="news-item__header">
      {primaryTag && <span class="news-item__tag">{primaryTag}</span>}
      <time class="news-item__date">{date}</time>
    </div>
    <h3 class="news-item__title">
      <a href={href}>{displayTitle}</a>
    </h3>
    <p class="news-item__summary">{summary}</p>
  </div>
</article>

<style>
  .news-item {
    display: grid;
    grid-template-columns: clamp(96px, 26vw, 136px) 1fr;
    gap: clamp(0.75rem, 0.55rem + 0.8vw, 1.1rem);
    align-items: start;
    padding: 1.15rem 0;
    border-bottom: 1px solid var(--color-fog);
  }

  .news-item:last-child {
    border-bottom: none;
  }

  .news-item__thumb-link {
    display: block;
    border-radius: var(--radius-card);
    overflow: hidden;
    background-color: color-mix(in oklch, var(--color-cat-news) 8%, var(--color-paper));
  }

  .news-item__thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .news-item:hover .news-item__thumb {
    transform: scale(1.04);
  }

  .news-item__content {
    min-width: 0;
  }

  .news-item__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.375rem;
  }

  .news-item__tag {
    display: inline-flex;
    align-items: center;
    padding: 0.1rem 0.45rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 600;
    white-space: nowrap;
    background-color: color-mix(in oklch, var(--color-cat-news) 14%, var(--color-paper));
    color: var(--color-cat-news);
  }

  .news-item__date {
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    color: color-mix(in oklch, var(--color-ink) 45%, transparent);
  }

  .news-item__title {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.4;
    margin-bottom: 0.375rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-item__title a {
    color: inherit;
    text-decoration: none;
  }

  .news-item__title a:hover {
    color: var(--color-teal);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .news-item__summary {
    font-size: var(--text-meta);
    color: color-mix(in oklch, var(--color-ink) 60%, transparent);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (min-width: 640px) {
    .news-item {
      grid-template-columns: clamp(128px, 20vw, 168px) 1fr;
    }
  }
</style>
