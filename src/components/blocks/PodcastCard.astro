---
interface Props {
  title: string;
  description: string;
  href: string;
  episodeNumber: number;
  duration: string;
  publishDate?: Date;
}

const { title, description, href, episodeNumber, duration, publishDate } = Astro.props;
const dateLabel = publishDate ? publishDate.toLocaleDateString('zh-TW') : '';
---

<a href={href} class="podcast-card" aria-label={`收聽 EP${episodeNumber}：${title}`}>
  <div class="podcast-card__body">
    <div class="podcast-card__top">
      <span class="podcast-card__tag">Podcast</span>
      <span class="podcast-card__ep">EP{episodeNumber}</span>
    </div>
    <h3 class="podcast-card__title">{title}</h3>
    <p class="podcast-card__desc">{description}</p>
    <div class="podcast-card__meta">
      <span>{duration}</span>
      {dateLabel && <span>{dateLabel}</span>}
    </div>
    <span class="podcast-card__cta">收聽本集 →</span>
  </div>
</a>

<style>
  .podcast-card {
    display: block;
    border-radius: var(--radius-card);
    text-decoration: none;
    color: inherit;
    background: color-mix(in oklch, var(--color-cat-podcast) 22%, var(--color-navy));
    border: 1px solid color-mix(in oklch, var(--color-cat-podcast) 60%, black 25%);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .podcast-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-card-hover); }
  .podcast-card__body { padding: clamp(1.15rem, 1.05rem + 0.4vw, 1.4rem); display: flex; flex-direction: column; gap: 0.72rem; }
  .podcast-card__top { display: flex; justify-content: space-between; align-items: center; }
  .podcast-card__tag { font-size: var(--text-badge); color: var(--color-on-dark-meta); font-family: var(--font-ui); }
  .podcast-card__ep { font-size: var(--text-badge); color: color-mix(in oklch, var(--color-cat-podcast) 88%, white); font-weight: 600; font-family: var(--font-ui); }
  .podcast-card__title { color: var(--color-on-dark-heading); font-size: var(--text-h3); line-height: 1.42; }
  .podcast-card__desc { color: var(--color-on-dark-body); font-size: var(--text-meta); line-height: 1.68; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .podcast-card__meta { display: flex; gap: 0.8rem; color: var(--color-on-dark-meta); font-family: var(--font-ui); font-size: var(--text-meta); margin-top: 0.2rem; }
  .podcast-card__cta { color: var(--color-cat-podcast); font-family: var(--font-ui); font-size: var(--text-meta); font-weight: 700; margin-top: 0.45rem; }
</style>
