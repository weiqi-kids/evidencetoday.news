---
interface Props {
  title: string;
  description: string;
  href: string;
  episodeNumber: number;
  duration: string;
}

const { title, description, href, episodeNumber, duration } = Astro.props;
---

<a href={href} class="podcast-card">
  <div class="podcast-card__body">
    <span class="podcast-card__ep">EP {episodeNumber}</span>
    <h3 class="podcast-card__title">{title}</h3>
    <p class="podcast-card__desc">{description}</p>
    <div class="podcast-card__meta">
      <span class="podcast-card__play">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
      </span>
      <span>{duration}</span>
    </div>
  </div>
</a>

<style>
  .podcast-card {
    display: block;
    background-color: var(--color-navy);
    border-radius: var(--radius-card);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .podcast-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
  }

  .podcast-card__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .podcast-card__ep {
    font-family: var(--font-ui);
    font-size: var(--text-badge);
    font-weight: 600;
    color: var(--color-on-dark-meta);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .podcast-card__title {
    font-family: var(--font-sans);
    font-size: var(--text-h3);
    font-weight: 600;
    color: var(--color-on-dark-heading);
    line-height: 1.35;
  }

  .podcast-card__desc {
    font-size: var(--text-meta);
    color: var(--color-on-dark-body);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .podcast-card__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    color: var(--color-on-dark-meta);
  }

  .podcast-card__play {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background-color: var(--color-on-dark-link);
    color: var(--color-navy);
  }
</style>
