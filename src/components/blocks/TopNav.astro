---
const navLinks = [
  { label: '文章', href: '/articles/' },
  { label: '健康專題', href: '/topics/' },
  { label: 'Podcast', href: '/podcasts/' },
  { label: '短影音', href: '/videos/' },
  { label: '闢謠', href: '/myths/' },
  { label: '成分解析', href: '/ingredients/' },
  { label: '趨勢', href: '/news/' },
  { label: '關於我們', href: '/about/' },
];
const currentPath = Astro.url.pathname;
---

<header class="topnav">
  <div class="topnav__inner container">
    <a href="/" class="topnav__brand" aria-label="本日有據 首頁">
      <img
        src="/images/brand/logo-icon.png"
        alt=""
        class="topnav__logo-icon"
        loading="eager"
        decoding="async"
      />
      <span class="topnav__brand-zh">本日有據</span>
    </a>

    <nav class="topnav__nav" aria-label="主選單">
      <ul>
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'topnav__link',
                { 'is-active': currentPath.startsWith(link.href) },
              ]}
              aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="topnav__actions">
      <a href="/search/" class="topnav__search-btn" aria-label="搜尋">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m20 20-4.2-4.2"></path>
        </svg>
      </a>

      <button
        class="topnav__hamburger"
        type="button"
        aria-label="開啟選單"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-menu" class="topnav__mobile" aria-label="行動版選單" hidden>
    <ul>
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'topnav__mobile-link',
              { 'is-active': currentPath.startsWith(link.href) },
            ]}
            aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const hamburger = document.querySelector('.topnav__hamburger');
  const mobileMenu = document.getElementById('mobile-menu');

  if (hamburger && mobileMenu) {
    hamburger.addEventListener('click', () => {
      const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
      hamburger.setAttribute('aria-expanded', String(!isOpen));
      mobileMenu.hidden = isOpen;
    });

    // 跨到桌機斷點時重置行動選單狀態（避免「開著選單放大視窗後 aria 狀態殘留」）
    const desktopQuery = window.matchMedia('(min-width: 1024px)');
    desktopQuery.addEventListener('change', (e) => {
      if (e.matches) {
        hamburger.setAttribute('aria-expanded', 'false');
        mobileMenu.hidden = true;
      }
    });
  }
</script>

<style>
  .topnav {
    position: sticky;
    top: 0;
    z-index: 40;
    background-color: color-mix(in oklch, var(--color-paper) 88%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-fog);
  }

  .topnav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 4.35rem;
    gap: 1rem;
  }

  .topnav__brand {
    display: flex;
    align-items: center;
    gap: clamp(0.4rem, 1vw, 0.6rem);
    min-width: 0;
    text-decoration: none;
    -webkit-user-drag: none;
  }

  .topnav__logo-icon {
    display: block;
    height: 30px;
    width: auto;
    flex-shrink: 0;
  }

  .topnav__brand-zh {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: clamp(1.05rem, 1.8vw, 1.45rem);
    color: var(--color-teal);
    letter-spacing: 0.06em;
    white-space: nowrap;
    line-height: 1.2;
  }

  .topnav__nav {
    display: none;
  }

  @media (min-width: 1024px) {
    .topnav__nav {
      display: block;
      align-self: stretch;
    }
  }

  .topnav__nav ul {
    display: flex;
    align-items: stretch;
    gap: 0.35rem;
    list-style: none;
    margin: 0;
    padding: 0;
    height: 100%;
  }

  .topnav__link {
    display: flex;
    align-items: flex-end;
    height: 100%;
    padding: 0 0.85rem clamp(1.106rem, calc(19.80px - 0.164vw), 1.145rem);
    font-family: var(--font-serif);
    font-size: clamp(1.05rem, 1.8vw, 1.45rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-ink);
    text-decoration: none;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .topnav__link:hover {
    background-color: var(--color-teal-subtle);
    color: var(--color-teal);
  }

  .topnav__link.is-active {
    color: var(--color-teal);
    /* 非顏色相依的目前頁指示（底部指示條），不影響連結高度 */
    box-shadow: inset 0 -3px 0 var(--color-teal);
  }

  .topnav__actions {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-shrink: 0;
  }

  .topnav__search-btn,
  .topnav__hamburger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.65rem;
    height: 2.65rem;
    border-radius: 999px;
    color: var(--color-ink);
    text-decoration: none;
    border: none;
    background: none;
  }

  .topnav__search-btn svg {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    stroke-width: 2;
    fill: none;
  }

  .topnav__hamburger svg {
    width: 22px;
    height: 22px;
    stroke: currentColor;
    stroke-width: 2;
    fill: none;
    stroke-linecap: round;
  }

  .topnav__search-btn:hover,
  .topnav__hamburger:hover {
    background-color: var(--color-teal-subtle);
  }

  @media (min-width: 1024px) {
    .topnav__hamburger {
      display: none;
    }
  }

  .topnav__mobile {
    border-top: 1px solid var(--color-fog);
    padding: 0.55rem var(--space-page-x) 1rem;
    background-color: var(--color-paper);
  }

  @media (min-width: 1024px) {
    .topnav__mobile {
      display: none;
    }
  }

  .topnav__mobile ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .topnav__mobile-link {
    display: block;
    padding: 0.7rem 0.8rem;
    font-size: 1.02rem;
    color: var(--color-ink);
    text-decoration: none;
    border-radius: var(--radius-sm);
  }

  .topnav__mobile-link:hover,
  .topnav__mobile-link.is-active {
    background-color: var(--color-teal-subtle);
    color: var(--color-teal);
  }
</style>