---
const navLinks = [
  { label: '文章', href: '/articles/' },
  { label: 'Podcast', href: '/podcasts/' },
  { label: '短影音', href: '/videos/' },
  { label: '闢謠', href: '/myths/' },
  { label: '原料', href: '/ingredients/' },
  { label: '趨勢', href: '/news/' },
  { label: '關於我們', href: '/about/' },
];
const currentPath = Astro.url.pathname;
---
<header class="topnav"><div class="topnav__inner container"><a href="/" class="topnav__brand" aria-label="本日有據 首頁"><img src="/images/brand/logo-icon.png" alt="" class="topnav__logo-icon" loading="eager" decoding="async" /><span class="topnav__brand-text"><span class="topnav__brand-zh">本日有據</span><span class="topnav__brand-divider" aria-hidden="true"></span><span class="topnav__brand-en">EVIDENCE TODAY</span></span></a><nav class="topnav__nav" aria-label="主選單"><ul>{navLinks.map((link) => <li><a href={link.href} class:list={['topnav__link', { 'is-active': currentPath.startsWith(link.href) }]}>{link.label}</a></li>)}</ul></nav><div class="topnav__actions"><a href="/search/" class="topnav__search-btn" aria-label="搜尋">🔍</a><button class="topnav__hamburger" type="button" aria-label="開啟選單" aria-expanded="false" aria-controls="mobile-menu">☰</button></div></div><nav id="mobile-menu" class="topnav__mobile" aria-label="行動版選單" hidden><ul>{navLinks.map((link) => <li><a href={link.href} class:list={['topnav__mobile-link', { 'is-active': currentPath.startsWith(link.href) }]}>{link.label}</a></li>)}</ul></nav></header>
<script>const hamburger=document.querySelector('.topnav__hamburger');const mobileMenu=document.getElementById('mobile-menu');if(hamburger&&mobileMenu){hamburger.addEventListener('click',()=>{const isOpen=hamburger.getAttribute('aria-expanded')==='true';hamburger.setAttribute('aria-expanded',String(!isOpen));mobileMenu.hidden=isOpen;});}</script>
<style>.topnav{position:sticky;top:0;z-index:40;background-color:color-mix(in oklch,var(--color-paper) 88%,transparent);backdrop-filter:blur(12px);border-bottom:1px solid var(--color-fog)}.topnav__inner{display:flex;align-items:center;justify-content:space-between;min-height:4.35rem;gap:1rem}.topnav__brand{display:flex;align-items:center;gap:clamp(0.4rem,1vw,0.6rem);min-width:0;text-decoration:none;-webkit-user-drag:none}.topnav__logo-icon{display:block;height:clamp(34px,5vw,46px);width:auto;flex-shrink:0}.topnav__brand-text{display:flex;flex-direction:column;align-items:center;min-width:0;-webkit-user-select:text;user-select:text}.topnav__brand-zh{font-family:var(--font-serif);font-weight:700;font-size:clamp(1.05rem,1.8vw,1.45rem);color:var(--color-teal);letter-spacing:0.1em;white-space:nowrap;line-height:1.2}.topnav__brand-divider{display:block;height:5px;align-self:stretch;margin:clamp(2px,0.3vw,4px) 0;background:linear-gradient(oklch(0.69 0.09 72),oklch(0.69 0.09 72)) left center/calc(50% - 4px) 1.5px no-repeat,radial-gradient(circle,oklch(0.69 0.09 72) 2px,transparent 2.5px) center/5px 5px no-repeat,linear-gradient(oklch(0.69 0.09 72),oklch(0.69 0.09 72)) right center/calc(50% - 4px) 1.5px no-repeat}.topnav__brand-en{font-family:var(--font-display);font-weight:600;font-size:clamp(0.5rem,0.85vw,0.62rem);color:var(--color-teal);letter-spacing:0.18em;white-space:nowrap;line-height:1.3}.topnav__nav{display:none}@media (min-width:900px){.topnav__nav{display:block;align-self:stretch}}.topnav__nav ul{display:flex;align-items:stretch;gap:.35rem;list-style:none;margin:0;padding:0;height:100%}.topnav__link{display:flex;align-items:center;padding:0 .85rem;font-family:var(--font-ui);font-size:clamp(1.08rem,1.3vw,1.2rem);font-weight:600;color:var(--color-ink);text-decoration:none}.topnav__link:hover{color:var(--color-teal)}.topnav__link.is-active{color:var(--color-teal)}.topnav__actions{display:flex;align-items:center;gap:.35rem;flex-shrink:0}.topnav__search-btn,.topnav__hamburger{display:flex;align-items:center;justify-content:center;width:2.65rem;height:2.65rem;border-radius:999px;color:var(--color-ink);font-size:1.2rem;text-decoration:none;border:none;background:none}.topnav__search-btn:hover,.topnav__hamburger:hover{background-color:var(--color-teal-subtle)}@media (min-width:900px){.topnav__hamburger{display:none}}.topnav__mobile{border-top:1px solid var(--color-fog);padding:.55rem var(--space-page-x) 1rem;background-color:var(--color-paper)}@media (min-width:900px){.topnav__mobile{display:none !important}}.topnav__mobile ul{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:.125rem}.topnav__mobile-link{display:block;padding:.7rem .8rem;font-size:1.02rem;font-weight:600;color:var(--color-ink);text-decoration:none;border-radius:var(--radius-sm)}.topnav__mobile-link.is-active{color:var(--color-teal)}</style>
