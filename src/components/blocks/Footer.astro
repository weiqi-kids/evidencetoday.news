---
const contentLinks = [
  { label: '文章', href: '/articles/' },
  { label: 'Podcast', href: '/podcasts/' },
  { label: '短影音', href: '/videos/' },
  { label: '闢謠', href: '/myths/' },
  { label: '原料', href: '/ingredients/' },
  { label: '趨勢', href: '/news/' },
];

const resourceLinks = [
  { label: '搜尋', href: '/search/' },
  { label: 'RSS', href: '/rss.xml' },
];

const aboutLinks = [
  { label: '關於本站', href: '/about/' },
  { label: '編輯政策', href: '/editorial-policy/' },
  { label: '醫療聲明', href: '/medical-disclaimer/' },
  { label: '零業配與編輯獨立聲明', href: '/disclosure/' },
  { label: '隱私政策', href: '/privacy/' },
  { label: '使用條款', href: '/terms/' },
  { label: '聯絡我們', href: '/contact/' },
];

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner container">
    <!-- Top section -->
    <div class="footer__top">
      <!-- Brand column -->
      <div class="footer__brand">
        <div class="footer__logo">
          <span class="footer__logo-zh">本日有據</span>
          <span class="footer__logo-en">Evidence Today</span>
        </div>
        <p class="footer__tagline">把健康議題，講得有根據，也講得讓人看得懂。</p>
      </div>

      <!-- Link columns -->
      <div class="footer__columns">
        <div class="footer__col">
          <h3 class="footer__col-title">內容</h3>
          <ul>
            {contentLinks.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>

        <div class="footer__col">
          <h3 class="footer__col-title">資源</h3>
          <ul>
            {resourceLinks.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>

        <div class="footer__col">
          <h3 class="footer__col-title">關於</h3>
          <ul>
            {aboutLinks.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom section -->
    <div class="footer__bottom">
      <p class="footer__copyright">
        &copy; {year} 本日有據 Evidence Today. All rights reserved.
      </p>
      <p class="footer__disclaimer">
        本站內容僅供一般健康資訊參考，不構成醫療建議。本日有據採零業配原則，不接受廠商付費置入或贊助內容。
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-navy);
    padding: var(--space-section-gap) 0 2rem;
    margin-top: var(--space-section-gap);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* Top section */
  .footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 768px) {
    .footer__top {
      grid-template-columns: 1fr 2fr;
      gap: 3rem;
    }
  }

  /* Brand */
  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer__logo {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .footer__logo-zh {
    font-family: var(--font-serif);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-on-dark-heading);
  }

  .footer__logo-en {
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-on-dark-meta);
  }

  .footer__tagline {
    font-family: var(--font-sans);
    font-size: var(--text-meta);
    color: var(--color-on-dark-body);
    line-height: 1.6;
    max-width: 22ch;
  }

  /* Link columns */
  .footer__columns {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  @media (min-width: 640px) {
    .footer__columns {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .footer__col-title {
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    font-weight: 700;
    color: var(--color-on-dark-heading);
    text-transform: none;
    margin-bottom: 0.75rem;
  }

  .footer__col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .footer__col a {
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    color: var(--color-on-dark-body);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer__col a:hover {
    color: var(--color-on-dark-link);
  }

  /* Bottom section */
  .footer__bottom {
    border-top: 1px solid color-mix(in oklch, var(--color-on-dark-meta) 20%, transparent);
    padding-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__copyright {
    font-family: var(--font-ui);
    font-size: var(--text-badge);
    color: var(--color-on-dark-meta);
  }

  .footer__disclaimer {
    font-family: var(--font-sans);
    font-size: var(--text-badge);
    color: var(--color-on-dark-meta);
    line-height: 1.6;
  }

  .footer__disclosure {
    font-family: var(--font-sans);
    font-size: var(--text-badge);
    color: var(--color-on-dark-meta);
    line-height: 1.6;
  }

  .footer__disclosure a {
    color: var(--color-on-dark-link);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .footer__disclosure a:hover {
    color: var(--color-on-dark-link);
    text-decoration-thickness: 2px;
  }
</style>
