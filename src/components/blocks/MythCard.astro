---
import VerdictBadge from '../ui/VerdictBadge.astro';
import type { MythVerdict } from '@/utils/myths/schema';

interface Props {
  title: string;
  verdictSummary: string;
  href: string;
  verdict: MythVerdict;
  date: string;
}

const { title, verdictSummary, href, verdict, date } = Astro.props;
---

<a href={href} class="myth-card">
  <div class="myth-card__bar"></div>
  <div class="myth-card__body">
    <div class="myth-card__top">
      <VerdictBadge verdict={verdict} size="sm" />
    </div>
    <h3 class="myth-card__title">{title}</h3>
    <p class="myth-card__desc">{verdictSummary}</p>
    <div class="myth-card__meta">
      <span>{date}</span>
    </div>
  </div>
</a>

<style>
  .myth-card {
    display: block;
    background-color: white;
    border: 1px solid var(--color-fog);
    border-radius: var(--radius-card);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .myth-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
  }

  .myth-card__bar {
    height: 6px;
    background-color: var(--color-cat-myth);
  }

  .myth-card__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .myth-card__top {
    display: flex;
    align-items: center;
  }

  .myth-card__title {
    font-family: var(--font-sans);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.35;
  }

  .myth-card__desc {
    font-size: var(--text-meta);
    color: color-mix(in oklch, var(--color-ink) 70%, transparent);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .myth-card__meta {
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    color: color-mix(in oklch, var(--color-ink) 55%, transparent);
  }
</style>
