---
import CategoryTag from '../ui/CategoryTag.astro';
import { existsSync } from 'node:fs';
import { join } from 'node:path';

interface Props {
  title: string;
  description: string;
  href: string;
  category: 'article';
  author: string;
  date: string;
  editorReviewed?: boolean;
  coverImage?: string;
  coverAlt?: string;
  topicLabel?: string;
  aeoLabel?: string;
}

const { title, description, href, category, author, date, coverImage, coverAlt, topicLabel, aeoLabel } = Astro.props;
// process.cwd() 而非 import.meta.url 相對路徑：production build 打包後元件的 import.meta.url
// 會指向 bundle chunk 位置而非原始 src 路徑，`../../../public` 這類相對推算會失準（本地圖片
// 全數誤判不存在、退回佔位卡）；astro build 執行時 cwd 恆為專案根目錄，兩種環境都可靠。
const safeCoverImage =
  typeof coverImage === 'string' &&
  (coverImage.startsWith('http://') ||
    coverImage.startsWith('https://') ||
    (coverImage.startsWith('/') && existsSync(join(process.cwd(), 'public', coverImage))))
    ? coverImage
    : undefined;
---

<a href={href} class="article-card">
  {safeCoverImage ? (
    <img class="article-card__image" src={safeCoverImage} alt={coverAlt || `${title} 縮圖`} loading="lazy" />
  ) : (
    <div class="article-card__image article-card__image--fallback" aria-hidden="true">本日有據</div>
  )}
  <div class="article-card__bar"></div>
  <div class="article-card__body">
    <div class="article-card__top">
      <CategoryTag category={category} />
      {topicLabel && <span class="article-card__topic">{topicLabel}</span>}
      {aeoLabel && <span class="article-card__topic article-card__topic--aeo">{aeoLabel}</span>}
    </div>
    <h3 class="article-card__title">{title}</h3>
    <p class="article-card__desc">{description}</p>
    <div class="article-card__meta">
      <span>{author}</span>
      <span>{date}</span>
    </div>
  </div>
</a>

<style>
  .article-card {
    display: block;
    background-color: white;
    border: 1px solid var(--color-fog);
    border-radius: var(--radius-card);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .article-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
  }

  .article-card__bar {
    height: 6px;
    background-color: var(--color-cat-article);
  }

  .article-card__image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .article-card__image--fallback {
    background: linear-gradient(
      160deg,
      color-mix(in oklch, var(--color-cat-article) 16%, white),
      color-mix(in oklch, var(--color-fog) 45%, white)
    );
    display: grid;
    place-items: center;
    color: var(--color-ink-muted);
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    letter-spacing: 0.04em;
  }

  .article-card__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .article-card__top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .article-card__topic {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.15rem 0.55rem;
    font-size: 0.76rem;
    color: color-mix(in oklch, var(--color-ink) 86%, transparent);
    background: color-mix(in oklch, var(--color-fog) 92%, white);
  }

  .article-card__topic--aeo {
    color: color-mix(in oklch, var(--color-teal) 65%, var(--color-ink));
    background: color-mix(in oklch, var(--color-teal) 14%, white);
    border: 1px solid color-mix(in oklch, var(--color-teal) 22%, white);
  }

  .article-card__title {
    font-family: var(--font-sans);
    font-size: var(--text-h3);
    font-weight: 600;
    color: var(--color-ink);
    line-height: 1.35;
  }

  .article-card__desc {
    font-size: var(--text-meta);
    color: color-mix(in oklch, var(--color-ink) 70%, transparent);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-card__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    color: var(--color-ink-muted);
  }
</style>
