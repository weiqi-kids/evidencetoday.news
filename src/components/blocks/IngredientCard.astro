---
import { existsSync } from 'node:fs';
import { join } from 'node:path';

interface Props {
  title: string;
  titleEn?: string;
  description: string;
  href: string;
  coverImage?: string;
  coverAlt?: string;
  uses: Array<{ evidenceLevel: string }>;
  tags?: string[];
}

const { title, titleEn, description, href, coverImage, coverAlt, uses, tags = [] } = Astro.props;

// 封面安全守衛：外連 http(s) 直接採用；本地 `/…` 須確認 public 下存在，缺圖或路徑非法時退回品牌佔位。
// 用 process.cwd() 而非 import.meta.url 相對路徑：production build 打包後元件的 import.meta.url
// 會指向 bundle chunk 位置而非原始 src 路徑，`../../../public` 這類相對推算會失準（本地圖片
// 全數誤判不存在、退回佔位卡）；astro build 執行時 cwd 恆為專案根目錄，兩種環境都可靠。
const safeCoverImage =
  typeof coverImage === 'string' &&
  (coverImage.startsWith('http://') ||
    coverImage.startsWith('https://') ||
    (coverImage.startsWith('/') && existsSync(join(process.cwd(), 'public', coverImage))))
    ? coverImage
    : undefined;

const evidenceLabels: Record<string, string> = {
  'meta-analysis': '系統性回顧／統合分析',
  rct: '隨機對照試驗',
  observational: '觀察性研究',
  animal: '動物實驗',
  'in-vitro': '體外實驗',
};

const uniqueEvidence = Array.from(new Set(uses.map((use) => use.evidenceLevel)));
const mappedEvidence = uniqueEvidence
  .map((level) => evidenceLabels[level] ?? null)
  .filter((label): label is string => Boolean(label));
const topTags = tags.slice(0, 3);
---

<a href={href} class="ingredient-card">
  <div class="ingredient-card__bar"></div>
  {safeCoverImage ? (
    <img class="ingredient-card__thumb" src={safeCoverImage} alt={coverAlt || `${title} 成分解析縮圖`} loading="lazy" />
  ) : (
    <div class="ingredient-card__thumb ingredient-card__thumb--fallback" aria-hidden="true">本日有據</div>
  )}
  <div class="ingredient-card__body">
    <h3 class="ingredient-card__title">{title}</h3>
    {titleEn && <p class="ingredient-card__title-en">{titleEn}</p>}
    <p class="ingredient-card__desc">{description}</p>
    {topTags.length > 0 && (
      <div class="ingredient-card__tags">
        {topTags.map((tag) => (
          <span class="ingredient-card__tag">{tag}</span>
        ))}
      </div>
    )}
    {mappedEvidence.length > 0 && (
      <p class="ingredient-card__evidence">
        {mappedEvidence.length >= 2
          ? `證據概況：${mappedEvidence.slice(0, 2).join('、')}`
          : `目前證據：${mappedEvidence[0]}為主`}
      </p>
    )}
  </div>
</a>

<style>
  .ingredient-card {
    display: block;
    min-width: 0;
    background-color: white;
    border: 1px solid var(--color-fog);
    border-radius: var(--radius-card);
    overflow: hidden;
    overflow-wrap: anywhere;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .ingredient-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
  }

  .ingredient-card__bar {
    height: 6px;
    background-color: var(--color-cat-ingredient);
  }

  .ingredient-card__thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    min-width: 0;
    border-bottom: 1px solid var(--color-fog);
  }

  .ingredient-card__thumb--fallback {
    background: linear-gradient(
      160deg,
      color-mix(in oklch, var(--color-cat-ingredient) 16%, white),
      color-mix(in oklch, var(--color-fog) 45%, white)
    );
    display: grid;
    place-items: center;
    color: var(--color-ink-muted);
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    letter-spacing: 0.04em;
  }

  .ingredient-card__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    min-width: 0;
    gap: 0.625rem;
  }

  .ingredient-card__title {
    font-family: var(--font-sans);
    font-size: var(--text-h3);
    font-weight: 600;
    color: var(--color-ink);
    line-height: 1.35;
  }

  .ingredient-card__title-en {
    font-size: var(--text-meta);
    color: color-mix(in oklch, var(--color-ink) 70%, transparent);
  }

  .ingredient-card__desc {
    font-size: var(--text-meta);
    color: color-mix(in oklch, var(--color-ink) 70%, transparent);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    overflow-wrap: anywhere;
  }

  .ingredient-card__tags {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    flex-wrap: wrap;
    min-width: 0;
  }

  .ingredient-card__tag {
    font-size: 0.72rem;
    color: var(--color-cat-ingredient);
    border: 1px solid color-mix(in oklch, var(--color-cat-ingredient) 25%, var(--color-fog));
    background-color: color-mix(in oklch, var(--color-cat-ingredient) 10%, white);
    border-radius: 999px;
    padding: 0.1rem 0.45rem;
  }
  .ingredient-card__evidence {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.55;
    color: color-mix(in oklch, var(--color-ink) 76%, transparent);
  }
</style>