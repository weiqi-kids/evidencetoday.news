---
import Badge from '../ui/Badge.astro';
import { AUTHORS } from '@/data/authors';

interface Props {
  author: string;
  reviewer?: string;
  editorReviewed: boolean;
}

const { author, reviewer, editorReviewed } = Astro.props;

// 作者已登錄於 registry 時，把姓名連到作者頁，串起 文章 → 作者 → sameAs 實體圖（E-E-A-T）。
const authorPath = AUTHORS[author]?.url?.replace('https://evidencetoday.news', '') ?? null;
---

<div class="editor-info">
  <div class="editor-info__people">
    <span class="editor-info__item">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
      {authorPath ? <a class="editor-info__author-link" href={authorPath} rel="author">{author}</a> : author}
    </span>
    {reviewer && (
      <span class="editor-info__item">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
        主編把關：{reviewer}
      </span>
    )}
  </div>
  {editorReviewed && (
    <Badge variant="editor">主編把關</Badge>
  )}
</div>

<style>
  .editor-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .editor-info__people {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .editor-info__item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    color: var(--color-ink);
  }

  .editor-info__item svg {
    color: color-mix(in oklch, var(--color-ink) 50%, transparent);
    flex-shrink: 0;
  }

  .editor-info__author-link {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: color-mix(in oklch, var(--color-ink) 30%, transparent);
    text-underline-offset: 2px;
  }

  .editor-info__author-link:hover {
    text-decoration-color: currentColor;
  }
</style>
