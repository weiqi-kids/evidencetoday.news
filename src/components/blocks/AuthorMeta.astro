---
interface Props {
  publishDate: Date;
  updatedDate?: Date;
  readingTime?: number;
}

const { publishDate, updatedDate, readingTime } = Astro.props;

const formatDate = (d: Date) => d.toISOString().slice(0, 10);
const pubStr = formatDate(publishDate);
const updStr = updatedDate ? formatDate(updatedDate) : null;
const showUpdated = updStr && updStr !== pubStr;
---

<div class="author-meta">
  <span class="author-meta__item">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
    發佈 {pubStr}
  </span>
  {showUpdated && (
    <span class="author-meta__item">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
      最後更新 {updStr}
    </span>
  )}
  {readingTime && (
    <span class="author-meta__item">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
      閱讀 {readingTime} 分鐘
    </span>
  )}
</div>

<style>
  .author-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: var(--text-meta);
    font-family: var(--font-ui);
    color: color-mix(in oklch, var(--color-ink) 65%, transparent);
  }

  .author-meta__item {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .author-meta__item svg {
    flex-shrink: 0;
    opacity: 0.7;
  }
</style>
