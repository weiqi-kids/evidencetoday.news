---
interface Props {
  summary: string;
}

type SummaryRender =
  | { type: 'paragraphs'; items: string[] }
  | { type: 'ul' | 'ol'; items: string[] };

const { summary } = Astro.props;

function normalize(text: string): string {
  return text.replace(/\r\n/g, '\n').trim();
}

function trimEndingPunctuation(text: string): string {
  return text.replace(/[；;，,。！？!?、：:\s]+$/u, '').trim();
}

function sanitizeItems(items: string[]): string[] {
  return items.map((item) => trimEndingPunctuation(item)).filter(Boolean);
}

function splitBySemicolon(text: string): string[] {
  return sanitizeItems(text.split(/[；;]/).map((item) => item.trim()));
}

function parseMarkdownList(lines: string[]): SummaryRender | null {
  const bulletLines = lines.filter((line) => /^\s*[-*]\s+/.test(line));
  if (bulletLines.length >= 2 && bulletLines.length === lines.length) {
    return { type: 'ul', items: sanitizeItems(bulletLines.map((line) => line.replace(/^\s*[-*]\s+/, '').trim())) };
  }

  const numberLines = lines.filter((line) => /^\s*\d+[.)]\s+/.test(line));
  if (numberLines.length >= 2 && numberLines.length === lines.length) {
    return { type: 'ol', items: sanitizeItems(numberLines.map((line) => line.replace(/^\s*\d+[.)]\s+/, '').trim())) };
  }

  return null;
}

function splitToBulletItems(text: string): string[] {
  const semicolonParts = splitBySemicolon(text);
  if (semicolonParts.length >= 2 && semicolonParts.length <= 12) {
    return semicolonParts;
  }

  const sentenceParts = text
    .split(/(?<=[。！？；;.!?])\s*/)
    .map((item) => item.trim());

  const sanitizedSentenceParts = sanitizeItems(sentenceParts);

  if (sanitizedSentenceParts.length < 2 || sanitizedSentenceParts.length > 6) {
    return [];
  }

  const validLengthItems = sanitizedSentenceParts.filter((item) => item.length >= 12);
  if (validLengthItems.length !== sanitizedSentenceParts.length) {
    return [];
  }

  return sanitizedSentenceParts;
}

function formatSummary(input: string): SummaryRender {
  const cleanSummary = normalize(input);
  const rawLines = cleanSummary.split('\n').map((line) => line.trim());
  const lines = rawLines.filter(Boolean);

  if (lines.length === 0) {
    return { type: 'paragraphs', items: [] };
  }

  const markdownList = parseMarkdownList(lines);
  if (markdownList) {
    return markdownList;
  }

  if (lines.length > 1) {
    const listishLines = lines.filter((line) => line.length >= 8);
    if (listishLines.length >= 2 && listishLines.length <= 6) {
      return { type: 'ul', items: sanitizeItems(listishLines) };
    }
    return { type: 'paragraphs', items: sanitizeItems(lines) };
  }

  const autoBulletItems = splitToBulletItems(lines[0]);
  if (autoBulletItems.length >= 2) {
    return { type: 'ul', items: sanitizeItems(autoBulletItems) };
  }

  return { type: 'paragraphs', items: sanitizeItems(lines) };
}

const formattedSummary = formatSummary(summary);
---

<aside class="summary-box" aria-label="重點摘要">
  <h2 class="summary-box__title">重點摘要</h2>
  <div class="summary-box__content">
    {formattedSummary.type === 'paragraphs' ? (
      formattedSummary.items.map((item) => <p>{item}</p>)
    ) : formattedSummary.type === 'ol' ? (
      <ol class="summary-box__list">
        {formattedSummary.items.map((item) => <li class="summary-box__item">{item}</li>)}
      </ol>
    ) : (
      <ul class="summary-box__list">
        {formattedSummary.items.map((item) => <li class="summary-box__item">{item}</li>)}
      </ul>
    )}
  </div>
</aside>

<style>
  .summary-box {
    background-color: var(--color-teal-subtle);
    border-radius: 1rem;
    padding: clamp(1rem, 0.8rem + 1vw, 1.5rem);
    border: 1px solid color-mix(in oklch, var(--color-teal) 18%, white);
  }

  .summary-box__title {
    margin: 0 0 0.75rem;
    font-family: var(--font-sans);
    font-size: var(--text-h3);
    color: var(--color-ink);
  }

  .summary-box__content {
    display: grid;
    gap: 0.75rem;
    color: var(--color-ink);
  }

  .summary-box__content p {
    margin: 0;
    font-size: var(--text-body);
    line-height: 1.8;
  }

  .summary-box__list {
    margin: 0;
    padding-inline-start: 1.35rem;
    display: grid;
    gap: 0.45rem;
    color: var(--color-ink);
  }

  .summary-box__list li::marker {
    color: color-mix(in oklch, var(--color-ink) 86%, black 14%);
  }

  .summary-box__item {
    font-size: var(--text-body);
    line-height: 1.75;
    color: var(--color-ink);
  }
</style>
