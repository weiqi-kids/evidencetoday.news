---
import TopNav from '@/components/blocks/TopNav.astro';
import Footer from '@/components/blocks/Footer.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import '@/styles/global.css';
import '@/styles/rwd-fixes.css';

/* Self-hosted fonts via fontsource */
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/700.css';
import '@fontsource/noto-sans-tc/400.css';
import '@fontsource/noto-sans-tc/700.css';
import '@fontsource/noto-serif-tc/700.css';
import '@fontsource/source-serif-4/600.css';
import '@fontsource/source-serif-4/700.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
}

const {
  title,
  description = '健康研究，白話解釋。把健康議題講得有根據，也講得讓人看得懂。',
  ogImage = '/og/index.png',
  ogType = 'website',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: '本日有據',
  alternateName: 'Evidence Today',
  url: 'https://evidencetoday.news/',
  inLanguage: 'zh-TW',
  publisher: {
    '@type': 'Organization',
    name: '本日有據',
    url: 'https://evidencetoday.news/',
  },
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://evidencetoday.news/search/?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<!doctype html>
<html lang="zh-Hant-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#103B44" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:site_name" content="本日有據 Evidence Today" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="alternate" type="application/rss+xml" title="本日有據 RSS" href="/rss.xml" />

    <JsonLd data={websiteSchema} />
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">跳到主要內容</a>
    <TopNav />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      (() => {
        const isHome = window.location.pathname === '/' || window.location.pathname === '/index.html';
        if (!isHome) return;

        const badge = document.querySelector('.hero__badge');
        if (badge) badge.textContent = '健康研究，白話解釋';

        const title = document.querySelector('.hero__title');
        if (title) {
          title.replaceChildren();
          const firstLine = document.createElement('span');
          firstLine.className = 'hero__title-line';
          firstLine.textContent = '把健康議題講得有根據';

          const secondLine = document.createElement('span');
          secondLine.className = 'hero__title-line';
          secondLine.textContent = '也講得讓人看得懂';

          title.append(firstLine, secondLine);
        }

        document.title = '本日有據 — 健康研究，白話解釋';

        const description = '健康研究，白話解釋。把健康議題講得有根據，也講得讓人看得懂。';
        document.querySelector('meta[name="description"]')?.setAttribute('content', description);
        document.querySelector('meta[property="og:description"]')?.setAttribute('content', description);
        document.querySelector('meta[name="twitter:description"]')?.setAttribute('content', description);
      })();
    </script>
    <slot name="scripts" />
  </body>
</html>
