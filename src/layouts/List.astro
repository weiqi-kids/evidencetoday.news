---
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';

interface Props {
  title: string;
  description: string;
  seoTitle?: string;
  category?: 'article' | 'myth' | 'ingredient' | 'podcast' | 'video' | 'news';
  breadcrumbItems: Array<{ label: string; href?: string }>;
  totalItems?: number;
}

const {
  title,
  description,
  seoTitle,
  category,
  breadcrumbItems,
  totalItems,
} = Astro.props;
---

<Base title={seoTitle ?? `${title} | 本日有據`} description={description}>
  <div class="list-layout container">
    <Breadcrumb items={breadcrumbItems} />

    <header class="list-header">
      {category && <div class="list-color-bar" data-category={category} />}
      <h1>{title}</h1>
      {totalItems != null && (
        <span class="list-count">{totalItems} 篇內容</span>
      )}
      <slot name="filters" />
    </header>

    <div class="list-content">
      <slot />
    </div>

    <slot name="pagination" />
  </div>
</Base>

<style>
  .list-layout {
    padding-block: var(--space-page-y);
  }

  .list-header {
    padding-block: 1.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .list-color-bar {
    width: 3rem;
    height: 4px;
    border-radius: var(--radius-pill);
  }

  .list-color-bar[data-category='article'] {
    background-color: var(--color-cat-article);
  }

  .list-color-bar[data-category='myth'] {
    background-color: var(--color-cat-myth);
  }

  .list-color-bar[data-category='ingredient'] {
    background-color: var(--color-cat-ingredient);
  }

  .list-color-bar[data-category='podcast'] {
    background-color: var(--color-cat-podcast);
  }

  .list-color-bar[data-category='video'] {
    background-color: var(--color-cat-video);
  }

  .list-color-bar[data-category='news'] {
    background-color: var(--color-cat-news);
  }

  .list-count {
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    color: color-mix(in oklch, var(--color-ink) 65%, transparent);
  }

  .list-content {
    padding-block: 1rem;
  }
</style>
