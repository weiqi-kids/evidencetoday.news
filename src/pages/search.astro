---
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Button from '@/components/ui/Button.astro';
import { getTopTags } from '@/utils/tag-stats';

const topTags = await getTopTags(12);
---

<Base title="搜尋 | 本日有據" noindex={true}>
  <div class="search-page container">
    <Breadcrumb items={[{ label: '首頁', href: '/' }, { label: '搜尋結果' }]} />

    <header class="search-header">
      <h1>搜尋</h1>
      <p class="search-header__desc">輸入關鍵字，使用 Pagefind 全文搜尋文章、趨勢、Podcast、短影音、闢謠與成分解析內容。</p>
    </header>

    <div id="search-container"></div>

    <nav class="search-fallback" aria-label="內容分類入口">
      <h2 class="search-fallback__title">瀏覽所有分類</h2>
      <div class="search-fallback__grid">
        <Button variant="secondary" href="/articles/">文章</Button>
        <Button variant="secondary" href="/myths/">闢謠</Button>
        <Button variant="secondary" href="/ingredients/">成分解析</Button>
        <Button variant="secondary" href="/podcasts/">Podcast</Button>
        <Button variant="secondary" href="/videos/">短影音</Button>
        <Button variant="secondary" href="/news/">趨勢</Button>
      </div>
    </nav>

    {topTags.length > 0 && (
      <section class="search-hot-tags" aria-label="熱門標籤">
        <h2 class="search-fallback__title">熱門標籤</h2>
        <div class="search-hot-tags__list">
          {topTags.map(({ tag }) => (
            <a href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a>
          ))}
        </div>
        <p class="search-note">若找不到結果，請嘗試同義詞或改用較短關鍵字。</p>
      </section>
    )}
  </div>
</Base>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet">
<script is:inline>
  // Pagefind UI 延後到瀏覽器閒置時再載入，避免其 JS 阻擋首屏繪製（搜尋頁的其餘內容不依賴它）。
  (() => {
    const params = new URLSearchParams(window.location.search);
    const initialQuery = params.get('q') || params.get('query') || '';

    function applyInitialQuery() {
      if (!initialQuery) return;
      requestAnimationFrame(() => {
        const input = document.querySelector(
          '#search-container input[type="text"], #search-container input[type="search"]'
        );

        if (input instanceof HTMLInputElement) {
          input.value = initialQuery;
          input.dispatchEvent(new Event('input', { bubbles: true }));
          input.dispatchEvent(new KeyboardEvent('keyup', { bubbles: true, key: 'Enter' }));
        }
      });
    }

    function initPagefind() {
      new PagefindUI({
        element: '#search-container',
        showSubResults: true,
        resetStyles: false,
        translations: {
          placeholder: '搜尋關鍵字（例如：魚油、Omega-3、三酸甘油酯、薑黃素）',
        },
        processResult: (result) => result,
      });
      applyInitialQuery();
    }

    function loadPagefind() {
      const script = document.createElement('script');
      script.src = '/pagefind/pagefind-ui.js';
      script.onload = initPagefind;
      document.head.appendChild(script);
    }

    if ('requestIdleCallback' in window) {
      requestIdleCallback(loadPagefind, { timeout: 2000 });
    } else {
      setTimeout(loadPagefind, 200);
    }
  })();
</script>

<style>
  .search-page {
    padding-block: var(--space-page-y);
    max-width: 68ch;
    margin-inline: auto;
  }

  .search-header {
    padding-block: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .search-header h1 {
    font-family: var(--font-sans);
    font-size: var(--text-h1);
    font-weight: 700;
    color: var(--color-ink);
  }

  .search-header__desc {
    color: color-mix(in oklch, var(--color-ink) 72%, transparent);
    line-height: 1.7;
  }

  #search-container {
    padding-block: 1rem 2rem;
  }

  .search-fallback,
  .search-hot-tags {
    padding-block: 1rem;
  }

  .search-fallback__title {
    font-family: var(--font-sans);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-ink);
    margin-bottom: 1rem;
  }

  .search-fallback__grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .search-hot-tags__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .search-hot-tags__list a {
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    text-decoration: none;
    background: var(--color-fog);
    border-radius: 999px;
    padding: 0.3rem 0.7rem;
    color: var(--color-ink);
  }

  .search-note {
    margin-top: 0.75rem;
    color: color-mix(in oklch, var(--color-ink) 65%, transparent);
    font-size: var(--text-meta);
  }
</style>
