---
import { getCollection, getEntry } from 'astro:content';
import Article from '@/layouts/Article.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import VerdictBadge from '@/components/ui/VerdictBadge.astro';
import { validateMythArticle } from '@/utils/myths/validate';

export async function getStaticPaths() {
  const entries = await getCollection('myths', ({ data }) => !data.draft);
  return entries.map((entry) => ({ params: { slug: entry.id.replace(/\.[^.]+$/, '') }, props: { entry } }));
}
const { entry } = Astro.props;
const d = entry.data;
const errors = validateMythArticle(entry);
if (errors.length > 0) throw new Error(`[myth:${entry.id}] ${errors.join(' | ')}`);
const canonical = `https://evidencetoday.news/myths/${entry.id.replace(/\.[^.]+$/, '')}/`;
const related = d.relatedArticles ? (await Promise.all(d.relatedArticles.map((id) => getEntry('articles', id)))).filter(Boolean) : [];
---
<Article title={d.ogTitle} description={d.ogDescription} ogImage={d.ogImage || d.shareCardImage} category="myth" publishDate={d.publishDate} updatedDate={d.updatedDate} tags={d.topicTags} breadcrumbItems={[{ label: '首頁', href: '/' }, { label: '健康迷思雷達', href: '/myths/' }, { label: d.title }]}>
  <Fragment slot="head"><meta property="article:published_time" content={d.publishDate.toISOString()} /><meta property="article:modified_time" content={d.updatedDate.toISOString()} /><meta property="article:author" content={d.author} /><meta name="keywords" content={d.topicTags.join(',')} /><JsonLd data={{ '@context':'https://schema.org','@type':'Article',headline:d.ogTitle,description:d.ogDescription,image:[d.ogImage || d.shareCardImage],datePublished:d.publishDate.toISOString(),dateModified:d.updatedDate.toISOString(),author:{'@type':'Person',name:d.author},publisher:{'@type':'Organization',name:'本日有據'},mainEntityOfPage:canonical }} /></Fragment>
  <section class="block"><h1>{d.title}</h1><p>迷思原句：{d.mythClaim}</p></section>
  <section class="block quick"><h2>30 秒快速結論</h2><p><strong>判讀結果：</strong><VerdictBadge verdict={d.verdict} /></p><p><strong>證據強度：</strong>{d.evidenceLevel}</p><p><strong>一句話結論：</strong>{d.verdictSummary}</p><ul>{d.tldr.map((item) => <li>{item}</li>)}</ul></section>
  <section class="block flow"><h2>為什麼寫這篇？網路目前如何流傳</h2><p>{d.currentSituation}</p><ul>{d.popularVersions.map((item) => <li>{item}</li>)}</ul><p>來源類型：{d.rumorSources.join('、')}｜擴散程度：{d.spreadLevel}</p></section>
  <section class="block belief"><h2>為什麼這個說法容易被相信</h2><ul>{d.whyItSpreads.map((item) => <li>{item}</li>)}</ul></section>
  <section class="block science"><h2>科學證據怎麼看</h2><p>{d.scientificEvidence}</p><ul><li>系統性回顧 / 統合分析：{d.evidencePyramid.systematicReview ?? '無'}</li><li>隨機對照試驗 RCT：{d.evidencePyramid.randomizedControlledTrial ?? '無'}</li><li>觀察性研究：{d.evidencePyramid.observationalStudy ?? '無'}</li><li>動物 / 細胞研究：{d.evidencePyramid.animalOrInVitro ?? '無'}</li><li>專家意見 / 機制推論：{d.evidencePyramid.expertOpinionOrMechanism ?? '無'}</li></ul></section>
  <section class="block"><h2>白話辯證</h2><p>{d.plainLanguageAnalysis}</p></section>
  <section class="block"><h2>適用與不適用情境</h2><div class="cols"><div><h3>適用情境</h3><ul>{d.applicableContext.map((i) => <li>{i}</li>)}</ul></div><div><h3>不適用情境</h3><ul>{d.notApplicableContext.map((i) => <li>{i}</li>)}</ul></div></div></section>
  <section class="block actions"><h2>一般人最安全做法</h2><div class="cols"><div><h3>可以做</h3><ul>{d.safeActions.map((i) => <li>{i}</li>)}</ul></div><div><h3>不建議</h3><ul>{d.avoidActions.map((i) => <li>{i}</li>)}</ul></div></div></section>
  <section class="block"><h2>一張圖看懂這則迷思</h2><p>這張圖卡整理了本篇的核心判讀。完整說明與來源請以本文內容為準。</p><img src={d.shareCardImage} alt={`${d.title}：${d.verdictSummary}`} /></section>
  <section class="block"><h2>分享這篇文章</h2><p>覺得這篇有幫助？點擊分享這則知識，讓更多人少被健康謠言誤導。</p><div class="share"><button id="share-btn" aria-label="分享這篇文章">分享這篇文章</button><button id="copy-btn" aria-label="複製連結">複製連結</button><a aria-label="傳到 LINE" target="_blank" rel="noopener noreferrer" href={`https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(canonical)}`}>傳到 LINE</a></div><p id="share-status" aria-live="polite"></p></section>
  <section class="block"><h2>來源與引用</h2><ol>{d.references.map((r)=><li><strong>{r.title}</strong>（類型：{r.sourceType}）<br/><a href={r.url} target="_blank" rel="noopener noreferrer">{r.url}</a></li>)}</ol></section>
  <section class="block"><h2>更新與更正紀錄</h2>{d.correctionLog.length===0?<p>本文目前尚無更正紀錄。</p>:<ul>{d.correctionLog.map((log)=><li>{log.date}：{log.description}</li>)}</ul>}</section>
  <section class="block"><h2>醫療聲明</h2><p>{d.medicalDisclaimer}</p></section>
  <section class="block"><h2>文章資訊</h2><p>發布日期：{d.publishDate.toISOString().slice(0,10)}</p><p>最後更新：{d.updatedDate.toISOString().slice(0,10)}</p><p>作者：{d.author}</p><p>主編：{d.editor}</p><p>內容屬性：健康教育與資訊判讀</p><p>利益揭露：本文未接受品牌贊助。</p></section>
  {related.length > 0 && <section class="block"><h2>延伸閱讀</h2><ul>{related.map((r)=><li><a href={`/articles/${r.id.replace(/\.[^.]+$/, '')}/`}>{r.data.title}</a></li>)}</ul></section>}
</Article>
<script define:vars={{ canonical, title: d.title, summary: d.verdictSummary }}>
const status = document.getElementById('share-status');
document.getElementById('share-btn')?.addEventListener('click', async () => {if (navigator.share) {await navigator.share({ title, text: summary, url: canonical }); status.textContent = '已開啟分享'; return;} await navigator.clipboard.writeText(canonical); status.textContent = '已複製連結';});
document.getElementById('copy-btn')?.addEventListener('click', async () => {await navigator.clipboard.writeText(canonical); status.textContent = '已複製連結';});
</script>
<style>.block{background:#fff;border:1px solid var(--color-fog);border-radius:var(--radius-card);padding:1rem 1.2rem}.quick{background:#edf7ff}.flow{background:#f8fafc}.belief{background:#fff8eb}.science{background:#fff}.block+.block{margin-top:1rem}.cols{display:grid;grid-template-columns:1fr 1fr;gap:1rem}.actions .cols>div:first-child{background:#effaf3;padding:.75rem;border-radius:12px}.actions .cols>div:last-child{background:#f5f6f8;padding:.75rem;border-radius:12px}.share{display:flex;gap:.75rem;flex-wrap:wrap}button,a{padding:.6rem .9rem;border-radius:10px;border:1px solid var(--color-fog);background:#fff;text-decoration:none;color:inherit}@media(max-width:700px){.cols{grid-template-columns:1fr}}</style>
