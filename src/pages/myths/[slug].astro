---
import { getCollection } from 'astro:content';
import Article from '@/layouts/Article.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { buildClaimReview, buildPerson, buildCitations, PUBLISHER_REF, WEBSITE_REF } from '@/utils/schema-org';
import { isPublicEntry } from '@/utils/visibility';
import MythSquareCardVisual from '@/components/myths/MythSquareCardVisual.astro';
import VerdictBadge from '@/components/ui/VerdictBadge.astro';
import { validateMythArticle } from '@/utils/myths/validate';
import { displayVerdict } from '@/utils/myths/schema';
import { contentSocial } from '@/utils/social-meta.mjs';
import EditButton from '@/components/editor/EditButton.svelte';
import ReadingEngagement from '@/components/blocks/ReadingEngagement.svelte';

export async function getStaticPaths() {
  const entries = await getCollection('myths', ({ data }) => isPublicEntry(data));
  return entries.map((entry) => ({ params: { slug: entry.id.replace(/\.[^.]+$/, '') }, props: { entry } }));
}

const { entry } = Astro.props;
const d = entry.data;
const social = contentSocial('myths', d, entry.id.replace(/\.[^.]+$/, ''));
const errors = validateMythArticle(entry);
if (errors.length > 0) throw new Error(`[myth:${entry.id}] ${errors.join(' | ')}`);

const canonical = `https://evidencetoday.news/myths/${entry.id.replace(/\.[^.]+$/, '')}/`;
const refs = (d.references || []).filter((r) => r?.title && r?.url);
const quickItems = d.thirtySecondConclusion?.length ? d.thirtySecondConclusion : d.tldr;
const whyItems = Array.isArray(d.whyItSpreads)
  ? d.whyItSpreads
  : [d.whyItSpreads.commonClaim, d.whyItSpreads.shortVideoVersion, d.whyItSpreads.adVersion, d.whyItSpreads.familyChatVersion].filter(Boolean);
const evidenceItems = d.evidenceSummary?.evidenceItems || [];
const shareSummary = d.cardConclusion || d.verdictSummary;
const mythCitations = buildCitations(d.references);
const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${canonical}#article`,
  headline: social.title,
  description: social.description,
  image: [social.image],
  datePublished: d.publishDate.toISOString(),
  dateModified: d.updatedDate.toISOString(),
  author: buildPerson(d.author),
  publisher: PUBLISHER_REF,
  isPartOf: WEBSITE_REF,
  ...(mythCitations ? { citation: mythCitations } : {}),
  mainEntityOfPage: canonical,
} satisfies Record<string, unknown>;
const claimReview = buildClaimReview({
  mythClaim: d.mythClaim,
  verdict: d.verdict,
  verdictSummary: d.verdictSummary,
  publishDate: d.publishDate,
  updatedDate: d.updatedDate,
  url: canonical,
  name: social.title,
});
const splitCarefulItem = (item: string) => {
  const match = item.match(/^\*\*(.+?)：\*\*\s*(.+)$/);
  return match ? { label: match[1], text: match[2] } : { label: '', text: item };
};
const sourceTypeLabels: Record<string, string> = {
  'official-agency': '官方機構健康教育資料',
  guideline: '指引或專業組織資料',
  'expert-review': '醫學機構資料',
  'systematic-review': '系統性回顧',
  'meta-analysis': '統合分析',
  rct: '隨機對照試驗',
  cohort: '世代研究',
  observational: '觀察性研究',
  'cochrane-review': 'Cochrane 系統性回顧',
  'safety-database': '安全性資料庫',
  animal: '動物研究',
  'in-vitro': '細胞或體外研究',
  'case-report': '個案報告',
};
const healthReminder = '本文為健康資訊與迷思查證，不提供個人診斷或治療建議。若你已被診斷疾病、正在服藥、懷孕、哺乳，或症狀持續未改善，請諮詢醫師、藥師或營養師。';
---

<Article title={d.title} description={social.description} seoTitle={social.title} socialTitle={social.title} socialDescription={social.description} ogImage={social.image} category="myth" variant="cards" showMedicalDisclaimer={false} publishDate={d.publishDate} updatedDate={d.updatedDate} tags={d.topicTags} breadcrumbItems={[{ label: '首頁', href: '/' }, { label: d.title }]}>
  <Fragment slot="head">
    <meta property="article:published_time" content={d.publishDate.toISOString()} />
    <meta property="article:modified_time" content={d.updatedDate.toISOString()} />
    <meta property="article:author" content={d.author} />
    <JsonLd data={[articleLd, claimReview]} />
  </Fragment>

  <section class="block quick">
    <div class="quick-panel">
      <h2>30 秒快速結論</h2>
      <div class="quick-badges">
        <VerdictBadge verdict={d.verdict} size="lg" />
        <span class="pill evidence">證據強度：{d.evidenceLevel}</span>
      </div>
    </div>
    <div>
      <ul>{quickItems.map((item) => <li>{item}</li>)}</ul>
    </div>
  </section>

  <section class="block flow">
    <h2>坊間怎麼流傳，為什麼容易相信？</h2>
    <p>{d.currentSituation}</p>
    {d.popularVersions?.length > 0 && <ul>{d.popularVersions.map((item) => <li>{item}</li>)}</ul>}
    {whyItems.map((item) => <p>{item}</p>)}
  </section>

  <section class="block science">
    <h2>科學證據怎麼看？</h2>
    {evidenceItems.length > 0 && (
      <div class="evidence-list">
        {evidenceItems.map((item, index) => (
          <article class="evidence-item">
            {index > 0 && <hr />}
            <h3>來源 {index + 1}：{item.title}</h3>
            <p><strong>研究類型：</strong>{sourceTypeLabels[item.sourceType] || item.sourceType}</p>
            <p><strong>主要發現：</strong>{item.mainFinding}</p>
          </article>
        ))}
      </div>
    )}
  </section>

  <section class="block reasoning">
    <h2>白話辯證</h2>
    {d.reasoningCards?.length ? (
      <div class="myth-reasoning-grid">
        {d.reasoningCards.map((card) => (
          <div class={`myth-reasoning-card myth-reasoning-card--${card.tone}`}>
            <h3>{card.title}</h3>
            <ul>{card.items.map((item) => <li>{item}</li>)}</ul>
          </div>
        ))}
      </div>
    ) : (
      <p>{d.plainLanguageReasoning || d.plainLanguageAnalysis}</p>
    )}
  </section>

  {d.whoShouldBeCareful?.length > 0 && <section class="block"><h2>哪些人要特別小心？</h2><ul>{d.whoShouldBeCareful.map((item) => { const carefulItem = splitCarefulItem(item); return <li>{carefulItem.label ? <><strong>{carefulItem.label}：</strong>{carefulItem.text}</> : carefulItem.text}</li>; })}</ul></section>}
  {d.faq?.length > 0 && <section class="block"><h2>FAQ</h2>{d.faq.map((item) => <article><h3>{item.question}</h3><p>{item.answer}</p></article>)}</section>}

  <section class="block share-block"><MythSquareCardVisual title={d.title} verdict={displayVerdict(d.verdict)} evidenceLevel={d.evidenceLevel} summary={d.cardConclusion || d.verdictSummary} theme={entry.id.includes('lemon') ? 'lemon' : 'vitamin'} showTitle={true} /><h2>分享這篇文章</h2><p>覺得這篇有幫助？歡迎分享給身邊也常遇到這類健康說法的人。</p><div class="share"><button id="share-btn" aria-label="分享這篇文章">分享這篇文章</button><button id="copy-btn" aria-label="複製連結">複製連結</button></div><p id="share-status" aria-live="polite"></p></section>
  {refs.length > 0 && <section class="block"><h2>References</h2><ol>{refs.map((r) => <li><strong>{r.title}</strong>{r.sourceType ? `（類型：${r.sourceType}）` : ''}{r.evidenceType ? `（證據類型：${r.evidenceType}）` : ''}<br /><a href={r.url} target="_blank" rel="noopener noreferrer">{r.url}</a></li>)}</ol></section>}
  <section class="block health-reminder"><h2>健康資訊提醒</h2><p>{healthReminder}</p></section>
  <EditButton client:idle repoPath={`src/content/myths/${entry.id}`} collection="myths" slug={entry.id.replace(/\.[^.]+$/, '')} />
  <ReadingEngagement client:idle contentType="myth" slug={entry.id.replace(/\.[^.]+$/, '')} tags={d.topicTags} author={d.author} verdict={d.verdict} evidenceLevel={d.evidenceLevel} hasRelated={false} />
</Article>
<script define:vars={{ canonical, title: d.title, summary: shareSummary }}>
const status = document.getElementById('share-status');
document.getElementById('share-btn')?.addEventListener('click', async () => { if (navigator.share) { await navigator.share({ title, text: summary, url: canonical }); status.textContent = '已開啟分享'; return; } await navigator.clipboard.writeText(canonical); status.textContent = '已複製連結'; });
document.getElementById('copy-btn')?.addEventListener('click', async () => { await navigator.clipboard.writeText(canonical); status.textContent = '已複製連結'; });
</script>
<style>
  /* ---- Base (mobile) ---- */
  .block {
    background: color-mix(in oklch, var(--color-paper) 55%, white);
    border: 1px solid var(--color-fog);
    border-radius: 14px;
    padding: clamp(1rem, 0.5rem + 2vw, 2.125rem);
    margin-top: 1rem;
    color: var(--color-ink);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .block :is(h1, h2, h3) {
    margin: 0 0 12px;
  }

  /* Quick conclusion — single column on mobile */
  .quick {
    background: color-mix(in oklch, var(--color-teal) 8%, white);
    border: 1px solid color-mix(in oklch, var(--color-teal) 24%, var(--color-fog));
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .quick-panel {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .quick-badges {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
  }

  .pill {
    display: inline-flex;
    padding: 8px 14px;
    border-radius: 999px;
    font-size: clamp(0.875rem, 0.8rem + 0.5vw, 1.125rem);
    font-weight: 700;
  }

  .evidence {
    background: color-mix(in oklch, var(--color-teal) 10%, white);
    color: var(--color-teal);
    border: 1px solid color-mix(in oklch, var(--color-teal) 28%, var(--color-fog));
  }

  .flow {
    background: color-mix(in oklch, var(--color-paper) 78%, white);
  }

  .evidence-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .evidence-item hr {
    border: 0;
    border-top: 1px solid color-mix(in oklch, var(--color-fog) 82%, var(--color-ink));
    margin: 0 0 1.25rem;
  }

  .myth-reasoning-grid {
    display: grid;
    gap: 1rem;
  }

  .myth-reasoning-card {
    border-radius: 14px;
    padding: clamp(1rem, 0.75rem + 1vw, 1.5rem);
  }

  .myth-reasoning-card--blue {
    background: color-mix(in oklch, var(--color-teal) 10%, white);
    border: 1px solid color-mix(in oklch, var(--color-teal) 28%, var(--color-fog));
  }

  .myth-reasoning-card--red {
    background: color-mix(in oklch, var(--color-coral) 9%, white);
    border: 1px solid color-mix(in oklch, var(--color-coral) 30%, var(--color-fog));
  }

  .share-block :global(.myth-visual) {
    max-width: 560px;
    margin: 0 auto 0.75rem;
  }

  .share-block,
  .share,
  .share button {
    font-size: 1rem;
  }

  .share {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    margin-top: 1rem;
  }

  .share button {
    min-height: 44px;
    padding: 0.75rem 1rem;
  }

  button {
    padding: 0.65rem 0.95rem;
    border-radius: 10px;
    border: 1px solid var(--color-fog);
    color: var(--color-ink);
    background: color-mix(in oklch, var(--color-paper) 55%, white);
  }

  #share-btn {
    border-color: var(--color-teal);
    background: var(--color-teal);
    color: white;
  }

  #copy-btn {
    border-color: var(--color-fog);
    background: color-mix(in oklch, var(--color-paper) 55%, white);
    color: var(--color-ink);
  }

  /* ---- Tablet and up (768px) ---- */
  @media (min-width: 768px) {
    .quick {
      display: grid;
      grid-template-columns: 1fr 1.25fr;
    }

    .myth-reasoning-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .share {
      flex-direction: row;
      flex-wrap: wrap;
    }

    .share button {
      flex: 1 1 160px;
    }
  }
</style>
