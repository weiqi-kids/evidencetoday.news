---
import { getCollection, getEntry } from 'astro:content';
import Article from '@/layouts/Article.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import VerdictBadge from '@/components/ui/VerdictBadge.astro';
import MythSquareCardVisual from '@/components/myths/MythSquareCardVisual.astro';
import { validateMythArticle } from '@/utils/myths/validate';
export async function getStaticPaths() { const entries = await getCollection('myths', ({ data }) => !data.draft); return entries.map((entry) => ({ params: { slug: entry.id.replace(/\.[^.]+$/, '') }, props: { entry } })); }
const { entry } = Astro.props; const d = entry.data; const errors = validateMythArticle(entry); if (errors.length > 0) throw new Error(`[myth:${entry.id}] ${errors.join(' | ')}`);
const canonical = `https://evidencetoday.news/myths/${entry.id.replace(/\.[^.]+$/, '')}/`; const related = d.relatedArticles ? (await Promise.all(d.relatedArticles.map((id) => getEntry('articles', id)))).filter(Boolean) : [];
const refs = (d.references || []).filter((r) => r?.title && r?.url);
---
<Article title={d.ogTitle} description={d.ogDescription} ogImage={d.ogImage || d.shareCardImage} category="myth" publishDate={d.publishDate} updatedDate={d.updatedDate} tags={d.topicTags} breadcrumbItems={[{ label: '首頁', href: '/' }, { label: d.title }]}>
  <Fragment slot="head"><meta property="article:published_time" content={d.publishDate.toISOString()} /><meta property="article:modified_time" content={d.updatedDate.toISOString()} /><meta property="article:author" content={d.author} /><JsonLd data={{ '@context':'https://schema.org','@type':'Article',headline:d.ogTitle,description:d.ogDescription,image:[d.ogImage || d.shareCardImage],datePublished:d.publishDate.toISOString(),dateModified:d.updatedDate.toISOString(),author:{'@type':'Person',name:d.author},publisher:{'@type':'Organization',name:'本日有據'},mainEntityOfPage:canonical }} /></Fragment>
  <section class="block"><h1>{d.title}</h1><p>迷思原句：{d.mythClaim}</p></section>
  <section class="block quick"><h2>30 秒快速結論</h2><p><strong>判讀結果：</strong><VerdictBadge verdict={d.verdict} /></p><p><strong>證據強度：</strong>{d.evidenceLevel}</p><p>{d.verdictSummary}</p><ul>{d.tldr.map((item) => <li>{item}</li>)}</ul></section>
  <section class="block flow"><h2>網路目前如何流傳</h2><p>{d.currentSituation}</p><ul>{d.popularVersions.map((item) => <li>{item}</li>)}</ul><p>常見來源：{d.rumorSources.join('、')}。這類說法常混合部分正確觀念與延伸推論，因此需要判讀。擴散程度：{d.spreadLevel}。</p></section>
  <section class="block belief"><h2>為什麼這個說法容易被相信</h2><ul>{d.whyItSpreads.map((item) => <li>{item}</li>)}</ul></section>
  <section class="block science"><h2>科學證據怎麼看</h2><p>{d.scientificEvidence}</p><ul><li>系統性回顧 / 統合分析：{d.evidencePyramid.systematicReview ?? '無'}</li><li>隨機對照試驗 RCT：{d.evidencePyramid.randomizedControlledTrial ?? '無'}</li><li>觀察性研究：{d.evidencePyramid.observationalStudy ?? '無'}</li><li>動物 / 細胞研究：{d.evidencePyramid.animalOrInVitro ?? '無'}</li><li>專家意見 / 機制推論：{d.evidencePyramid.expertOpinionOrMechanism ?? '無'}</li></ul></section>
  <section class="block"><h2>白話辯證</h2><p>{d.plainLanguageAnalysis}</p></section>
  
  <section class="block actions"><h2>一般人最安全做法</h2><div class="cols"><div><h3>可以做</h3><ul>{d.safeActions.map((i) => <li>{i}</li>)}</ul></div><div><h3>不建議</h3><ul>{d.avoidActions.map((i) => <li>{i}</li>)}</ul></div></div></section>
  <section class="block share-block"><MythSquareCardVisual title={d.title} verdict={d.verdict === '需謹慎' ? '須謹慎' : d.verdict} evidenceLevel={d.evidenceLevel} summary={d.verdictSummary} theme={entry.id.includes('lemon') ? 'lemon' : 'vitamin'} showTitle={false} /><h2>分享這篇文章</h2><p>覺得這篇有幫助？歡迎分享給身邊也常遇到這類健康說法的人。</p><div class="share"><button id="share-btn" aria-label="分享這篇文章">分享這篇文章</button><button id="copy-btn" aria-label="複製連結">複製連結</button></div><p id="share-status" aria-live="polite"></p></section>
  {refs.length > 0 && <section class="block"><h2>來源與引用</h2><ol>{refs.map((r) => <li><strong>{r.title}</strong>{r.sourceType ? `（類型：${r.sourceType}）` : ''}{r.evidenceType ? `（證據類型：${r.evidenceType}）` : ''}<br /><a href={r.url} target="_blank" rel="noopener noreferrer">{r.url}</a></li>)}</ol></section>}
  {d.correctionLog.length > 0 && <section class="block"><h2>更新與更正紀錄</h2><ul>{d.correctionLog.map((log) => <li>{log.date}：{log.description}</li>)}</ul></section>}
  {d.medicalDisclaimer && <section class="block"><h2>醫療聲明</h2><p>{d.medicalDisclaimer}</p></section>}
  <section class="block"><h2>文章資訊</h2><p>發布日期：{d.publishDate.toISOString().slice(0, 10)}</p><p>最後更新：{d.updatedDate.toISOString().slice(0, 10)}</p><p>作者：{d.author}</p><p>主編：{d.editor}</p><p>內容屬性：健康教育與資訊判讀</p><p>利益揭露：本文未接受品牌贊助。</p></section>
  {related.length > 0 && <section class="block"><h2>延伸閱讀</h2><ul>{related.map((r) => <li><a href={`/articles/${r.id.replace(/\.[^.]+$/, '')}/`}>{r.data.title}</a></li>)}</ul></section>}
</Article>
<script define:vars={{ canonical, title: d.title, summary: d.verdictSummary }}>
const status = document.getElementById('share-status');
document.getElementById('share-btn')?.addEventListener('click', async () => { if (navigator.share) { await navigator.share({ title, text: summary, url: canonical }); status.textContent = '已開啟分享'; return; } await navigator.clipboard.writeText(canonical); status.textContent = '已複製連結'; });
document.getElementById('copy-btn')?.addEventListener('click', async () => { await navigator.clipboard.writeText(canonical); status.textContent = '已複製連結'; });
</script>
<style>.block{background:#fff;border:1px solid var(--color-fog);border-radius:14px;padding:1rem 1.1rem;margin-top:1rem;display:flex;flex-direction:column;gap:.7rem}.block :is(h1,h2,h3){margin-top:0}.quick{background:#edf7ff}.quick .verdict{font-size:clamp(22px,2.8vw,34px);padding:10px 18px}.quick strong{font-size:clamp(18px,2vw,24px)}.quick p:nth-of-type(3){font-size:clamp(20px,2.2vw,28px);font-weight:700}.flow{background:#f8fafc}.belief{background:#fff8eb}.cols{display:grid;grid-template-columns:1fr 1fr;gap:.9rem}.actions .cols>div:first-child{background:#effaf3;padding:.85rem;border-radius:12px}.actions .cols>div:last-child{background:#f5f6f8;padding:.85rem;border-radius:12px}.share-block :global(.myth-visual){max-width:620px;margin:0 auto 0.75rem}.share{display:flex;gap:1rem;flex-wrap:wrap;margin-top:1.25rem}.share button{min-height:44px;padding:.75rem 1rem}button{padding:.65rem .95rem;border-radius:10px;border:1px solid var(--color-fog);background:#fff}@media(max-width:760px){.cols{grid-template-columns:1fr}.block{padding:.95rem}.share{flex-direction:column}}</style>
