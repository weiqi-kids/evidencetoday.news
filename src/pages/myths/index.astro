---
import List from '@/layouts/List.astro';
import { getCollection } from 'astro:content';
import MythSquareCardVisual from '@/components/myths/MythSquareCardVisual.astro';

const myths = (await getCollection('myths', (e) => !e.data.draft)).sort((a, b) => b.data.updatedDate.getTime() - a.data.updatedDate.getTime());
const topicOptions = [...new Set(myths.flatMap((m) => m.data.topicTags))].sort();
const themeFor = (slug:string)=> slug.includes('lemon') ? 'lemon' : slug.includes('vitamin') ? 'vitamin' : 'default';
---
<List title="健康迷思雷達" description="闢謠專區" category="myth" breadcrumbItems={[{ label: '首頁', href: '/' }, { label: '健康迷思雷達' }]} totalItems={myths.length}>
  <div class="filters"><input id="q" placeholder="搜尋標題、迷思原句、摘要、主題" /><select id="verdict"><option value="all">全部判讀</option><option value="大致正確">大致正確</option><option value="大致錯誤">大致錯誤</option><option value="證據不足">證據不足</option><option value="情境成立">情境成立</option><option value="過度簡化">過度簡化</option><option value="需謹慎">須謹慎</option></select><select id="topic"><option value="all">全部主題</option>{topicOptions.map((t) => <option value={t}>{t}</option>)}</select><select id="evidence"><option value="all">全部證據強度</option><option value="高">高</option><option value="中">中</option><option value="低">低</option><option value="資料不足">資料不足</option></select><select id="sort"><option value="new">最新更新</option><option value="old">最早更新</option></select></div>
  <div id="list" class="myths-grid">{myths.map((m) => <a href={`/myths/${m.id.replace(/\.[^.]+$/, '')}/`} class="myth-card" data-title={m.data.title} data-claim={m.data.mythClaim} data-summary={m.data.verdictSummary} data-tldr={m.data.tldr.join(' ')} data-tags={m.data.topicTags.join(' ')} data-verdict={m.data.verdict} data-evidence={m.data.evidenceLevel} data-topic={m.data.topicTags.join('|')} data-updated={m.data.updatedDate.toISOString()}><MythSquareCardVisual title={m.data.title} verdict={m.data.verdict === '需謹慎' ? '須謹慎' : m.data.verdict} evidenceLevel={m.data.evidenceLevel} summary={m.data.verdictSummary} theme={themeFor(m.id)} /></a>)}</div>
  <p id="empty" class="empty" hidden>目前沒有符合條件的闢謠文章，請調整搜尋或篩選條件。</p>
</List>
<script>
  const cards = [...document.querySelectorAll('.myth-card')];
  const [qInput, verdictSelect, topicSelect, evidenceSelect, sortSelect] = ['q', 'verdict', 'topic', 'evidence', 'sort'].map((id) => document.getElementById(id));
  const empty = document.getElementById('empty');
  const list = document.getElementById('list');

  const parseTime = (value) => {
    const time = new Date(value || 0).getTime();
    return Number.isNaN(time) ? 0 : time;
  };

  const render = () => {
    const searchQuery = qInput.value ?? '';
    const verdictFilter = verdictSelect.value || 'all';
    const topicFilter = topicSelect.value || 'all';
    const evidenceLevelFilter = evidenceSelect.value || 'all';
    const sortOrder = sortSelect.value || 'new';
    const keyword = searchQuery.trim().toLowerCase();

    const filteredCards = cards
      .filter((card) => {
        const searchableText = [
          card.dataset.title,
          card.dataset.claim,
          card.dataset.summary,
          card.dataset.tags,
          card.dataset.tldr,
        ]
          .filter(Boolean)
          .join(' ')
          .toLowerCase();

        const verdict = card.dataset.verdict === '須謹慎' ? '需謹慎' : card.dataset.verdict;
        const topicTags = (card.dataset.topic || '').split('|').filter(Boolean);

        const matchesSearch = !keyword || searchableText.includes(keyword);
        const matchesVerdict = verdictFilter === 'all' || verdict === verdictFilter;
        const matchesTopic = topicFilter === 'all' || topicTags.includes(topicFilter);
        const matchesEvidenceLevel = evidenceLevelFilter === 'all' || card.dataset.evidence === evidenceLevelFilter;

        return matchesSearch && matchesVerdict && matchesTopic && matchesEvidenceLevel;
      })
      .sort((a, b) => {
        const aTime = parseTime(a.dataset.updated);
        const bTime = parseTime(b.dataset.updated);
        return sortOrder === 'old' ? aTime - bTime : bTime - aTime;
      });

    cards.forEach((card) => {
      card.hidden = true;
    });

    filteredCards.forEach((card) => {
      card.hidden = false;
      list.appendChild(card);
    });

    list.hidden = filteredCards.length === 0;
    empty.hidden = filteredCards.length !== 0;
  };

  [qInput, verdictSelect, topicSelect, evidenceSelect, sortSelect].forEach((control) => {
    control.addEventListener('input', render);
    control.addEventListener('change', render);
  });

  render();
</script>
<style>.filters{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:.75rem;margin:1rem 0}.filters input,.filters select{padding:.68rem;border:1px solid var(--color-fog);border-radius:10px}.myths-grid{display:grid;grid-template-columns:repeat(2,minmax(0,420px));justify-content:start;gap:1rem}.myth-card{display:block;border-radius:18px;overflow:clip;transition:.2s;min-width:0;text-decoration:none}.myth-card,.myth-card *{text-decoration:none}.myth-card:hover,.myth-card:focus-visible{transform:translateY(-2px);box-shadow:var(--shadow-card-hover);outline:2px solid color-mix(in oklch,var(--color-cat-myth) 35%,white)}@media(max-width:900px){.myths-grid{grid-template-columns:1fr}}@media(max-width:640px){.filters{grid-template-columns:1fr}}</style>
