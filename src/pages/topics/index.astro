---
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { TOPICS } from '@/data/topics';
import { WEBSITE_REF, PUBLISHER_REF, SITE_URL } from '@/utils/schema-org';

const title = '健康專題｜主題整理 - 本日有據';
const description = '把同一主題的文章、闢謠、成分解析、Podcast 與短影音整理在一起，幫助讀者快速建立完整理解。';

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${SITE_URL}/topics/#collection`,
  name: '健康專題',
  description,
  url: `${SITE_URL}/topics/`,
  isPartOf: WEBSITE_REF,
  publisher: PUBLISHER_REF,
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: TOPICS.map((topic, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: `${SITE_URL}/topics/${topic.slug}/`,
      name: topic.name,
    })),
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: '健康專題', item: `${SITE_URL}/topics/` },
  ],
};
---

<Base title={title} description={description} ogTitle="健康專題｜主題整理" ogDescription={description}>
  <Fragment slot="head">
    <JsonLd data={collectionSchema} />
    <JsonLd data={breadcrumbSchema} />
  </Fragment>

  <main class="container topics-index">
    <Breadcrumb items={[{ label: '首頁', href: '/' }, { label: '健康專題' }]} />

    <header class="topics-header">
      <h1>健康專題</h1>
      <p>{description}</p>
    </header>

    <div class="topics-grid">
      {TOPICS.map((topic) => (
        <a class="topic-card" href={`/topics/${topic.slug}/`}>
          <h2>{topic.name}</h2>
          <p>{topic.intro}</p>
          <span class="topic-card__cta">查看專題 →</span>
        </a>
      ))}
    </div>
  </main>
</Base>

<style>
  .topics-index {
    padding-block: var(--space-page-y);
    display: flex;
    flex-direction: column;
    gap: clamp(1.25rem, 1rem + 1vw, 2rem);
  }

  .topics-header h1 {
    font-family: var(--font-serif);
    font-size: var(--text-h1);
    color: var(--color-ink);
    margin: 0.4rem 0 0.5rem;
  }

  .topics-header p {
    max-width: 60ch;
    font-size: var(--text-body);
    line-height: 1.8;
    color: color-mix(in oklch, var(--color-ink) 72%, transparent);
  }

  .topics-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-card-gap);
  }

  .topic-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: clamp(1.25rem, 1rem + 0.8vw, 1.75rem);
    border: 1px solid var(--color-fog);
    border-radius: var(--radius-card);
    background: white;
    text-decoration: none;
    color: inherit;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }

  .topic-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
    border-color: var(--color-teal);
  }

  .topic-card h2 {
    font-family: var(--font-sans);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-ink);
    margin: 0;
  }

  .topic-card p {
    margin: 0;
    font-size: var(--text-meta);
    line-height: 1.7;
    color: color-mix(in oklch, var(--color-ink) 70%, transparent);
  }

  .topic-card__cta {
    margin-top: auto;
    font-family: var(--font-ui);
    font-weight: 700;
    color: var(--color-teal);
  }

  @media (min-width: 640px) {
    .topics-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .topics-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
