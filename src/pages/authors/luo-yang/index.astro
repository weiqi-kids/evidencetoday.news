---
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';
import { STATIC_SOCIAL } from '@/utils/social-meta.mjs';
import JsonLd from '@/components/seo/JsonLd.astro';
import { buildPerson } from '@/utils/schema-org';

const curatedVideos = await getCollection('videos', ({ data }) => !data.draft);
const featuredVideos = curatedVideos.slice(0, 5);
const personSchema = { '@context': 'https://schema.org', ...buildPerson('羅揚') };
---

<Base title={STATIC_SOCIAL['author-luo-yang'].title} description={STATIC_SOCIAL['author-luo-yang'].description} ogTitle={STATIC_SOCIAL['author-luo-yang'].title} ogDescription={STATIC_SOCIAL['author-luo-yang'].description} ogImage={STATIC_SOCIAL['author-luo-yang'].ogPath}>
  <Fragment slot="head">
    <JsonLd data={personSchema} />
  </Fragment>
  <main class="container editor-page">
    <header class="editor-header">
      <h1>羅揚｜本日有據主編</h1>
    </header>

    <section class="editor-hero card">
      <picture class="editor-portrait">
        <source srcset="/images/authors/luo-yang.jpg" type="image/jpeg" />
        <img
          src="/images/authors/luo-yang-editor-portrait.svg"
          alt="本日有據主編羅揚"
          loading="eager"
          decoding="async"
        />
      </picture>
      <div class="editor-meta">
        <p class="hero-summary">主要負責本日有據的健康議題選題、研究資料整理與內容把關，希望把複雜的健康資訊整理成一般人看得懂、也能在生活中使用的內容。</p>
        <ul>
          <li><strong>身分：</strong>本日有據主編</li>
          <li><strong>產業經驗：</strong>長年身處營養保健產業，熟悉成分、研究與行銷話術之間的落差（<a href="/disclosure/">相關商業利益揭露</a>）</li>
          <li><strong>Podcast：</strong>《喜聞樂健》主持人</li>
          <li><strong>關注主題：</strong>健康識讀、營養科學、預防醫學、公共衛生、熟齡健康溝通、保健食品觀念</li>
          <li><strong>聯絡：</strong><a href="mailto:evidencetodaynews@gmail.com">evidencetodaynews@gmail.com</a></li>
        </ul>
      </div>
    </section>

    <section class="card section-block">
      <h2>為什麼做本日有據</h2>
      <p>現在的健康資訊很多，但真正困難的地方，常常不是找不到資料，而是不知道哪些內容可以相信、哪些只是說法很漂亮、哪些其實已經被行銷包裝過。</p>
      <p>一則研究、一段短影音、一篇文章，可能都只講了事情的一部分。有些內容看起來很專業，實際上證據並不完整；有些說法聽起來很有道理，卻忽略了適用對象、劑量、風險與生活情境。</p>
      <p>本日有據想做的，是把這些常見的健康問題整理清楚。不是製造恐慌，也不是替任何產品或立場背書，而是盡量把資料、說法與實際生活放在一起看，讓讀者能更穩定地理解健康資訊。</p>
      <p>我希望這個平台提供給讀者的，不只是更多健康知識，而是比較正確、比較可靠，也比較能用在生活中的健康判斷。</p>
    </section>

    <section class="card section-block featured-section">
      <div class="section-heading">
        <p class="section-eyebrow">Selected work</p>
        <h2>代表內容</h2>
      </div>

      <a class="podcast-card feature-link-card" href="/podcasts/">
        <div>
          <p class="card-kicker">Podcast</p>
          <h3>《喜聞樂健》</h3>
          <p>從日常健康問題出發，用比較接近聊天的方式，討論健康知識、保健觀念與判斷方式。</p>
        </div>
        <span class="cta-link">前往 Podcast 專區 →</span>
      </a>

      <div class="featured-groups">
        <article>
          <p class="card-kicker">Articles</p>
          <h3>保健食品與市場判讀</h3>
          <ul class="editor-article-list">
            <li><a href="/articles/melatonin-prescription-taiwan-gray-market/">褪黑激素在台灣是處方藥，但你可能已經從代購買了好幾瓶</a></li>
            <li><a href="/articles/krill-oil-vs-fish-oil-comparison/">南極磷蝦油vs魚油：價格貴三倍，效果有比較好嗎？</a></li>
            <li><a href="/articles/stem-cell-supplements-pseudoscience/">幹細胞保健品：台灣市場上最大膽的偽科學行銷</a></li>
          </ul>
        </article>
        <article>
          <p class="card-kicker">Articles</p>
          <h3>熟齡健康與營養</h3>
          <ul class="editor-article-list">
            <li><a href="/articles/iron-deficiency-anemia-women-supplements/">補了好幾年的鐵，血色素還是不是？你可能從來沒補到對的地方</a></li>
            <li><a href="/articles/menopause-supplement-stages-guide/">更年期保健品的最大盲點：前期、中期、後期的補充需求根本不一樣</a></li>
            <li><a href="/articles/coq10-beyond-heart-disease-after-40/">輔酶Q10不是心臟病患才要吃，40歲後你也該了解它</a></li>
          </ul>
        </article>
        <article>
          <p class="card-kicker">Articles</p>
          <h3>迷思查證與健康觀念</h3>
          <ul class="editor-article-list">
            <li><a href="/articles/supplement-felt-effect-vs-efficacy/">保健食品的「體感」到底是什麼？為什麼你的感覺不等於功效</a></li>
            <li><a href="/articles/coffee-healthy-or-not-wrong-question/">咖啡到底健不健康？我覺得這個問題本身就問錯了</a></li>
          </ul>
        </article>

        {featuredVideos.length > 0 && (
          <article>
            <p class="card-kicker">Shorts</p>
            <h3>精選短影音</h3>
            <ul class="editor-article-list compact-video-list">
              {featuredVideos.map((entry) => (
                <li>
                  <a href={`/videos/${entry.id.replace(/\.[^.]+$/, '')}/`}>
                    {entry.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </article>
        )}
      </div>

      <div class="content-actions">
        <a class="cta-link" href="/articles/?author=%E7%BE%85%E6%8F%9A">查看全部文章 →</a>
        <a class="cta-link" href="/videos/">查看全部短影音 →</a>
      </div>
    </section>

    <section class="card section-block">
      <h2>專業背景</h2>
      <ul class="plain-list">
        <li>長年身處營養保健產業，熟悉成分、研究與行銷話術之間的落差</li>
        <li>把產業內的第一線觀察，用於替讀者拆解保健資訊、看穿過度宣稱（相關商業利益揭露見 <a href="/disclosure/">利益揭露頁</a>）</li>
        <li>健康內容主編、Podcast 與健康教育內容製作經驗</li>
        <li>長期關注健康識讀、營養科學、預防醫學、公共衛生與熟齡健康溝通</li>
        <li>擅長將血液檢查、保健食品與營養議題整理成白話內容</li>
        <li>Podcast《喜聞樂健》主持人</li>
      </ul>
    </section>
  </main>
</Base>

<style>
  .editor-page {
    padding-block: var(--space-page-y);
    display: flex;
    flex-direction: column;
    gap: clamp(1.25rem, 1rem + 1vw, 2rem);
    max-width: 72rem;
  }

  .editor-header h1 {
    margin: 0;
  }

  .card {
    border: 1px solid var(--color-fog);
    border-radius: var(--radius-card);
    background: white;
    padding: clamp(1rem, 0.85rem + 0.5vw, 1.25rem);
  }

  .editor-hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    align-items: stretch;
  }

  .editor-portrait {
    display: block;
    width: 100%;
  }

  .editor-hero img {
    width: 100%;
    border-radius: var(--radius-card);
    aspect-ratio: 2 / 3;
    object-fit: cover;
    border: 1px solid var(--color-fog);
    background: white;
  }

  .editor-meta {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.75rem;
  }

  .editor-meta ul,
  .plain-list {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.3rem;
  }

  .hero-summary {
    margin: 0;
    line-height: 1.8;
  }

  .section-block {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    line-height: 1.8;
  }

  .section-block h2,
  .section-block h3,
  .section-block p {
    margin: 0;
  }

  .featured-section {
    gap: clamp(1rem, 0.8rem + 0.8vw, 1.5rem);
    padding: clamp(1.15rem, 1rem + 1.25vw, 2rem);
    background:
      radial-gradient(circle at top left, color-mix(in oklch, var(--color-teal) 10%, transparent), transparent 34%),
      #fff;
  }

  .section-heading {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .section-eyebrow,
  .card-kicker {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: color-mix(in oklch, var(--color-teal) 76%, var(--color-ink));
  }

  .podcast-card,
  .featured-groups article {
    border: 1px solid color-mix(in oklch, var(--color-fog) 86%, white);
    border-radius: var(--radius-card);
    background: color-mix(in oklch, white 94%, var(--color-fog));
    transition:
      border-color 0.16s ease,
      box-shadow 0.16s ease,
      transform 0.16s ease;
  }

  .podcast-card {
    display: grid;
    gap: 0.85rem;
    align-items: center;
    padding: clamp(1rem, 0.85rem + 0.8vw, 1.35rem);
  }

  .feature-link-card {
    color: inherit;
    text-decoration: none;
  }

  .podcast-card:hover,
  .featured-groups article:hover {
    transform: translateY(-2px);
    border-color: color-mix(in oklch, var(--color-teal) 32%, var(--color-fog));
    box-shadow: var(--shadow-card);
  }

  .podcast-card h3 {
    font-size: clamp(1.3rem, 1.1rem + 0.8vw, 1.8rem);
    line-height: 1.25;
  }

  .podcast-card p:not(.card-kicker) {
    max-width: 46rem;
    color: color-mix(in oklch, var(--color-ink) 76%, transparent);
  }

  .cta-link {
    width: fit-content;
    text-decoration: none;
    font-family: var(--font-ui);
    font-weight: 700;
    color: var(--color-ink);
    border: 1px solid var(--color-fog);
    border-radius: 999px;
    padding: 0.42rem 0.85rem;
    display: inline-flex;
    align-items: center;
    background: white;
  }

  .featured-groups {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(0.85rem, 0.7rem + 0.7vw, 1.15rem);
  }

  .featured-groups article {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    min-width: 0;
    padding: clamp(1rem, 0.9rem + 0.6vw, 1.25rem);
  }

  .featured-groups h3 {
    font-size: clamp(1.12rem, 1rem + 0.35vw, 1.35rem);
    line-height: 1.35;
  }

  .editor-article-list {
    padding-left: 1.1rem;
    margin: 0.1rem 0 0;
    display: grid;
    gap: 0.55rem;
  }

  .editor-article-list li {
    padding-left: 0.15rem;
  }

  .editor-article-list a {
    display: inline;
    line-height: 1.7;
    text-underline-offset: 0.18em;
  }

  .compact-video-list {
    gap: 0.45rem;
  }

  .content-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  @media (min-width: 768px) {
    .editor-hero {
      grid-template-columns: minmax(180px, 220px) 1fr;
    }

    .podcast-card {
      grid-template-columns: minmax(0, 1fr) auto;
    }

    .featured-groups {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1080px) {
    .featured-groups {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      align-items: stretch;
    }
  }

  @media (max-width: 640px) {
    .editor-page {
      gap: 1rem;
    }

    .podcast-card,
    .featured-groups article {
      border-radius: calc(var(--radius-card) - 0.2rem);
    }

    .cta-link {
      width: 100%;
      justify-content: center;
    }
  }
</style>
