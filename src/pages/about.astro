---
import Policy from '@/layouts/Policy.astro';

const mod = await import('../data/policies/about.md');
const Content = mod.Content;
---

<Policy title="關於本日有據" updatedDate={new Date('2026-05-20')}>
  <Content />
</Policy>


<style>
  :global(.principles-subitems) {
    margin-left: 2rem;
  }

  @media (max-width: 640px) {
    :global(.principles-subitems) {
      margin-left: 1rem;
    }
  }

  :global(.editor-profile a) {
    text-decoration: underline;
    text-underline-offset: 0.14em;
  }

  :global(ol) {
    margin-block: 1rem 1.5rem;
    padding-left: 1.5rem;
  }

  :global(.prose ul) {
    margin-block: 0.75rem 1.25rem;
  }
</style>
