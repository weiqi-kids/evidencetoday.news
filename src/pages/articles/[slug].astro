---
import { getCollection, getEntry } from 'astro:content';
import Article from '@/layouts/Article.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import TableOfContents from '@/components/blocks/TableOfContents.svelte';
import ArticleCard from '@/components/blocks/ArticleCard.astro';
import MythCard from '@/components/blocks/MythCard.astro';
import IngredientCard from '@/components/blocks/IngredientCard.astro';
import VideoCard from '@/components/blocks/VideoCard.astro';
import PodcastCard from '@/components/blocks/PodcastCard.astro';
import { fmtDate } from '@/utils/date';
import { stripPodcastSlug } from '@/utils/podcasts';
import { getArticleQueryPatternLabel } from '@/utils/article-query-patterns';
import { contentSocial } from '@/utils/social-meta.mjs';
import EditButton from '@/components/editor/EditButton.svelte';
import ReadingEngagement from '@/components/blocks/ReadingEngagement.svelte';
import { buildPerson, buildCitations, PUBLISHER_REF, WEBSITE_REF } from '@/utils/schema-org';
import { isPublicEntry } from '@/utils/visibility';

function stripExt(id: string): string {
  return id.replace(/\.[^.]+$/, '');
}

export async function getStaticPaths() {
  const entries = await getCollection('articles', ({ data }) => isPublicEntry(data));
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.[^.]+$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();
const data = entry.data;
const queryPatternLabel = getArticleQueryPatternLabel(data.queryPattern);
const social = contentSocial('articles', data, entry.id.replace(/\.[^.]+$/, ''));

const citationAnswer =
  data.aiAnswer ||
  data.quickAnswer ||
  data.citationAnswer ||
  data.summary ||
  data.tldr ||
  data.description;


/* Resolve related content */
const relatedArticles = data.relatedArticles
  ? (await Promise.all(data.relatedArticles.map((id) => getEntry('articles', id)))).filter(Boolean)
  : [];
const relatedMyths = data.relatedMyths
  ? (await Promise.all(data.relatedMyths.map((id) => getEntry('myths', id)))).filter(Boolean)
  : [];
const relatedIngredients = data.relatedIngredients
  ? (await Promise.all(data.relatedIngredients.map((id) => getEntry('ingredients', id)))).filter(Boolean)
  : [];
const relatedVideos = data.relatedVideos
  ? (await Promise.all(data.relatedVideos.map((id) => getEntry('videos', id)))).filter(Boolean)
  : [];
const relatedPodcasts = data.relatedPodcasts
  ? (await Promise.all(data.relatedPodcasts.map((id) => getEntry('podcasts', id)))).filter(Boolean)
  : [];

const hasRelated = relatedArticles.length > 0 || relatedMyths.length > 0 || relatedIngredients.length > 0 || relatedVideos.length > 0 || relatedPodcasts.length > 0;

/* JSON-LD structured data */
const slug = entry.id.replace(/\.[^.]+$/, '');
// 只有「審閱者 ≠ 作者」時才輸出 Person 層級的 reviewedBy（獨立審閱才有 E-E-A-T 價值；
// 自己審自己是 schema.org reviewedBy 的反模式，Google/LLM 會折價）。審閱者等於作者、
// 或僅 editorReviewed 時，退為機構層級（本日有據編輯室背書），誠實且不灌水。
const independentReviewer = data.reviewer && data.reviewer !== data.author;
const reviewedBy = independentReviewer
  ? buildPerson(data.reviewer)
  : data.reviewer || data.editorReviewed
    ? { '@type': 'Organization', name: '本日有據', url: 'https://evidencetoday.news/' }
    : null;
const citations = buildCitations(data.references);
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': ['Article', 'MedicalWebPage'],
  '@id': `https://evidencetoday.news/articles/${slug}/#article`,
  mainEntityOfPage: `https://evidencetoday.news/articles/${slug}/`,
  headline: data.title,
  description: data.description,
  author: buildPerson(data.author),
  ...(reviewedBy ? { reviewedBy, lastReviewed: data.updatedDate.toISOString() } : {}),
  medicalAudience: { '@type': 'MedicalAudience', audienceType: 'Patient' },
  datePublished: data.publishDate.toISOString(),
  dateModified: data.updatedDate.toISOString(),
  publisher: PUBLISHER_REF,
  isPartOf: WEBSITE_REF,
  ...(citations ? { citation: citations } : {}),
  keywords: [...(data.tags ?? []), ...(queryPatternLabel ? [queryPatternLabel] : [])],
};

const faqSchema = data.faq && data.faq.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: data.faq.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: { '@type': 'Answer', text: item.answer },
      })),
    }
  : null;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: 'https://evidencetoday.news/' },
    { '@type': 'ListItem', position: 2, name: '文章', item: 'https://evidencetoday.news/articles/' },
    { '@type': 'ListItem', position: 3, name: data.title, item: `https://evidencetoday.news/articles/${slug}/` },
  ],
};
---

<Article
  title={data.title}
  description={social.description}
  seoTitle={social.title}
  socialTitle={social.title}
  socialDescription={social.description}
  ogImage={social.image}
  category="article"
  publishDate={data.publishDate}
  updatedDate={data.updatedDate}
  author={data.author}
  reviewer={data.reviewer}
  readingTime={data.readingTime}
  editorReviewed={data.editorReviewed}
  disclosure={data.disclosure}
  tags={data.tags}
  breadcrumbItems={[
    { label: '首頁', href: '/' },
    { label: '文章', href: '/articles/' },
    { label: data.title },
  ]}
  faq={data.faq}
  references={data.references}
  citationAnswer={citationAnswer}
  queryPatternLabel={queryPatternLabel}
>
  <Fragment slot="head">
    <JsonLd data={articleSchema} />
    {faqSchema && <JsonLd data={faqSchema} />}
    <JsonLd data={breadcrumbSchema} />
  </Fragment>

  <Content />

  <Fragment slot="sidebar">
    {headings.length > 0 && (
      <TableOfContents headings={headings} client:idle />
    )}
  </Fragment>

  {hasRelated && (
    <Fragment slot="after-content">
      <section class="related-content">
        <h2 class="related-content__title">相關內容</h2>
        <div class="related-content__grid">
          {relatedArticles.map((a) => (
            <ArticleCard
              title={a.data.title}
              description={a.data.description}
              href={`/articles/${stripExt(a.id)}/`}
              category="article"
              author={a.data.author}
              date={fmtDate(a.data.publishDate)}
              editorReviewed={a.data.editorReviewed}
              coverImage={a.data.coverImage}
              coverAlt={a.data.coverAlt}
            />
          ))}
          {relatedMyths.map((m) => (
            <MythCard
              title={m.data.title}
              verdictSummary={m.data.verdictSummary}
              href={`/myths/${stripExt(m.id)}/`}
              verdict={m.data.verdict}
              date={fmtDate(m.data.publishDate)}
            />
          ))}
          {relatedIngredients.map((i) => (
            <IngredientCard
              title={i.data.title}
              description={i.data.description}
              href={`/ingredients/${stripExt(i.id)}/`}
              uses={i.data.uses}
            />
          ))}
          {relatedVideos.map((v) => (
            <VideoCard
              title={v.data.title}
              tldr={v.data.tldr}
              href={`/videos/${stripExt(v.id)}/`}
              youtubeId={v.data.youtubeId}
            />
          ))}
          {relatedPodcasts.map((p) => (
            <PodcastCard
              title={p.data.title}
              description={p.data.description}
              href={`/podcasts/${stripPodcastSlug(p.id)}/`}
              episodeNumber={p.data.episodeNumber}
              duration={p.data.duration}
            />
          ))}
        </div>
      </section>
    </Fragment>
  )}

  <EditButton client:idle repoPath={`src/content/articles/${entry.id}`} collection="articles" slug={slug} />
  <ReadingEngagement client:idle contentType="article" slug={slug} tags={data.tags} author={data.author} queryPattern={data.queryPattern} readingTime={data.readingTime} hasRelated={hasRelated} />
</Article>

<style>
  .related-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .related-content__title {
    font-family: var(--font-sans);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-ink);
  }

  .related-content__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-card-gap);
  }

  @media (min-width: 640px) {
    .related-content__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
