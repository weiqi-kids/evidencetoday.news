---
import List from '@/layouts/List.astro';
import ArticleCard from '@/components/blocks/ArticleCard.astro';
import { fmtDate } from '@/utils/date';
import { getPublishedArticles } from '@/utils/articles';
import { ARTICLE_CATEGORIES, categorizeArticles, type ArticleCategorySlug } from '@/utils/article-categories';
import { getArticleQueryPatternLabel } from '@/utils/article-query-patterns';
import { listSocial } from '@/utils/social-meta.mjs';

function stripExt(id: string): string {
  return id.replace(/\.[^.]+$/, '');
}

const articles = await getPublishedArticles();
const categorizedArticles = categorizeArticles(articles);
const articleCounts = ARTICLE_CATEGORIES.reduce<Record<ArticleCategorySlug, number>>(
  (acc, category) => {
    acc[category.slug] = categorizedArticles.filter((article) => article.categorySlug === category.slug).length;
    return acc;
  },
  {
    vitamins: 0,
    minerals: 0,
    'basic-nutrition': 0,
    antioxidant: 0,
    'health-concepts': 0,
    'health-myths': 0,
    'sleep-stress': 0,
    menopause: 0,
    'food-safety': 0,
    'oral-hygiene': 0,
  },
);
const visibleCategories = ARTICLE_CATEGORIES.filter((category) => articleCounts[category.slug] > 0);
const social = listSocial('articles');
---

<List
  title="文章"
  description={social.description}
  seoTitle={social.title}
  socialTitle={social.title}
  socialDescription={social.description}
  ogImage={social.image}
  category="article"
  breadcrumbItems={[{ label: '首頁', href: '/' }, { label: '文章' }]}
  totalItems={categorizedArticles.length}
>
  <nav class="article-tabs" aria-label="文章分類">
    <button type="button" class="article-tab" data-category="all" aria-selected="true">
      全部 <span>{categorizedArticles.length}</span>
    </button>
    {visibleCategories.map((category) => (
      <button type="button" class="article-tab" data-category={category.slug} aria-selected="false">
        {category.label} <span>{articleCounts[category.slug]}</span>
      </button>
    ))}
  </nav>

  <p id="article-category-description" class="article-category-description">顯示全部文章。</p>

  <div class="articles-grid" id="articles-grid">
    {categorizedArticles.map((a) => (
      <article class="article-card-shell" data-category={a.categorySlug}>
        <ArticleCard
          title={a.data.title}
          description={a.data.description}
          href={`/articles/${stripExt(a.id)}/`}
          category="article"
          coverImage={a.data.coverImage}
          coverAlt={a.data.coverAlt}
          author={a.data.author}
          date={fmtDate(a.data.publishDate)}
          editorReviewed={a.data.editorReviewed}
          topicLabel={a.categoryLabel}
          aeoLabel={getArticleQueryPatternLabel(a.data.queryPattern)}
        />
      </article>
    ))}
  </div>

  <p id="article-empty" class="article-empty" hidden>目前此分類沒有文章，請改看其他分類。</p>
</List>

<script is:inline define:vars={{ visibleCategories }}>
  const categoryMap = new Map(visibleCategories.map((category) => [category.slug, category]));
  const tabs = Array.from(document.querySelectorAll('.article-tab'));
  const cards = Array.from(document.querySelectorAll('.article-card-shell'));
  const emptyState = document.getElementById('article-empty');
  const description = document.getElementById('article-category-description');

  const getCategoryFromUrl = () => {
    const params = new URLSearchParams(window.location.search);
    const selected = params.get('category');

    if (!selected || !categoryMap.has(selected)) {
      return 'all';
    }

    return selected;
  };

  const applyCategory = (category) => {
    let visibleCount = 0;

    for (const tab of tabs) {
      const isSelected = tab.dataset.category === category;
      tab.setAttribute('aria-selected', isSelected ? 'true' : 'false');
    }

    for (const card of cards) {
      const shouldShow = category === 'all' || card.dataset.category === category;
      card.hidden = !shouldShow;
      if (shouldShow) visibleCount += 1;
    }

    if (description) {
      if (category === 'all') {
        description.textContent = '顯示全部文章。';
      } else {
        const item = categoryMap.get(category);
        description.textContent = item ? item.description : '顯示全部文章。';
      }
    }

    if (emptyState) {
      emptyState.hidden = visibleCount > 0;
    }
  };

  const setCategory = (category) => {
    const normalized = category === 'all' || categoryMap.has(category) ? category : 'all';
    const nextUrl = new URL(window.location.href);

    if (normalized === 'all') {
      nextUrl.searchParams.delete('category');
    } else {
      nextUrl.searchParams.set('category', normalized);
    }

    window.history.replaceState({}, '', nextUrl);
    applyCategory(normalized);
  };

  tabs.forEach((tab) => {
    tab.addEventListener('click', (event) => {
      event.preventDefault();
      setCategory(tab.dataset.category || 'all');
    });
  });

  applyCategory(getCategoryFromUrl());
</script>

<style>
  .article-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }

  .article-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border: 1px solid var(--color-fog);
    border-radius: 999px;
    padding: 0.4rem 0.85rem;
    color: var(--color-ink);
    text-decoration: none;
    font: inherit;
    font-size: var(--text-meta);
    background: #fff;
    cursor: pointer;
  }

  .article-tab span {
    color: color-mix(in oklch, var(--color-ink) 65%, transparent);
  }

  .article-tab[aria-selected='true'] {
    border-color: var(--color-teal);
    background: color-mix(in oklch, var(--color-teal) 10%, white);
  }

  .article-category-description {
    margin-bottom: 1rem;
    color: color-mix(in oklch, var(--color-ink) 72%, transparent);
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-card-gap);
  }

  .article-empty {
    margin-top: 1rem;
    padding: 0.85rem 1rem;
    border: 1px dashed var(--color-fog);
    border-radius: var(--radius-card);
    color: color-mix(in oklch, var(--color-ink) 70%, transparent);
  }

  @media (max-width: 1024px) {
    .articles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
