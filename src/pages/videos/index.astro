---
import List from '@/layouts/List.astro';
import { getCollection } from 'astro:content';
import shortsData from '@/data/youtube-shorts.json';
import { videoItemsSchema, YOUTUBE_CHANNEL_URL } from '@/lib/youtube';
import { fmtDate } from '@/utils/date';
import { VIDEO_CATEGORIES, categorizeVideos, type VideoCategorySlug } from '@/utils/videos';
import { listSocial } from '@/utils/social-meta.mjs';

const parsedVideos = videoItemsSchema.safeParse(shortsData);
const videos = parsedVideos.success ? parsedVideos.data : [];
const categorizedVideos = categorizeVideos(videos);
const videoCounts = VIDEO_CATEGORIES.reduce<Record<VideoCategorySlug, number>>(
  (acc, category) => {
    acc[category.slug] = categorizedVideos.filter((video) => video.categorySlug === category.slug).length;
    return acc;
  },
  {
    vitamins: 0,
    minerals: 0,
    'basic-nutrition': 0,
    antioxidant: 0,
    'health-concepts': 0,
    'health-myths': 0,
    'sleep-stress': 0,
    menopause: 0,
    'food-safety': 0,
    'oral-hygiene': 0,
  }
);
const visibleCategories = VIDEO_CATEGORIES.filter((category) => videoCounts[category.slug] > 0);
const curatedVideos = await getCollection('videos', ({ data }) => !data.draft);
const curatedMap = new Map(curatedVideos.map((entry) => [entry.data.youtubeId, entry]));
const stripExt = (id: string) => id.replace(/\.[^.]+$/, '');
const featuredVideoIds = [
  'why-i-make-health-shorts',
  'blanch-spinach-oxalate',
  'garlic-crush-rest-10-min',
  'okra-blanch-before-cutting',
  'sun-dried-shiitake-vitamin-d',
];
const curatedEntryMap = new Map(curatedVideos.map((entry) => [stripExt(entry.id), entry]));
const featuredVideos = featuredVideoIds.map((id) => curatedEntryMap.get(id)).filter(Boolean);
const primaryFeaturedVideo = featuredVideos[0];
const secondaryFeaturedVideos = featuredVideos.slice(1, 5);
const getVideoHref = (id: string) => `/videos/${stripExt(id)}/`;
const getVideoThumbnail = (youtubeId: string) => `https://i.ytimg.com/vi/${youtubeId}/hqdefault.jpg`;
const getVideoSummary = (entry: { data: { keyPoints?: string[]; tldr: string; description: string } }) => {
  const keyPointSummary = entry.data.keyPoints?.filter(Boolean).join(' ');
  return keyPointSummary || entry.data.tldr || entry.data.description;
};
const social = listSocial('videos');
---

<List
  title="短影音"
  description={social.description}
  seoTitle={social.title}
  socialTitle={social.title}
  socialDescription={social.description}
  ogImage={social.image}
  seoTitle="短影音｜本日有據 Evidence Today"
  category="video"
  breadcrumbItems={[{ label: '首頁', href: '/' }, { label: '短影音' }]}
  totalItems={categorizedVideos.length}
>
  <section class="videos-hero" aria-labelledby="videos-hero-title">
    <div class="videos-hero__content">
      <p class="eyebrow">本日有據 YouTube Shorts</p>
      <h2 id="videos-hero-title">30 秒抓住健康重點</h2>
      <p class="subtitle">所有影片同步來自本日有據 YouTube Shorts。</p>
      <a class="videos-hero__link" href={YOUTUBE_CHANNEL_URL} target="_blank" rel="noopener noreferrer">前往 YouTube 頻道</a>
    </div>
    <dl class="videos-hero__stats" aria-label="短影音內容統計">
      <div>
        <dt>{categorizedVideos.length}</dt>
        <dd>支短影音</dd>
      </div>
      <div>
        <dt>{visibleCategories.length}</dt>
        <dd>主題分類</dd>
      </div>
      <div>
        <dt>{curatedVideos.length}</dt>
        <dd>精選整理</dd>
      </div>
    </dl>
  </section>

  {primaryFeaturedVideo && (
    <section class="curated" aria-labelledby="curated-videos-title">
      <div class="curated__header">
        <p class="curated__eyebrow">YouTube Shorts 精選</p>
        <h2 id="curated-videos-title">精選短影音整理</h2>
      </div>

      <a class="curated-feature" href={getVideoHref(primaryFeaturedVideo.id)}>
        <div class="curated-feature__thumb">
          <img src={getVideoThumbnail(primaryFeaturedVideo.data.youtubeId)} alt={`${primaryFeaturedVideo.data.title}影片縮圖`} loading="lazy" />
          <span class="curated-play" aria-hidden="true">▶</span>
        </div>
        <div class="curated-feature__body">
          <span class="curated-feature__label">第一精選・主編本人實錄</span>
          <h3>{primaryFeaturedVideo.data.title}</h3>
          <p>{getVideoSummary(primaryFeaturedVideo)}</p>
          <span class="curated-cta">觀看重點整理 →</span>
        </div>
      </a>

      {secondaryFeaturedVideos.length > 0 && (
        <div class="curated-grid" aria-label="精選短影音整理">
          {secondaryFeaturedVideos.map((entry) => (
            <a class="curated-card" href={getVideoHref(entry.id)}>
              <div class="curated-card__thumb">
                <img src={getVideoThumbnail(entry.data.youtubeId)} alt={`${entry.data.title}影片縮圖`} loading="lazy" />
                <span class="curated-play curated-play--small" aria-hidden="true">▶</span>
              </div>
              <div class="curated-card__body">
                <h3>{entry.data.title}</h3>
                <p>{getVideoSummary(entry)}</p>
                <span class="curated-cta">觀看整理 →</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </section>
  )}

  {categorizedVideos.length === 0 ? (
    <p class="fallback">目前短影音資料暫時無法載入，請稍後再試，或前往<a href={YOUTUBE_CHANNEL_URL} target="_blank" rel="noopener noreferrer">本日有據 YouTube 頻道</a>觀看。</p>
  ) : (
    <>
      <nav class="video-tabs" aria-label="短影音分類">
        <a class="video-tab" href="/videos/" data-category="all" aria-selected="true">
          全部 <span>{categorizedVideos.length}</span>
        </a>
        {visibleCategories.map((category) => (
          <a class="video-tab" href={`/videos/?category=${category.slug}`} data-category={category.slug} aria-selected="false">
            {category.label} <span>{videoCounts[category.slug]}</span>
          </a>
        ))}
      </nav>

      <p id="video-category-description" class="video-category-description">顯示全部短影音。</p>

      <div class="videos-grid" id="videos-grid">
        {categorizedVideos.map((v) => (
          <article class="video-card" data-category={v.categorySlug}>
            <div class="video-frame">
              <iframe src={v.embedUrl} title={v.title} loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
            </div>
            <div class="video-card__body">
              <div class="video-card__meta">
                <span class="video-card__category">{v.categoryLabel}</span>
                <p>{v.publishedAt ? fmtDate(new Date(v.publishedAt)) : '日期待補'}</p>
              </div>
              <h3>{v.title}</h3>
              {curatedMap.has(v.id) && <p class="curated-link"><span class="curated-badge">已整理</span><a href={getVideoHref(curatedMap.get(v.id)?.id || '')}>看重點整理 →</a></p>}
            </div>
          </article>
        ))}
      </div>

      <p id="video-empty" class="video-empty" hidden>目前此分類沒有短影音，請改看其他分類。</p>
    </>
  )}
</List>

<script is:inline define:vars={{ visibleCategories }}>
  const categoryMap = new Map(visibleCategories.map((category) => [category.slug, category]));
  const tabs = Array.from(document.querySelectorAll('.video-tab'));
  const cards = Array.from(document.querySelectorAll('.video-card'));
  const emptyState = document.getElementById('video-empty');
  const description = document.getElementById('video-category-description');

  const getCategoryFromUrl = () => {
    const params = new URLSearchParams(window.location.search);
    const selected = params.get('category');

    if (!selected || !categoryMap.has(selected)) {
      return 'all';
    }

    return selected;
  };

  const applyCategory = (category) => {
    let visibleCount = 0;

    for (const tab of tabs) {
      const isSelected = tab.dataset.category === category;
      tab.setAttribute('aria-selected', isSelected ? 'true' : 'false');
    }

    for (const card of cards) {
      const shouldShow = category === 'all' || card.dataset.category === category;
      card.hidden = !shouldShow;
      if (shouldShow) visibleCount += 1;
    }

    if (description) {
      if (category === 'all') {
        description.textContent = '顯示全部短影音。';
      } else {
        const item = categoryMap.get(category);
        description.textContent = item ? item.description : '顯示全部短影音。';
      }
    }

    if (emptyState) {
      emptyState.hidden = visibleCount > 0;
    }
  };

  const setCategory = (category) => {
    const normalized = category === 'all' || categoryMap.has(category) ? category : 'all';
    const nextUrl = new URL(window.location.href);

    if (normalized === 'all') {
      nextUrl.searchParams.delete('category');
    } else {
      nextUrl.searchParams.set('category', normalized);
    }

    window.history.replaceState({}, '', nextUrl);
    applyCategory(normalized);
  };

  tabs.forEach((tab) => {
    tab.addEventListener('click', (event) => {
      event.preventDefault();
      setCategory(tab.dataset.category || 'all');
    });
  });

  applyCategory(getCategoryFromUrl());
</script>

<style>
  .videos-hero,
  .curated,
  .video-card,
  .video-empty {
    box-shadow: var(--shadow-card);
  }

  .videos-hero {
    position: relative;
    display: grid;
    gap: clamp(1.5rem, 3vw, 3rem);
    grid-template-columns: minmax(0, 1.35fr) minmax(16rem, 0.65fr);
    align-items: stretch;
    margin-bottom: 1.5rem;
    padding: clamp(1.25rem, 3vw, 2.25rem);
    overflow: hidden;
    border: 1px solid color-mix(in oklch, var(--color-cat-video) 24%, var(--color-fog));
    border-radius: calc(var(--radius-card) + 0.35rem);
    background:
      radial-gradient(circle at top left, color-mix(in oklch, var(--color-cat-video) 20%, transparent), transparent 34%),
      linear-gradient(135deg, #fff 0%, color-mix(in oklch, var(--color-cat-video) 8%, var(--color-paper)) 100%);
  }

  .videos-hero::after {
    content: '';
    position: absolute;
    right: -5rem;
    bottom: -7rem;
    width: 18rem;
    height: 18rem;
    border-radius: 999px;
    background: color-mix(in oklch, var(--color-coral) 14%, transparent);
    pointer-events: none;
  }

  .videos-hero__content,
  .videos-hero__stats {
    position: relative;
    z-index: 1;
  }

  .eyebrow {
    margin-bottom: 0.45rem;
    font-family: var(--font-ui);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: color-mix(in oklch, var(--color-cat-video) 76%, var(--color-ink));
    text-transform: uppercase;
  }

  .videos-hero h2 {
    max-width: 17em;
    margin: 0;
    font-size: clamp(1.75rem, 3vw, 3rem);
    line-height: 1.18;
    letter-spacing: -0.03em;
  }

  .subtitle {
    max-width: 38rem;
    margin-top: 0.85rem;
    color: color-mix(in oklch, var(--color-ink) 76%, transparent);
  }

  .videos-hero__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 1.25rem;
    border: 1px solid color-mix(in oklch, var(--color-cat-video) 42%, var(--color-ink));
    border-radius: var(--radius-pill);
    padding: 0.55rem 0.95rem;
    color: var(--color-ink);
    background: color-mix(in oklch, white 82%, var(--color-cat-video));
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    font-weight: 700;
    text-decoration: none;
  }

  .videos-hero__link:hover {
    color: var(--color-ink);
    border-color: var(--color-cat-video);
    box-shadow: var(--shadow-card-hover);
  }

  .videos-hero__stats {
    display: grid;
    gap: 0.75rem;
    align-self: stretch;
  }

  .videos-hero__stats div {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 5.25rem;
    border: 1px solid color-mix(in oklch, var(--color-cat-video) 18%, var(--color-fog));
    border-radius: var(--radius-card);
    padding: 1rem;
    background: color-mix(in oklch, white 84%, transparent);
    text-align: center;
    backdrop-filter: blur(8px);
  }

  .videos-hero__stats dt {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    line-height: 1;
    color: var(--color-cat-video);
  }

  .videos-hero__stats dd {
    margin: 0.35rem 0 0;
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    color: color-mix(in oklch, var(--color-ink) 72%, transparent);
  }

  .curated {
    display: grid;
    gap: clamp(1rem, 2vw, 1.5rem);
    margin-bottom: 1.35rem;
    border: 1px solid color-mix(in oklch, var(--color-teal) 22%, var(--color-fog));
    border-radius: var(--radius-card);
    padding: clamp(1rem, 2.5vw, 1.5rem);
    background: linear-gradient(135deg, color-mix(in oklch, var(--color-teal) 8%, #fff), #fff 64%);
  }

  .curated__header {
    max-width: 44rem;
  }

  .curated__header h2,
  .curated-feature h3,
  .curated-card h3 {
    margin: 0;
    color: var(--color-ink);
  }

  .curated__header p:last-child {
    margin: 0.45rem 0 0;
    color: color-mix(in oklch, var(--color-ink) 72%, transparent);
  }

  .curated__eyebrow,
  .curated-feature__label {
    margin: 0 0 0.35rem;
    color: color-mix(in oklch, var(--color-teal) 72%, var(--color-ink));
    font-family: var(--font-ui);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .curated-feature,
  .curated-card {
    overflow: hidden;
    border: 1px solid color-mix(in oklch, var(--color-fog) 84%, white);
    border-radius: calc(var(--radius-card) - 0.1rem);
    color: var(--color-ink);
    background: #fff;
    text-decoration: none;
    transition:
      transform 0.16s ease,
      box-shadow 0.16s ease,
      border-color 0.16s ease;
  }

  .curated-feature:hover,
  .curated-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in oklch, var(--color-teal) 38%, var(--color-fog));
    box-shadow: var(--shadow-card-hover);
  }

  .curated-feature {
    display: grid;
    grid-template-columns: minmax(16rem, 0.86fr) minmax(0, 1fr);
    align-items: stretch;
  }

  .curated-feature__thumb,
  .curated-card__thumb {
    position: relative;
    overflow: hidden;
    background: var(--color-fog);
  }

  .curated-feature__thumb {
    min-height: 17rem;
  }

  .curated-card__thumb {
    aspect-ratio: 16 / 9;
  }

  .curated-feature__thumb img,
  .curated-card__thumb img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .curated-play {
    position: absolute;
    inset: 50% auto auto 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 999px;
    color: #fff;
    background: oklch(0 0 0 / 0.48);
    font-size: 1.35rem;
    transform: translate(-50%, -50%);
  }

  .curated-play--small {
    width: 2.5rem;
    height: 2.5rem;
    font-size: 1rem;
  }

  .curated-feature__body,
  .curated-card__body {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .curated-feature__body {
    justify-content: center;
    padding: clamp(1.15rem, 3vw, 2rem);
  }

  .curated-feature h3 {
    font-size: clamp(1.45rem, 2.3vw, 2.15rem);
    line-height: 1.25;
  }

  .curated-feature p,
  .curated-card p {
    color: color-mix(in oklch, var(--color-ink) 72%, transparent);
    line-height: 1.7;
  }

  .curated-feature p {
    margin: 0.8rem 0 1rem;
  }

  .curated-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(0.85rem, 2vw, 1.1rem);
  }

  .curated-card {
    display: flex;
    flex-direction: column;
  }

  .curated-card__body {
    flex: 1;
    padding: 1rem;
  }

  .curated-card h3 {
    font-size: 1.05rem;
    line-height: 1.45;
  }

  .curated-card p {
    display: -webkit-box;
    flex: 1;
    margin: 0.55rem 0 0.85rem;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .curated-cta {
    margin-top: auto;
    color: var(--color-teal);
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    font-weight: 800;
  }

  .video-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }

  .video-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border: 1px solid color-mix(in oklch, var(--color-fog) 88%, white);
    border-radius: 999px;
    padding: 0.48rem 0.9rem;
    color: var(--color-ink);
    text-decoration: none;
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    font-weight: 650;
    background: #fff;
    box-shadow: 0 1px 2px oklch(0 0 0 / 0.04);
  }

  .video-tab span {
    color: color-mix(in oklch, var(--color-ink) 65%, transparent);
  }

  .video-tab:hover {
    border-color: color-mix(in oklch, var(--color-teal) 34%, var(--color-fog));
    color: var(--color-ink);
    box-shadow: var(--shadow-card);
  }

  .video-tab[aria-selected='true'] {
    border-color: var(--color-teal);
    background: color-mix(in oklch, var(--color-teal) 10%, white);
  }

  .video-category-description {
    margin-bottom: 1rem;
    color: color-mix(in oklch, var(--color-ink) 72%, transparent);
  }

  .videos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 14rem), 1fr));
    gap: clamp(1rem, 2vw, 1.35rem);
  }

  .video-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid color-mix(in oklch, var(--color-fog) 88%, white);
    border-radius: var(--radius-card);
    background: #fff;
    transition:
      transform 0.16s ease,
      box-shadow 0.16s ease,
      border-color 0.16s ease;
  }

  .video-card[hidden] {
    display: none;
  }

  .video-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in oklch, var(--color-cat-video) 36%, var(--color-fog));
    box-shadow: var(--shadow-card-hover);
  }

  .video-frame {
    aspect-ratio: 9 / 16;
    width: 100%;
    overflow: hidden;
    background: var(--color-fog);
  }

  .video-frame iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  .video-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 0.95rem;
  }

  .video-card__meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.55rem;
  }

  .video-card__meta p {
    margin: 0;
    font-size: var(--text-meta);
    color: color-mix(in oklch, var(--color-ink) 62%, transparent);
    white-space: nowrap;
  }

  .video-card__category {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.16rem 0.58rem;
    font-size: 0.76rem;
    font-weight: 700;
    color: color-mix(in oklch, var(--color-cat-video) 72%, var(--color-ink));
    background: color-mix(in oklch, var(--color-cat-video) 12%, white);
  }

  .video-card h3 {
    margin: 0;
    font-size: 1rem;
    line-height: 1.5;
  }

  .curated-link {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.55rem;
    align-items: center;
    margin-top: auto;
    padding-top: 0.85rem;
    font-size: var(--text-meta);
  }

  .curated-link a {
    font-weight: 700;
    text-decoration: none;
  }

  .curated-badge {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-pill);
    padding: 0.16rem 0.5rem;
    color: var(--color-paper);
    background: var(--color-teal);
    font-size: 0.72rem;
    font-weight: 700;
  }

  .video-empty {
    margin-top: 1rem;
    padding: 0.85rem 1rem;
    border: 1px dashed var(--color-fog);
    border-radius: var(--radius-card);
    color: color-mix(in oklch, var(--color-ink) 70%, transparent);
    background: #fff;
  }

  .fallback a {
    margin-left: 0.25rem;
  }

  @media (max-width: 52rem) {
    .videos-hero {
      grid-template-columns: 1fr;
    }

    .videos-hero__stats {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .curated-feature {
      grid-template-columns: 1fr;
    }

    .curated-feature__thumb {
      min-height: auto;
      aspect-ratio: 16 / 9;
    }
  }

  @media (max-width: 34rem) {
    .videos-hero__stats {
      grid-template-columns: 1fr;
    }

    .video-card__meta {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.45rem;
    }

    .curated-feature {
      grid-template-columns: 1fr;
    }

    .curated-feature__thumb {
      min-height: auto;
      aspect-ratio: 16 / 9;
    }

    .curated-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
