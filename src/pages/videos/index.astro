---
import List from '@/layouts/List.astro';
import VideoCard from '@/components/blocks/VideoCard.astro';
import { getCollection } from 'astro:content';

function stripExt(id: string): string {
  return id.replace(/\.[^.]+$/, '');
}

const videos = (await getCollection('videos', (e) => !e.data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<List
  title="短影音"
  description="三到十分鐘的影片，快速掌握一個健康主題。"
  category="video"
  breadcrumbItems={[{ label: '首頁', href: '/' }, { label: '短影音' }]}
  totalItems={videos.length}
>
  <div class="videos-grid">
    {videos.map((v) => (
      <VideoCard
        title={v.data.title}
        tldr={v.data.tldr}
        href={`/videos/${stripExt(v.id)}/`}
        youtubeId={v.data.youtubeId}
      />
    ))}
  </div>
</List>

<style>
  .videos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-card-gap);
  }

  @media (max-width: 1024px) {
    .videos-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .videos-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
