---
import { getCollection, getEntry } from 'astro:content';
import Media from '@/layouts/Media.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import TldrBox from '@/components/blocks/TldrBox.astro';
import ReferenceList from '@/components/blocks/ReferenceList.astro';
import ArticleCard from '@/components/blocks/ArticleCard.astro';
import MythCard from '@/components/blocks/MythCard.astro';
import IngredientCard from '@/components/blocks/IngredientCard.astro';
import PodcastCard from '@/components/blocks/PodcastCard.astro';

function stripExt(id: string): string {
  return id.replace(/\.[^.]+$/, '');
}

export async function getStaticPaths() {
  const entries = await getCollection('videos', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.[^.]+$/, '') },
    props: { entry },
  }));
}

function fmtDate(d: Date): string {
  return d.toISOString().slice(0, 10);
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;

/* Resolve related content */
const relatedArticles = data.relatedArticles
  ? (await Promise.all(data.relatedArticles.map((id) => getEntry('articles', id)))).filter(Boolean)
  : [];
const relatedMyths = data.relatedMyths
  ? (await Promise.all(data.relatedMyths.map((id) => getEntry('myths', id)))).filter(Boolean)
  : [];
const relatedIngredients = data.relatedIngredients
  ? (await Promise.all(data.relatedIngredients.map((id) => getEntry('ingredients', id)))).filter(Boolean)
  : [];
const relatedPodcasts = data.relatedPodcasts
  ? (await Promise.all(data.relatedPodcasts.map((id) => getEntry('podcasts', id)))).filter(Boolean)
  : [];

const hasRelated = relatedArticles.length > 0 || relatedMyths.length > 0 || relatedIngredients.length > 0 || relatedPodcasts.length > 0;

/* JSON-LD structured data */
const slug = entry.id.replace(/\.[^.]+$/, '');
const videoSchema = {
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: data.title,
  description: data.description,
  thumbnailUrl: `https://img.youtube.com/vi/${data.youtubeId}/maxresdefault.jpg`,
  uploadDate: data.publishDate.toISOString(),
  embedUrl: `https://www.youtube.com/embed/${data.youtubeId}`,
};

const videoBreadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: 'https://evidencetoday.news/' },
    { '@type': 'ListItem', position: 2, name: '短影音', item: 'https://evidencetoday.news/videos/' },
    { '@type': 'ListItem', position: 3, name: data.title, item: `https://evidencetoday.news/videos/${slug}/` },
  ],
};
---

<Media
  title={data.title}
  description={data.description}
  ogImage={data.coverImage}
  category="video"
  publishDate={data.publishDate}
  updatedDate={data.updatedDate}
  tags={data.tags}
  breadcrumbItems={[
    { label: '首頁', href: '/' },
    { label: '短影音', href: '/videos/' },
    { label: data.title },
  ]}
>
  <Fragment slot="head">
    <JsonLd data={videoSchema} />
    <JsonLd data={videoBreadcrumbSchema} />
  </Fragment>

  <Fragment slot="player">
    <div class="video-player">
      <iframe
        src={`https://www.youtube.com/embed/${data.youtubeId}`}
        title={data.title}
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>
  </Fragment>

  <TldrBox>{data.tldr}</TldrBox>

  <Content />

  <Fragment slot="after-content">
    {data.transcript && (
      <section class="video-transcript">
        <details>
          <summary class="transcript-summary">逐字稿</summary>
          <div class="transcript-content">
            <p>{data.transcript}</p>
          </div>
        </details>
      </section>
    )}

    {data.references && data.references.length > 0 && (
      <section class="video-references">
        <ReferenceList references={data.references} />
      </section>
    )}

    {hasRelated && (
      <section class="related-content">
        <h2 class="related-content__title">相關內容</h2>
        <div class="related-content__grid">
          {relatedArticles.map((a) => (
            <ArticleCard
              title={a.data.title}
              description={a.data.description}
              href={`/articles/${stripExt(a.id)}/`}
              category="article"
              author={a.data.author}
              date={fmtDate(a.data.publishDate)}
              editorReviewed={a.data.editorReviewed}
            />
          ))}
          {relatedMyths.map((m) => (
            <MythCard
              title={m.data.title}
              verdictSummary={m.data.verdictSummary}
              href={`/myths/${stripExt(m.id)}/`}
              verdict={m.data.verdict}
              date={fmtDate(m.data.publishDate)}
            />
          ))}
          {relatedIngredients.map((i) => (
            <IngredientCard
              title={i.data.title}
              description={i.data.description}
              href={`/ingredients/${stripExt(i.id)}/`}
              uses={i.data.uses}
            />
          ))}
          {relatedPodcasts.map((p) => (
            <PodcastCard
              title={p.data.title}
              description={p.data.description}
              href={`/podcasts/${stripExt(p.id)}/`}
              episodeNumber={p.data.episodeNumber}
              duration={p.data.duration}
            />
          ))}
        </div>
      </section>
    )}
  </Fragment>
</Media>

<style>
  .video-player {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 aspect ratio */
    border-radius: var(--radius-card);
    overflow: hidden;
    background-color: var(--color-fog);
  }

  .video-player iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .video-transcript {
    border: 1px solid var(--color-fog);
    border-radius: var(--radius-sm);
  }

  .transcript-summary {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    font-weight: 600;
    color: var(--color-ink);
    cursor: pointer;
    user-select: none;
    list-style: none;
  }

  .transcript-summary::-webkit-details-marker {
    display: none;
  }

  .transcript-summary::before {
    content: '\25B6';
    font-size: 0.65em;
    transition: transform 0.2s ease;
  }

  details[open] > .transcript-summary::before {
    transform: rotate(90deg);
  }

  .transcript-content {
    padding: 0 1rem 1rem;
    font-size: var(--text-meta);
    line-height: 1.8;
    color: color-mix(in oklch, var(--color-ink) 80%, transparent);
  }

  .video-references {
    margin-top: 0;
  }

  .related-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .related-content__title {
    font-family: var(--font-sans);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-ink);
  }

  .related-content__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-card-gap);
  }

  @media (max-width: 640px) {
    .related-content__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
