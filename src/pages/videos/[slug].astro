---
import { getCollection, getEntry } from 'astro:content';
import Base from '@/layouts/Base.astro';
import EditButton from '@/components/editor/EditButton.svelte';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import ArticleCard from '@/components/blocks/ArticleCard.astro';
import MythCard from '@/components/blocks/MythCard.astro';
import IngredientCard from '@/components/blocks/IngredientCard.astro';
import PodcastCard from '@/components/blocks/PodcastCard.astro';
import VideoCard from '@/components/blocks/VideoCard.astro';
import { fmtDate } from '@/utils/date';
import { stripPodcastSlug } from '@/utils/podcasts';
import type { MythVerdict } from '@/utils/myths/schema';
import { contentSocial } from '@/utils/social-meta.mjs';
import { isPublicEntry } from '@/utils/visibility';

function stripExt(id: string): string {
  return id.replace(/\.[^.]+$/, '');
}

const toTagHref = (tag: string) => `/tags/${encodeURIComponent(tag)}/`;

function parseSummary(value: string): string[] {
  return value
    .split(/\n+|(?<=[。！？])\s*/u)
    .map((line) => line.trim())
    .filter(Boolean);
}

function parseDurationToIsoDuration(value: string): string | undefined {
  const input = value.trim();
  const sec = input.match(/^(\d+)\s*(?:s|sec|secs|second|seconds|秒)$/i);
  if (sec) return `PT${sec[1]}S`;
  const min = input.match(/^(\d+)\s*(?:m|min|mins|minute|minutes|分)$/i);
  if (min) return `PT${min[1]}M`;
  const minSec = input.match(/^(\d+)[:：](\d{1,2})$/);
  if (minSec) return `PT${Number(minSec[1])}M${Number(minSec[2])}S`;
  return undefined;
}

export async function getStaticPaths() {
  const entries = await getCollection('videos', ({ data }) => isPublicEntry(data));
  return entries.map((entry) => ({ params: { slug: entry.id.replace(/\.[^.]+$/, '') }, props: { entry } }));
}

const { entry } = Astro.props;
const data = entry.data;
const social = contentSocial('videos', data, entry.id.replace(/\.[^.]+$/, ''));
const slug = stripExt(entry.id);
const summary = data.aiAnswer || data.citationAnswer || data.quickAnswer || data.tldr || data.description;
const summaryBlocks = parseSummary(summary);
const textSummary = data.tldr || data.description;
const relatedArticles = data.relatedArticles ? (await Promise.all(data.relatedArticles.map((id) => getEntry('articles', id)))).filter(Boolean) : [];
const relatedMyths = data.relatedMyths ? (await Promise.all(data.relatedMyths.map((id) => getEntry('myths', id)))).filter(Boolean) : [];
const relatedIngredients = data.relatedIngredients ? (await Promise.all(data.relatedIngredients.map((id) => getEntry('ingredients', id)))).filter(Boolean) : [];
const relatedPodcasts = data.relatedPodcasts ? (await Promise.all(data.relatedPodcasts.map((id) => getEntry('podcasts', id)))).filter(Boolean) : [];

const requestedRelatedVideos = data.relatedVideos ? (await Promise.all(data.relatedVideos.map((id) => getEntry('videos', id)))).filter(Boolean).filter((video) => stripExt(video.id) !== slug) : [];
const fallbackVideos = requestedRelatedVideos.length === 0
  ? (await getCollection('videos', ({ data: videoData }) => isPublicEntry(videoData)))
      .filter((video) => stripExt(video.id) !== slug)
      .filter((video) => video.data.tags.some((tag) => data.tags.includes(tag)))
      .slice(0, 3)
  : [];
const continueWatching = requestedRelatedVideos.length > 0 ? requestedRelatedVideos.slice(0, 3) : fallbackVideos;

const videoJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: data.title,
  description: data.description,
  thumbnailUrl: data.coverImage || `https://i.ytimg.com/vi/${data.youtubeId}/hqdefault.jpg`,
  uploadDate: data.publishDate.toISOString(),
  dateModified: (data.updatedDate ?? data.publishDate).toISOString(),
  embedUrl: `https://www.youtube.com/embed/${data.youtubeId}`,
  contentUrl: `https://www.youtube.com/watch?v=${data.youtubeId}`,
  inLanguage: 'zh-TW',
  duration: data.duration ? parseDurationToIsoDuration(data.duration) : undefined,
  publisher: {
    '@type': 'Organization',
    name: '本日有據',
    url: 'https://evidencetoday.news/',
  },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: 'https://evidencetoday.news/' },
    { '@type': 'ListItem', position: 2, name: '短影音', item: 'https://evidencetoday.news/videos/' },
    { '@type': 'ListItem', position: 3, name: data.title, item: `https://evidencetoday.news/videos/${slug}/` },
  ],
};

const hasRelatedContent = relatedArticles.length || relatedMyths.length || relatedIngredients.length || relatedPodcasts.length;
---

<Base title={social.title} description={social.description} ogTitle={social.title} ogDescription={social.description} ogImage={social.image} ogType="article">
  <Fragment slot="head">
    <JsonLd data={videoJsonLd} />
    <JsonLd data={breadcrumbJsonLd} />
  </Fragment>
  <article class="video-article container">
    <Breadcrumb items={[{ label: '首頁', href: '/' }, { label: '短影音', href: '/videos/' }, { label: data.title }]} />
    <header class="video-hero">
      <p class="eyebrow">短影音</p>
      <h1>{data.title}</h1>
      <p>{data.description}</p>
      <p class="video-meta">發布日：{fmtDate(data.publishDate)}{data.updatedDate ? ` · 更新日：${fmtDate(data.updatedDate)}` : ''}</p>
    </header>

    <section class="video-player">
      <div class="video-frame">
        <iframe src={`https://www.youtube.com/embed/${data.youtubeId}`} title={data.title} loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
      </div>
    </section>

    <section class="video-summary"><h2>重點摘要</h2>{summaryBlocks.length > 1 ? <ul>{summaryBlocks.map((item) => <li>{item}</li>)}</ul> : <p>{summaryBlocks[0]}</p>}</section>
    {data.keyPoints && data.keyPoints.length > 0 && <section class="video-key-points"><h2>30 秒重點</h2><ul>{data.keyPoints.map((point) => <li>{point}</li>)}</ul></section>}
    <section class="video-body-summary"><h2>文字摘要</h2><p>{textSummary}</p></section>

    {data.transcript && <details class="video-transcript"><summary>完整逐字稿</summary><p>{data.transcript}</p></details>}

    <section class="video-related">
      <h2>延伸閱讀與繼續看</h2>
      {hasRelatedContent ? <div class="related-grid">{relatedArticles.map((item) => <ArticleCard title={item.data.title} description={item.data.description} href={`/articles/${stripExt(item.id)}/`} category="article" coverImage={item.data.coverImage} coverAlt={item.data.coverAlt} author={item.data.author} date={fmtDate(item.data.publishDate)} editorReviewed={item.data.editorReviewed} />)}{relatedMyths.map((item) => <MythCard title={item.data.title} verdictSummary={item.data.verdictSummary} href={`/myths/${stripExt(item.id)}/`} verdict={item.data.verdict as MythVerdict} date={fmtDate(item.data.publishDate)} />)}{relatedIngredients.map((item) => <IngredientCard title={item.data.title} description={item.data.description} href={`/ingredients/${stripExt(item.id)}/`} uses={item.data.uses} coverImage={item.data.coverImage} coverAlt={item.data.coverAlt} />)}{relatedPodcasts.map((item) => <PodcastCard title={item.data.title} description={item.data.description} href={`/podcasts/${stripPodcastSlug(item.id)}/`} episodeNumber={item.data.episodeNumber} duration={item.data.duration} publishDate={item.data.publishDate} />)}</div> : <div><h3>相關主題</h3><div class="tag-list">{data.tags.map((tag) => <a href={toTagHref(tag)}>{tag}</a>)}</div></div>}
      {continueWatching.length > 0 && <div><h3>繼續看短影音</h3><div class="related-grid">{continueWatching.map((item) => <VideoCard title={item.data.title} tldr={item.data.tldr} href={`/videos/${stripExt(item.id)}/`} youtubeId={item.data.youtubeId} />)}</div></div>}
    </section>
  </article>
  <EditButton client:idle repoPath={`src/content/videos/${entry.id}`} collection="videos" slug={slug} />
</Base>

<style>
.video-article{
  padding-block:clamp(1.75rem,1.2rem + 2vw,4rem);
  display:flex;
  flex-direction:column;
  gap:clamp(1.1rem,.9rem + .8vw,1.9rem);
}
.video-hero,.video-summary,.video-key-points,.video-body-summary,.video-transcript,.video-related{
  max-width:min(100%,64rem);
  margin-inline:auto;
  width:100%;
  background:var(--color-paper);
  border:1px solid var(--color-fog);
  border-radius:var(--radius-card);
  padding:clamp(1.15rem,.9rem + 1.2vw,2rem);
}
.video-hero{
  display:flex;
  flex-direction:column;
  gap:.65rem;
}
.video-hero h1{
  max-width:18ch;
  line-height:1.08;
}
.video-hero > p:not(.eyebrow):not(.video-meta){
  max-width:54rem;
  line-height:1.75;
}
.eyebrow{color:var(--color-cat-video);font-size:var(--text-meta)}
.video-meta{font-size:var(--text-meta);color:color-mix(in oklch,var(--color-ink) 72%,transparent)}
.video-player{max-width:min(100%,64rem);margin-inline:auto;width:100%}
.video-frame{width:min(100%,28rem);margin-inline:auto;aspect-ratio:9/16;border-radius:var(--radius-card);overflow:hidden;background:var(--color-fog)}
.video-frame iframe{width:100%;height:100%;border:0}
.video-summary h2,.video-key-points h2,.video-body-summary h2,.video-related h2{margin-bottom:.75rem}
.video-summary ul,.video-key-points ul{padding-left:1.15rem;line-height:1.8}
.video-summary li,.video-key-points li{padding-left:.25rem;margin-block:.25rem}
.video-body-summary p,.video-transcript p{line-height:1.85}
.video-related{display:flex;flex-direction:column;gap:clamp(1.1rem,.9rem + .8vw,1.6rem)}
.related-grid{display:grid;grid-template-columns:1fr;gap:1rem}.tag-list{display:flex;flex-wrap:wrap;gap:.6rem}.tag-list a{background:var(--color-teal-subtle);color:var(--color-navy);padding:.4rem .75rem;border-radius:999px;text-decoration:none}
@media (min-width:768px){.related-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.video-frame{width:min(64vw,30rem)}}
@media (min-width:1024px){.video-article{gap:clamp(1.4rem,1rem + 1vw,2.2rem)}.video-frame{width:min(42vw,32rem)}}
@media (min-width:1280px){.video-frame{width:30rem}.video-related{max-width:min(100%,70rem)}}
@media (max-width:520px){.video-article{padding-inline:.75rem}.video-hero h1{max-width:100%;font-size:clamp(2.15rem,1.7rem + 6vw,3rem)}.video-frame{width:min(100%,24rem)}.video-summary ul,.video-key-points ul{padding-left:1rem}}
</style>
