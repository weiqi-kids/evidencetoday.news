---
import { getCollection, getEntry } from 'astro:content';
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import ArticleCard from '@/components/blocks/ArticleCard.astro';
import MythCard from '@/components/blocks/MythCard.astro';
import IngredientCard from '@/components/blocks/IngredientCard.astro';
import VideoCard from '@/components/blocks/VideoCard.astro';
import PodcastCard from '@/components/blocks/PodcastCard.astro';
import { fmtDate } from '@/utils/date';

function stripExt(id: string): string {
  return id.replace(/\.[^.]+$/, '');
}

export async function getStaticPaths() {
  const entries = await getCollection('news', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.[^.]+$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;
const slug = entry.id.replace(/\.[^.]+$/, '');

/* Resolve related content */
const relatedArticles = data.relatedArticles
  ? (await Promise.all(data.relatedArticles.map((id) => getEntry('articles', id)))).filter(Boolean)
  : [];
const relatedMyths = data.relatedMyths
  ? (await Promise.all(data.relatedMyths.map((id) => getEntry('myths', id)))).filter(Boolean)
  : [];
const relatedIngredients = data.relatedIngredients
  ? (await Promise.all(data.relatedIngredients.map((id) => getEntry('ingredients', id)))).filter(Boolean)
  : [];
const relatedVideos = data.relatedVideos
  ? (await Promise.all(data.relatedVideos.map((id) => getEntry('videos', id)))).filter(Boolean)
  : [];
const relatedPodcasts = data.relatedPodcasts
  ? (await Promise.all(data.relatedPodcasts.map((id) => getEntry('podcasts', id)))).filter(Boolean)
  : [];

const hasRelated = relatedArticles.length > 0 || relatedMyths.length > 0 || relatedIngredients.length > 0 || relatedVideos.length > 0 || relatedPodcasts.length > 0;

/* JSON-LD */
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: data.title,
  description: data.summary,
  author: { '@type': 'Organization', name: data.source },
  datePublished: data.publishDate.toISOString(),
  publisher: {
    '@type': 'Organization',
    name: '本日有據',
    url: 'https://evidencetoday.news',
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: 'https://evidencetoday.news/' },
    { '@type': 'ListItem', position: 2, name: '趨勢', item: 'https://evidencetoday.news/news/' },
    { '@type': 'ListItem', position: 3, name: data.title, item: `https://evidencetoday.news/news/${slug}/` },
  ],
};
---

<Base title={`${data.title} | 本日有據`} description={data.summary} ogType="article">
  <Fragment slot="head">
    <JsonLd data={articleSchema} />
    <JsonLd data={breadcrumbSchema} />
  </Fragment>

  <div class="news-detail container">
    <Breadcrumb items={[
      { label: '首頁', href: '/' },
      { label: '趨勢', href: '/news/' },
      { label: data.title },
    ]} />

    <article class="news-article">
      <header class="news-article__header">
        <div class="news-article__bar"></div>
        <div class="news-article__meta">
          <span class="news-article__source">{data.source}</span>
          <span aria-hidden="true">&middot;</span>
          <time>{fmtDate(data.publishDate)}</time>
        </div>
        <h1 class="news-article__title">{data.title}</h1>
        <p class="news-article__summary">{data.summary}</p>
        {data.tags.length > 0 && (
          <div class="news-article__tags">
            {data.tags.map((tag) => (
              <span class="news-article__tag">{tag}</span>
            ))}
          </div>
        )}
      </header>

      {data.editorComment && (
        <blockquote class="editor-comment">
          <span class="editor-comment__label">主編觀點</span>
          <p>{data.editorComment}</p>
        </blockquote>
      )}

      <div class="news-article__body prose">
        <Content />
      </div>
    </article>

    {hasRelated && (
      <section class="related-section">
        <h2 class="related-section__title">你可能想看</h2>
        <div class="related-grid">
          {relatedArticles.map((a) => (
            <ArticleCard
              title={a.data.title}
              description={a.data.description}
              href={`/articles/${stripExt(a.id)}/`}
              category="article"
              author={a.data.author}
              date={fmtDate(a.data.publishDate)}
              editorReviewed={a.data.editorReviewed}
            />
          ))}
          {relatedMyths.map((m) => (
            <MythCard
              title={m.data.title}
              verdictSummary={m.data.verdictSummary}
              href={`/myths/${stripExt(m.id)}/`}
              verdict={m.data.verdict}
              date={fmtDate(m.data.publishDate)}
            />
          ))}
          {relatedIngredients.map((i) => (
            <IngredientCard
              title={i.data.title}
              description={i.data.description}
              href={`/ingredients/${stripExt(i.id)}/`}
              uses={i.data.uses}
            />
          ))}
          {relatedVideos.map((v) => (
            <VideoCard
              title={v.data.title}
              tldr={v.data.tldr}
              href={`/videos/${stripExt(v.id)}/`}
              youtubeId={v.data.youtubeId}
            />
          ))}
          {relatedPodcasts.map((p) => (
            <PodcastCard
              title={p.data.title}
              description={p.data.description}
              href={`/podcasts/${stripExt(p.id)}/`}
              episodeNumber={p.data.episodeNumber}
              duration={p.data.duration}
            />
          ))}
        </div>
      </section>
    )}
  </div>
</Base>

<style>
  .news-detail {
    padding-block: var(--space-page-y);
  }

  .news-article {
    max-width: 72ch;
    margin: 0 auto;
  }

  .news-article__header {
    padding-block: 1.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .news-article__bar {
    width: 3rem;
    height: 4px;
    border-radius: var(--radius-pill);
    background-color: var(--color-cat-news);
  }

  .news-article__meta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    color: color-mix(in oklch, var(--color-ink) 55%, transparent);
  }

  .news-article__source {
    font-weight: 600;
  }

  .news-article__title {
    font-family: var(--font-sans);
    font-size: var(--text-h1);
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.3;
  }

  .news-article__summary {
    font-size: var(--text-body);
    color: color-mix(in oklch, var(--color-ink) 70%, transparent);
    line-height: 1.7;
  }

  .news-article__tags {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .news-article__tag {
    display: inline-flex;
    align-items: center;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-ui);
    font-size: var(--text-badge);
    font-weight: 500;
    line-height: 1.4;
    white-space: nowrap;
    background-color: color-mix(in oklch, var(--color-cat-news) 14%, white);
    color: var(--color-cat-news);
  }

  .editor-comment {
    margin: 0 0 2rem;
    padding: 1.25rem 1.5rem;
    background-color: var(--color-paper);
    border-left: 4px solid var(--color-cat-news);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .editor-comment__label {
    font-family: var(--font-ui);
    font-size: var(--text-badge);
    font-weight: 700;
    color: var(--color-cat-news);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .editor-comment p {
    margin: 0;
    font-size: var(--text-meta);
    color: color-mix(in oklch, var(--color-ink) 75%, transparent);
    line-height: 1.7;
  }

  .news-article__body {
    padding-block: 1rem 3rem;
  }

  /* Related */
  .related-section {
    max-width: 72ch;
    margin: 0 auto;
    padding-block: 2rem 0;
    border-top: 2px solid var(--color-fog);
  }

  .related-section__title {
    font-family: var(--font-sans);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-ink);
    margin-bottom: 1.25rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-card-gap);
  }

  @media (max-width: 640px) {
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
