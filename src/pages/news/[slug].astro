---
import { getCollection, getEntry } from 'astro:content';
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import ArticleCard from '@/components/blocks/ArticleCard.astro';
import MythCard from '@/components/blocks/MythCard.astro';
import IngredientCard from '@/components/blocks/IngredientCard.astro';
import VideoCard from '@/components/blocks/VideoCard.astro';
import PodcastCard from '@/components/blocks/PodcastCard.astro';
import { fmtDate } from '@/utils/date';
import { getDisplayTitle, getNewsCategory, getNewsHeroImage } from '@/utils/news';
import { stripPodcastSlug } from '@/utils/podcasts';

function stripExt(id: string): string {
  return id.replace(/\.[^.]+$/, '');
}

export async function getStaticPaths() {
  const entries = await getCollection('news', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.[^.]+$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;
const slug = entry.id.replace(/\.[^.]+$/, '');

const displayTitle = getDisplayTitle(data.titleDisplay, data.title);
const category = getNewsCategory(data.tags, data.category);
const heroImage = getNewsHeroImage(data.heroImage, data.thumbnail, data.tags, data.category);

/* Resolve related content */
const relatedArticles = data.relatedArticles
  ? (await Promise.all(data.relatedArticles.map((id) => getEntry('articles', id)))).filter(Boolean)
  : [];
const relatedMyths = data.relatedMyths
  ? (await Promise.all(data.relatedMyths.map((id) => getEntry('myths', id)))).filter(Boolean)
  : [];
const relatedIngredients = data.relatedIngredients
  ? (await Promise.all(data.relatedIngredients.map((id) => getEntry('ingredients', id)))).filter(Boolean)
  : [];
const relatedVideos = data.relatedVideos
  ? (await Promise.all(data.relatedVideos.map((id) => getEntry('videos', id)))).filter(Boolean)
  : [];
const relatedPodcasts = data.relatedPodcasts
  ? (await Promise.all(data.relatedPodcasts.map((id) => getEntry('podcasts', id)))).filter(Boolean)
  : [];

const hasRelated = relatedArticles.length > 0 || relatedMyths.length > 0 || relatedIngredients.length > 0 || relatedVideos.length > 0 || relatedPodcasts.length > 0;

/* Meta description */
const metaDesc = (data.subtitle || data.summary || '').slice(0, 140);

/* JSON-LD */
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: displayTitle,
  description: metaDesc,
  image: new URL(heroImage, 'https://evidencetoday.news').href,
  author: { '@type': 'Organization', name: '本日有據' },
  datePublished: data.publishDate.toISOString(),
  publisher: {
    '@type': 'Organization',
    name: '本日有據',
    url: 'https://evidencetoday.news',
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: 'https://evidencetoday.news/' },
    { '@type': 'ListItem', position: 2, name: '趨勢', item: 'https://evidencetoday.news/news/' },
    { '@type': 'ListItem', position: 3, name: displayTitle, item: `https://evidencetoday.news/news/${slug}/` },
  ],
};
---

<Base title={`${displayTitle} | 本日有據`} description={metaDesc} ogImage={data.heroImage || data.thumbnail || `/og/index.png`} ogType="article">
  <Fragment slot="head">
    <JsonLd data={articleSchema} />
    <JsonLd data={breadcrumbSchema} />
  </Fragment>

  <div class="news-detail container">
    <Breadcrumb items={[
      { label: '首頁', href: '/' },
      { label: '趨勢', href: '/news/' },
      { label: displayTitle },
    ]} />

    <article class="news-article">
      {/* ---- Hero ---- */}
      <header class="news-article__header">
        <span class="news-article__cat">{category}</span>
        <h1 class="news-article__title">{displayTitle}</h1>
        {data.subtitle && (
          <p class="news-article__subtitle">{data.subtitle}</p>
        )}
        <div class="news-article__meta">
          <time>{fmtDate(data.publishDate)}</time>
          {data.sourceUrl && (
            <>
              <span aria-hidden="true">&middot;</span>
              <a href={data.sourceUrl} target="_blank" rel="noopener noreferrer" class="news-article__source-link">原始來源</a>
            </>
          )}
        </div>
      </header>

      {/* ---- Hero image ---- */}
      <div class="news-article__hero-img">
        <img src={heroImage} alt={displayTitle} loading="eager" />
      </div>

      {/* ---- Intro ---- */}
      {data.intro && (
        <div class="news-article__intro">
          <p>{data.intro}</p>
        </div>
      )}

      {/* ---- 先看懂這個詞 ---- */}
      {data.termBox && data.termBox.length > 0 && (
        <aside class="term-box">
          <h2 class="term-box__heading">先看懂這個詞</h2>
          <dl class="term-box__list">
            {data.termBox.map((item) => (
              <>
                <dt class="term-box__term">{item.term}</dt>
                <dd class="term-box__def">{item.definition}</dd>
              </>
            ))}
          </dl>
        </aside>
      )}

      {/* ---- Body (Markdown content) ---- */}
      <div class="news-article__body prose">
        <Content />
      </div>

      {/* ---- 證據提醒 ---- */}
      {data.evidenceNote && (
        <aside class="evidence-note">
          <h2 class="evidence-note__heading">證據提醒</h2>
          <p class="evidence-note__text">{data.evidenceNote}</p>
        </aside>
      )}

      {/* ---- 我的觀點與行動建議 ---- */}
      {data.editorComment && (
        <aside class="editor-action">
          <h2 class="editor-action__heading">我的觀點與行動建議</h2>
          <div class="editor-action__content">
            {data.editorComment.split('\n\n').map((para) => (
              <p>{para}</p>
            ))}
          </div>
        </aside>
      )}

      {/* ---- 資料來源 ---- */}
      {data.pmid && (
        <footer class="source-ref">
          <h2 class="source-ref__heading">資料來源</h2>
          <p class="source-ref__link">
            PubMed PMID：<a href={`https://pubmed.ncbi.nlm.nih.gov/${data.pmid}/`} target="_blank" rel="noopener noreferrer">{data.pmid}</a>
          </p>
        </footer>
      )}
    </article>

    {/* ---- Related ---- */}
    {hasRelated && (
      <section class="related-section">
        <h2 class="related-section__title">你可能想看</h2>
        <div class="related-grid">
          {relatedArticles.map((a) => (
            <ArticleCard
              title={a.data.title}
              description={a.data.description}
              href={`/articles/${stripExt(a.id)}/`}
              category="article"
              author={a.data.author}
              date={fmtDate(a.data.publishDate)}
              editorReviewed={a.data.editorReviewed}
            />
          ))}
          {relatedMyths.map((m) => (
            <MythCard
              title={m.data.title}
              verdictSummary={m.data.verdictSummary}
              href={`/myths/${stripExt(m.id)}/`}
              verdict={m.data.verdict}
              date={fmtDate(m.data.publishDate)}
            />
          ))}
          {relatedIngredients.map((i) => (
            <IngredientCard
              title={i.data.title}
              description={i.data.description}
              href={`/ingredients/${stripExt(i.id)}/`}
              uses={i.data.uses}
            />
          ))}
          {relatedVideos.map((v) => (
            <VideoCard
              title={v.data.title}
              tldr={v.data.tldr}
              href={`/videos/${stripExt(v.id)}/`}
              youtubeId={v.data.youtubeId}
            />
          ))}
          {relatedPodcasts.map((p) => (
            <PodcastCard
              title={p.data.title}
              description={p.data.description}
              href={`/podcasts/${stripPodcastSlug(p.id)}/`}
              episodeNumber={p.data.episodeNumber}
              duration={p.data.duration}
            />
          ))}
        </div>
      </section>
    )}
  </div>
</Base>

<style>
  .news-detail {
    padding-block: var(--space-page-y);
  }

  .news-article {
    max-width: 52rem;
    margin: 0 auto;
  }

  /* ---- Header / Hero ---- */
  .news-article__header {
    padding-block: 1.5rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .news-article__cat {
    display: inline-flex;
    align-self: flex-start;
    padding: 0.2rem 0.65rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    color: white;
    background: color-mix(in oklch, var(--color-cat-news) 90%, black);
  }

  .news-article__title {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.35;
  }

  .news-article__subtitle {
    font-size: var(--text-body);
    color: color-mix(in oklch, var(--color-ink) 65%, transparent);
    line-height: 1.7;
  }

  .news-article__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    color: color-mix(in oklch, var(--color-ink) 50%, transparent);
  }

  .news-article__source-link {
    color: var(--color-teal);
    font-weight: 500;
  }

  /* ---- Hero image ---- */
  .news-article__hero-img {
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-card);
    overflow: hidden;
    background: var(--color-fog);
    margin-bottom: 2rem;
  }

  .news-article__hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ---- Intro ---- */
  .news-article__intro {
    margin-bottom: 1.75rem;
  }

  .news-article__intro p {
    font-size: 1.05rem;
    color: color-mix(in oklch, var(--color-ink) 80%, transparent);
    line-height: 1.85;
  }

  /* ---- 先看懂這個詞 ---- */
  .term-box {
    margin-bottom: 2rem;
    padding: 1.25rem 1.5rem;
    background: color-mix(in oklch, var(--color-cat-news) 6%, var(--color-paper));
    border-radius: var(--radius-sm);
    border: 1px solid color-mix(in oklch, var(--color-cat-news) 15%, transparent);
  }

  .term-box__heading {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-cat-news);
    margin-bottom: 0.75rem;
  }

  .term-box__list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .term-box__term {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    font-weight: 700;
    color: var(--color-ink);
  }

  .term-box__def {
    font-size: var(--text-meta);
    color: color-mix(in oklch, var(--color-ink) 70%, transparent);
    line-height: 1.7;
    margin-bottom: 0.25rem;
  }

  /* ---- Body ---- */
  .news-article__body {
    max-width: 52rem;
    padding-block: 0 2rem;
  }

  /* ---- 證據提醒 ---- */
  .evidence-note {
    margin-bottom: 2rem;
    padding: 1.25rem 1.5rem;
    background: color-mix(in oklch, var(--color-fog) 50%, white);
    border-radius: var(--radius-sm);
    border-left: 3px solid var(--color-fog);
  }

  .evidence-note__heading {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 700;
    color: color-mix(in oklch, var(--color-ink) 65%, transparent);
    margin-bottom: 0.5rem;
  }

  .evidence-note__text {
    font-size: var(--text-meta);
    color: color-mix(in oklch, var(--color-ink) 65%, transparent);
    line-height: 1.75;
  }

  /* ---- 資料來源 ---- */
  .source-ref {
    margin-bottom: 2.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-fog);
  }

  .source-ref__heading {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 700;
    color: color-mix(in oklch, var(--color-ink) 55%, transparent);
    margin-bottom: 0.5rem;
  }

  .source-ref__link {
    font-size: var(--text-meta);
    color: color-mix(in oklch, var(--color-ink) 60%, transparent);
  }

  .source-ref__link a {
    color: var(--color-teal);
  }

  /* ---- 我的觀點與行動建議 ---- */
  .editor-action {
    margin: 0 0 2.5rem;
    padding: clamp(1.25rem, 0.75rem + 1.5vw, 1.75rem);
    background: color-mix(in oklch, var(--color-teal) 6%, var(--color-paper));
    border-left: 4px solid var(--color-teal);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .editor-action__heading {
    font-family: var(--font-sans);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-teal);
    margin-bottom: 0.75rem;
  }

  .editor-action__content p {
    font-size: var(--text-body);
    color: color-mix(in oklch, var(--color-ink) 80%, transparent);
    line-height: 1.8;
    margin-bottom: 0.75rem;
  }

  .editor-action__content p:last-child {
    margin-bottom: 0;
  }

  /* ---- Related ---- */
  .related-section {
    max-width: 52rem;
    margin: 0 auto;
    padding-block: 2rem 0;
    border-top: 2px solid var(--color-fog);
  }

  .related-section__title {
    font-family: var(--font-sans);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-ink);
    margin-bottom: 1.25rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-card-gap);
  }

  @media (min-width: 640px) {
    .news-article__title {
      font-size: clamp(1.5rem, 1.2rem + 1.5vw, 2.25rem);
    }

    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
