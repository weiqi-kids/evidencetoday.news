---
import { getCollection, getEntry } from 'astro:content';
import Base from '@/layouts/Base.astro';
import EditButton from '@/components/editor/EditButton.svelte';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import ArticleCard from '@/components/blocks/ArticleCard.astro';
import MythCard from '@/components/blocks/MythCard.astro';
import IngredientCard from '@/components/blocks/IngredientCard.astro';
import VideoCard from '@/components/blocks/VideoCard.astro';
import PodcastCard from '@/components/blocks/PodcastCard.astro';
import ShareButtons from '@/components/blocks/ShareButtons.astro';
import { fmtDate } from '@/utils/date';
import { getDisplayTitle, getNewsCategory, getNewsHeroImage } from '@/utils/news';
import { stripPodcastSlug } from '@/utils/podcasts';
import { contentSocial } from '@/utils/social-meta.mjs';
import { buildCitations, PUBLISHER_REF, WEBSITE_REF } from '@/utils/schema-org';
import { isPublicEntry } from '@/utils/visibility';
import { getAutoRelated } from '@/utils/related';

function stripExt(id: string): string {
  return id.replace(/\.[^.]+$/, '');
}

function cleanPoint(value: string): string {
  return value.trim().replace(/^-+\s*/u, '').replace(/[；。]$/u, '');
}

function splitSummary(summary: string): string[] {
  return summary
    .split('。')
    .map(cleanPoint)
    .filter(Boolean)
    .slice(0, 6);
}

export async function getStaticPaths() {
  const entries = await getCollection('news', ({ data }) => isPublicEntry(data));
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.[^.]+$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;
const social = contentSocial('news', data, entry.id.replace(/\.[^.]+$/, ''));
const slug = entry.id.replace(/\.[^.]+$/, '');

const displayTitle = getDisplayTitle(data.titleDisplay, data.title);
const category = getNewsCategory(data.tags, data.category);
const heroImage = getNewsHeroImage(data.heroImage, data.thumbnail, data.tags, data.category, {
  title: data.title,
  titleDisplay: data.titleDisplay,
  subtitle: data.subtitle,
  summary: data.summary,
});
const filteredTermBox = (data.termBox ?? []).filter(
  (item) => !['統合分析', '系統性回顧', 'RCT', '健康使用者偏誤', '觀察性研究', '世代研究', '橫斷面研究'].includes(item.term.trim()),
);

function normalizeEditorPoints(): string[] {
  if (Array.isArray(data.editorPoints) && data.editorPoints.length > 0) {
    return data.editorPoints.map(cleanPoint).filter(Boolean);
  }

  const editorComment = data.editorComment;
  if (!editorComment) return [];

  if (Array.isArray(editorComment)) {
    return editorComment.map(cleanPoint).filter(Boolean);
  }

  const lines = editorComment.split('\n').map(cleanPoint).filter(Boolean);
  if (lines.length >= 2) return lines;

  return editorComment.split('\n\n').map(cleanPoint).filter(Boolean);
}

const keyPoints = Array.isArray(data.keyPoints) && data.keyPoints.length > 0
  ? data.keyPoints.map(cleanPoint).filter(Boolean)
  : splitSummary(data.summary);
const editorPoints = normalizeEditorPoints();
const cautionText = data.cautionNote?.trim() || data.evidenceNote?.trim() || '';
const references = data.references ?? [];
const hasStructuredReferences = references.length > 0;
const hasSimpleSource = Boolean(data.pmid || data.sourceUrl);

const manualArticles = data.relatedArticles
  ? (await Promise.all(data.relatedArticles.map((id) => getEntry('articles', id)))).filter(Boolean)
  : [];
const manualMyths = data.relatedMyths
  ? (await Promise.all(data.relatedMyths.map((id) => getEntry('myths', id)))).filter(Boolean)
  : [];
const manualIngredients = data.relatedIngredients
  ? (await Promise.all(data.relatedIngredients.map((id) => getEntry('ingredients', id)))).filter(Boolean)
  : [];
const manualVideos = data.relatedVideos
  ? (await Promise.all(data.relatedVideos.map((id) => getEntry('videos', id)))).filter(Boolean)
  : [];
const manualPodcasts = data.relatedPodcasts
  ? (await Promise.all(data.relatedPodcasts.map((id) => getEntry('podcasts', id)))).filter(Boolean)
  : [];
const hasManual = manualArticles.length > 0 || manualMyths.length > 0 || manualIngredients.length > 0 || manualVideos.length > 0 || manualPodcasts.length > 0;

/* 手動全空 → 用 tag 重疊自動補相關內容（見 src/utils/related.ts） */
const auto = hasManual
  ? { articles: [], myths: [], ingredients: [], videos: [], podcasts: [] }
  : await getAutoRelated({ tags: data.tags ?? [], perBucket: 2 });

const relatedArticles = hasManual ? manualArticles : auto.articles;
const relatedMyths = hasManual ? manualMyths : auto.myths;
const relatedIngredients = hasManual ? manualIngredients : auto.ingredients;
const relatedVideos = hasManual ? manualVideos : auto.videos;
const relatedPodcasts = hasManual ? manualPodcasts : auto.podcasts;

const hasRelated = relatedArticles.length > 0 || relatedMyths.length > 0 || relatedIngredients.length > 0 || relatedVideos.length > 0 || relatedPodcasts.length > 0;
const metaDesc = (data.subtitle || data.summary || '').slice(0, 140);
const shareUrl = new URL(Astro.url.pathname, Astro.site).href;

const newsCitations = buildCitations(references);
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  '@id': `https://evidencetoday.news/news/${slug}/#article`,
  mainEntityOfPage: `https://evidencetoday.news/news/${slug}/`,
  headline: displayTitle,
  description: metaDesc,
  image: new URL(heroImage, 'https://evidencetoday.news').href,
  author: PUBLISHER_REF,
  datePublished: data.publishDate.toISOString(),
  publisher: PUBLISHER_REF,
  isPartOf: WEBSITE_REF,
  ...(newsCitations ? { citation: newsCitations } : {}),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: 'https://evidencetoday.news/' },
    { '@type': 'ListItem', position: 2, name: '趨勢', item: 'https://evidencetoday.news/news/' },
    { '@type': 'ListItem', position: 3, name: displayTitle, item: `https://evidencetoday.news/news/${slug}/` },
  ],
};
---

<Base title={social.title} description={social.description} ogTitle={social.title} ogDescription={social.description} ogImage={social.image} ogType="article">
  <Fragment slot="head">
    <JsonLd data={articleSchema} />
    <JsonLd data={breadcrumbSchema} />
  </Fragment>

  <div class="news-detail container">
    <Breadcrumb items={[
      { label: '首頁', href: '/' },
      { label: '趨勢', href: '/news/' },
      { label: displayTitle },
    ]} />

    <article class="news-article">
      <header class="news-article__header">
        <span class="news-article__cat">{category}</span>
        <h1 class="news-article__title">{displayTitle}</h1>
        {data.subtitle && <p class="news-article__subtitle">{data.subtitle}</p>}
        <div class="news-article__meta">
          <time>{fmtDate(data.publishDate)}</time>
        </div>
      </header>

      <div class="news-article__hero-img">
        <img src={heroImage} alt={data.coverAlt || displayTitle} loading="eager" />
        {data.coverImageCredit && <p class="news-article__hero-credit">攝影：{data.coverImageCredit}</p>}
      </div>

      {data.intro && (
        <div class="news-article__intro">
          <p>{data.intro}</p>
        </div>
      )}

      {keyPoints.length > 0 && (
        <section class="keypoints">
          <h2 class="keypoints__heading">重點摘要</h2>
          <ul class="keypoints__list">
            {keyPoints.map((item) => <li>{item}</li>)}
          </ul>
        </section>
      )}

      {filteredTermBox.length > 0 && (
        <aside class="term-box" aria-label="詞條提示">
          <div class="term-box__list">
            {filteredTermBox.map((item) => (
              <div class="term-box__item">
                <span class="term-box__term">{item.term}：</span>
                <span class="term-box__def">{item.definition}</span>
              </div>
            ))}
          </div>
        </aside>
      )}

      <div class="news-article__body prose">
        <Content />
      </div>

      {cautionText && (
        <aside class="evidence-note">
          <h2 class="evidence-note__heading">請注意</h2>
          <p class="evidence-note__text">{cautionText}</p>
        </aside>
      )}

      {editorPoints.length > 0 && (
        <aside class="editor-action">
          <h2 class="editor-action__heading">主編判讀</h2>
          <ul class="editor-action__content">
            {editorPoints.map((item) => <li>{item}</li>)}
          </ul>
        </aside>
      )}

      <footer class="source-ref">
        <h2 class="source-ref__heading">來源</h2>
        {hasStructuredReferences && (
          <ol class="source-ref__list">
            {references.map((reference) => (
              <li class="source-ref__item">
                {reference.url ? (
                  <a href={reference.url} target="_blank" rel="noopener noreferrer">{reference.title}</a>
                ) : (
                  <span>{reference.title}</span>
                )}
                {reference.journal && <span>｜{reference.journal}</span>}
                {reference.year && <span>｜{reference.year}</span>}
                {reference.pmid && <span>｜PMID：{reference.pmid}</span>}
                {reference.doi && <span>｜DOI：{reference.doi}</span>}
              </li>
            ))}
          </ol>
        )}
        {!hasStructuredReferences && data.pmid && (
          <p class="source-ref__link">
            PubMed PMID：<a href={`https://pubmed.ncbi.nlm.nih.gov/${data.pmid}/`} target="_blank" rel="noopener noreferrer">{data.pmid}</a>
          </p>
        )}
        {!hasStructuredReferences && data.sourceUrl && (
          <p class="source-ref__link">
            原文連結：<a href={data.sourceUrl} target="_blank" rel="noopener noreferrer">{data.sourceUrl}</a>
          </p>
        )}
        {!hasStructuredReferences && !hasSimpleSource && (
          <p class="source-ref__link">{data.sourcePendingReason || '原始來源連結尚未補上'}</p>
        )}
      </footer>

      <ShareButtons url={shareUrl} title={displayTitle} />
    </article>

    {hasRelated && (
      <section class="related-section">
        <h2 class="related-section__title">你可能想看</h2>
        <div class="related-grid">
          {relatedArticles.map((a) => (
            <ArticleCard
              title={a.data.title}
              description={a.data.description}
              href={`/articles/${stripExt(a.id)}/`}
              category="article"
              author={a.data.author}
              date={fmtDate(a.data.publishDate)}
              editorReviewed={a.data.editorReviewed}
            />
          ))}
          {relatedMyths.map((m) => (
            <MythCard
              title={m.data.title}
              verdictSummary={m.data.verdictSummary}
              href={`/myths/${stripExt(m.id)}/`}
              verdict={m.data.verdict}
              date={fmtDate(m.data.publishDate)}
            />
          ))}
          {relatedIngredients.map((i) => (
            <IngredientCard
              title={i.data.title}
              description={i.data.description}
              href={`/ingredients/${stripExt(i.id)}/`}
              uses={i.data.uses}
            />
          ))}
          {relatedVideos.map((v) => (
            <VideoCard
              title={v.data.title}
              tldr={v.data.tldr}
              href={`/videos/${stripExt(v.id)}/`}
              youtubeId={v.data.youtubeId}
            />
          ))}
          {relatedPodcasts.map((p) => (
            <PodcastCard
              title={p.data.title}
              description={p.data.description}
              href={`/podcasts/${stripPodcastSlug(p.id)}/`}
              episodeNumber={p.data.episodeNumber}
              duration={p.data.duration}
            />
          ))}
        </div>
      </section>
    )}
  </div>
  <EditButton client:idle repoPath={`src/content/news/${entry.id}`} collection="news" slug={slug} />
</Base>

<style>
  .news-detail {
    padding-block: var(--space-page-y);
  }

  .news-article,
  .related-section {
    max-width: 52rem;
    margin: 0 auto;
  }

  .news-article__header {
    padding-block: 1.5rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .news-article__cat {
    display: inline-flex;
    align-self: flex-start;
    padding: 0.25rem 0.7rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 600;
    color: white;
    background: color-mix(in oklch, var(--color-cat-news) 90%, black);
  }

  .news-article__title {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 1.2rem + 1.5vw, 2.25rem);
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.35;
  }

  .news-article__subtitle,
  .news-article__intro p {
    font-size: var(--text-body);
    color: color-mix(in oklch, var(--color-ink) 72%, transparent);
    line-height: 1.75;
  }

  .news-article__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    color: color-mix(in oklch, var(--color-ink) 50%, transparent);
  }

  .news-article__hero-img {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-card);
    overflow: hidden;
    background:
      radial-gradient(circle at 72% 28%, color-mix(in oklch, var(--color-teal) 10%, transparent), transparent 38%),
      color-mix(in oklch, var(--color-fog) 55%, white);
    margin-bottom: 2rem;
  }

  .news-article__hero-img::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.08), transparent 46%),
      radial-gradient(circle at 65% 22%, rgb(255 255 255 / 0.22), transparent 34%);
    mix-blend-mode: soft-light;
  }

  .news-article__hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* 圖庫照片授權署名（stock 圖才會有 coverImageCredit），疊在封面右下 */
  .news-article__hero-credit {
    position: absolute;
    right: 0;
    bottom: 0;
    z-index: 1;
    margin: 0;
    padding: 0.15rem 0.5rem;
    font-family: var(--font-ui);
    font-size: var(--text-badge);
    color: white;
    background: rgb(0 0 0 / 0.45);
    border-top-left-radius: var(--radius-sm);
  }

  .news-article__intro,
  .keypoints,
  .term-box,
  .evidence-note,
  .editor-action,
  .source-ref {
    margin-bottom: 2rem;
  }

  .keypoints,
  .term-box,
  .evidence-note,
  .editor-action {
    padding: clamp(1.25rem, 0.75rem + 1.5vw, 1.75rem);
    border-radius: var(--radius-sm);
  }

  .keypoints,
  .editor-action {
    background: color-mix(in oklch, var(--color-teal) 6%, var(--color-paper));
    border: 1px solid color-mix(in oklch, var(--color-teal) 22%, transparent);
  }

  .term-box {
    padding: 1rem 1.25rem;
    background: color-mix(in oklch, var(--color-cat-news) 5%, var(--color-paper));
    border: 1px solid color-mix(in oklch, var(--color-cat-news) 12%, transparent);
  }

  .evidence-note {
    background: color-mix(in oklch, var(--color-fog) 50%, white);
    border-left: 3px solid color-mix(in oklch, var(--color-ink) 30%, var(--color-fog));
  }

  .keypoints__heading,
  .evidence-note__heading,
  .editor-action__heading,
  .source-ref__heading,
  .related-section__title {
    font-family: var(--font-sans);
    font-weight: 700;
    color: var(--color-ink);
    margin-bottom: 0.75rem;
  }

  .keypoints__heading,
  .editor-action__heading,
  .related-section__title {
    color: var(--color-teal);
  }

  .keypoints__list,
  .editor-action__content,
  .source-ref__list {
    margin: 0;
    padding-left: 1.25rem;
    display: grid;
    gap: 0.55rem;
  }

  .keypoints__list li,
  .editor-action__content li,
  .evidence-note__text,
  .source-ref__item,
  .source-ref__link {
    font-size: var(--text-body);
    color: color-mix(in oklch, var(--color-ink) 80%, transparent);
    line-height: 1.75;
  }

  .term-box__list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 0;
  }

  .term-box__item {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
  }

  .term-box__term {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-body);
    font-weight: 700;
    color: var(--color-ink);
  }

  .term-box__def {
    flex: 1 1 16rem;
    min-width: 0;
    margin: 0;
    font-size: var(--text-body);
    color: color-mix(in oklch, var(--color-ink) 78%, transparent);
    line-height: 1.75;
  }

  .news-article__body {
    max-width: 52rem;
    padding-block: 0 2rem;
  }

  .source-ref {
    padding-top: 1rem;
    border-top: 1px solid var(--color-fog);
  }

  .source-ref a {
    color: var(--color-teal);
    word-break: break-word;
  }

  .related-section {
    padding-block: 2rem 0;
    border-top: 2px solid var(--color-fog);
  }

  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-card-gap);
  }

  @media (min-width: 640px) {
    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
