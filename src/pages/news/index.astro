---
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import NewsItem from '@/components/blocks/NewsItem.astro';
import ArticleCard from '@/components/blocks/ArticleCard.astro';
import MythCard from '@/components/blocks/MythCard.astro';
import { getCollection, getEntry } from 'astro:content';
import TrendBubbles from '@/components/charts/TrendBubbles.svelte';
import { getTopTags } from '@/utils/tag-stats';

function fmtDate(d: Date): string {
  return d.toISOString().slice(0, 10);
}

function stripExt(id: string): string {
  return id.replace(/\.[^.]+$/, '');
}

const allNews = (await getCollection('news', (e) => !e.data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const editorPicks = allNews.filter((n) => n.data.editorPick);
const latestNews = allNews;

/* Collect related content from editor picks */
const relatedArticleIds = new Set<string>();
const relatedMythIds = new Set<string>();
for (const pick of editorPicks) {
  if (pick.data.relatedArticles) {
    for (const id of pick.data.relatedArticles) relatedArticleIds.add(id);
  }
  if (pick.data.relatedMyths) {
    for (const id of pick.data.relatedMyths) relatedMythIds.add(id);
  }
}

const relatedArticles = (
  await Promise.all([...relatedArticleIds].map((id) => getEntry('articles', id)))
).filter(Boolean);

const relatedMyths = (
  await Promise.all([...relatedMythIds].map((id) => getEntry('myths', id)))
).filter(Boolean);

const hasRelated = relatedArticles.length > 0 || relatedMyths.length > 0;

const topTags = await getTopTags();
---

<Base title="趨勢 | 本日有據" description="每週健康新聞雷達，追蹤最新研究動態與編輯精選議題。">
  <div class="news-page container">
    <Breadcrumb items={[{ label: '首頁', href: '/' }, { label: '趨勢' }]} />

    <header class="news-header">
      <div class="news-header__bar"></div>
      <h1>健康議題雷達</h1>
      <p class="news-header__desc">追蹤最新健康研究動態，由編輯團隊篩選值得關注的議題。</p>
    </header>

    <!-- Section 1: Editor Picks -->
    {editorPicks.length > 0 && (
      <section class="news-section">
        <h2 class="news-section__title">主編選題</h2>
        <div class="editor-picks">
          {editorPicks.map((n) => (
            <article class="editor-pick">
              <div class="editor-pick__header">
                <span class="editor-pick__source">{n.data.source}</span>
                <time class="editor-pick__date">{fmtDate(n.data.publishDate)}</time>
              </div>
              <h3 class="editor-pick__title">
                {n.data.sourceUrl ? (
                  <a href={n.data.sourceUrl} target="_blank" rel="noopener noreferrer">{n.data.title}</a>
                ) : (
                  n.data.title
                )}
              </h3>
              <p class="editor-pick__summary">{n.data.summary}</p>
              {n.data.editorComment && (
                <blockquote class="editor-pick__comment">
                  <span class="editor-pick__comment-label">主編觀點</span>
                  <p>{n.data.editorComment}</p>
                </blockquote>
              )}
              {n.data.tags.length > 0 && (
                <div class="editor-pick__tags">
                  {n.data.tags.map((tag) => (
                    <span class="editor-pick__tag">{tag}</span>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- Section 2: All News -->
    <section class="news-section">
      <h2 class="news-section__title">最新新聞</h2>
      <div class="news-list">
        {latestNews.map((n) => (
          <NewsItem
            title={n.data.title}
            source={n.data.source}
            date={fmtDate(n.data.publishDate)}
            summary={n.data.summary}
            href={`/news/${stripExt(n.id)}/`}
            sourceUrl={n.data.sourceUrl}
            tags={n.data.tags}
          />
        ))}
      </div>
    </section>

    <!-- Section 3: Trend Radar -->
    <section class="news-section">
      <h2 class="news-section__title">健康議題雷達</h2>
      <TrendBubbles tags={topTags} client:visible />
    </section>

    <!-- Section 4: Related Content -->
    {hasRelated && (
      <section class="news-section">
        <h2 class="news-section__title">你可能想看</h2>
        <div class="related-grid">
          {relatedArticles.map((a) => (
            <ArticleCard
              title={a.data.title}
              description={a.data.description}
              href={`/articles/${stripExt(a.id)}/`}
              category="article"
              author={a.data.author}
              date={fmtDate(a.data.publishDate)}
              editorReviewed={a.data.editorReviewed}
            />
          ))}
          {relatedMyths.map((m) => (
            <MythCard
              title={m.data.title}
              verdictSummary={m.data.verdictSummary}
              href={`/myths/${stripExt(m.id)}/`}
              verdict={m.data.verdict}
              date={fmtDate(m.data.publishDate)}
            />
          ))}
        </div>
      </section>
    )}
  </div>
</Base>

<style>
  .news-page {
    padding-block: var(--space-page-y);
  }

  .news-header {
    padding-block: 1.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .news-header__bar {
    width: 3rem;
    height: 4px;
    border-radius: var(--radius-pill);
    background-color: var(--color-cat-news);
  }

  .news-header h1 {
    font-family: var(--font-sans);
    font-size: var(--text-h1);
    font-weight: 700;
    color: var(--color-ink);
  }

  .news-header__desc {
    font-size: var(--text-body);
    color: color-mix(in oklch, var(--color-ink) 70%, transparent);
    line-height: 1.7;
    max-width: 55ch;
  }

  .news-section {
    padding-block: 2rem 0;
  }

  .news-section__title {
    font-family: var(--font-sans);
    font-size: var(--text-h2);
    font-weight: 700;
    color: var(--color-ink);
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-fog);
  }

  /* Editor Picks */
  .editor-picks {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .editor-pick {
    background-color: var(--color-paper);
    border-radius: var(--radius-card);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .editor-pick__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    color: color-mix(in oklch, var(--color-ink) 55%, transparent);
  }

  .editor-pick__source {
    font-weight: 600;
  }

  .editor-pick__title {
    font-family: var(--font-sans);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.4;
  }

  .editor-pick__title a {
    color: inherit;
    text-decoration: none;
  }

  .editor-pick__title a:hover {
    color: var(--color-teal);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .editor-pick__summary {
    font-size: var(--text-body);
    color: color-mix(in oklch, var(--color-ink) 80%, transparent);
    line-height: 1.7;
  }

  .editor-pick__comment {
    margin: 0;
    padding: 1rem 1.25rem;
    background-color: white;
    border-left: 4px solid var(--color-cat-news);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .editor-pick__comment-label {
    font-family: var(--font-ui);
    font-size: var(--text-badge);
    font-weight: 700;
    color: var(--color-cat-news);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .editor-pick__comment p {
    margin: 0;
    font-size: var(--text-meta);
    color: color-mix(in oklch, var(--color-ink) 75%, transparent);
    line-height: 1.7;
  }

  .editor-pick__tags {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .editor-pick__tag {
    display: inline-flex;
    align-items: center;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-ui);
    font-size: var(--text-badge);
    font-weight: 500;
    line-height: 1.4;
    white-space: nowrap;
    background-color: color-mix(in oklch, var(--color-cat-news) 14%, white);
    color: var(--color-cat-news);
  }

  /* News list */
  .news-list {
    display: flex;
    flex-direction: column;
  }

  /* Related grid */
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-card-gap);
  }

  @media (max-width: 1024px) {
    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
