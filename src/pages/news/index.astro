---
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';
function stripExt(id:string){return id.replace(/\.[^.]+$/,'');}
const all=(await getCollection('news',(e)=>!e.data.draft)).sort((a,b)=>b.data.publishDate.getTime()-a.data.publishDate.getTime());
const picks=all.filter(n=>n.data.editorPick).slice(0,3);
const cats=['全部','食品安全','保健食品','公共衛生','運動營養','慢性病','國際政策','研究新知'];
---
<Base title="健康議題雷達 | 本日有據"><main class="container news"><h1>健康議題雷達</h1><p>替你追蹤最新健康研究與公共衛生消息，用白話整理真正值得注意的重點。</p><div>{cats.map(c=><span class="cat">{c}</span>)}</div>
<h2>主編選題</h2><section class="grid">{picks.map(n=><article class="card"><p>{n.data.source}</p><h3><a href={`/news/${stripExt(n.id)}/`}>{n.data.title}</a></h3><p>{n.data.summary}</p><p><strong>主編提醒：</strong>{n.data.editorComment ?? '持續觀察，避免過度延伸解讀。'}</p><p><strong>行動建議：</strong>了解即可</p></article>)}</section>
<h2>最新雷達</h2><section class="grid">{all.map(n=><article class="card"><p>{n.data.source}</p><h3><a href={`/news/${stripExt(n.id)}/`}>{n.data.title}</a></h3><p>{n.data.summary}</p><p>標籤：{n.data.tags.join('、')}</p></article>)}</section></main></Base>
<style>.news{padding:2rem 0}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1rem}.card{background:linear-gradient(180deg,#f8fbff,#fff);padding:1rem;border-radius:12px;line-height:1.8}.cat{display:inline-block;padding:.25rem .6rem;background:#eef3ff;margin:.25rem;border-radius:999px}</style>
