---
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';
import { fmtDate } from '@/utils/date';
import { getDisplayTitle, getNewsCategory, getNewsThumbnail } from '@/utils/news';
import { getTopTags } from '@/utils/tag-stats';
import TrendBubbles from '@/components/charts/TrendBubbles.svelte';

function stripExt(id: string) { return id.replace(/\.[^.]+$/, ''); }

const all = (await getCollection('news', (e) => !e.data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
const topTags = await getTopTags(12);
---

<Base title="趨勢 | 本日有據" description="替你追蹤最新健康研究與公共衛生消息，用白話整理真正值得注意的重點。">
  <main class="container news-list">
    <header class="news-list__header">
      <h1>趨勢</h1>
      <p class="news-list__desc">替你追蹤最新健康研究與公共衛生消息，用白話整理真正值得注意的重點。</p>
    </header>

    {topTags.length > 0 && (
      <section class="trend-section">
        <h2 class="trend-section__title">熱門健康話題</h2>
        <div class="trend-section__chart">
          <TrendBubbles tags={topTags} client:visible />
        </div>
      </section>
    )}

    <section class="news-grid">
      {all.map((n) => {
        const d = n.data;
        const title = getDisplayTitle(d.titleDisplay, d.title);
        const category = getNewsCategory(d.tags, d.category);
        const thumb = getNewsThumbnail(d.thumbnail, d.heroImage, d.tags, d.category);
        const href = `/news/${stripExt(n.id)}/`;
        return (
          <a href={href} class="news-card">
            <div class="news-card__img-wrap">
              <img src={thumb} alt="" loading="lazy" class="news-card__img" />
              <span class="news-card__badge">{category}</span>
            </div>
            <div class="news-card__body">
              <h2 class="news-card__title">{title}</h2>
              <p class="news-card__summary">{d.summary}</p>
              <time class="news-card__date">{fmtDate(d.publishDate)}</time>
            </div>
          </a>
        );
      })}
    </section>
  </main>
</Base>

<style>
  .news-list {
    padding-block: var(--space-page-y);
  }

  .news-list__header {
    margin-bottom: 2rem;
  }

  .news-list__header h1 {
    font-family: var(--font-serif);
    font-size: var(--text-h1);
    color: var(--color-ink);
    margin-bottom: 0.5rem;
  }

  .news-list__desc {
    font-size: var(--text-body);
    color: color-mix(in oklch, var(--color-ink) 60%, transparent);
    max-width: 48ch;
    line-height: 1.7;
  }

  /* ---- Grid ---- */
  .news-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-card-gap);
  }

  @media (min-width: 640px) {
    .news-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .news-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ---- Trend bubbles ---- */
  .trend-section {
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: white;
    border: 1px solid color-mix(in oklch, var(--color-fog) 80%, transparent);
    border-radius: var(--radius-card);
    max-height: 50vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .trend-section__title {
    font-family: var(--font-sans);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-ink);
    margin-bottom: 1rem;
    flex-shrink: 0;
  }

  .trend-section__chart {
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  .trend-section__chart > :global(astro-island) {
    display: contents;
  }

  /* ---- Card ---- */
  .news-card {
    display: flex;
    flex-direction: column;
    background: white;
    border: 1px solid color-mix(in oklch, var(--color-fog) 80%, transparent);
    border-radius: var(--radius-card);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .news-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }

  .news-card:focus-visible {
    outline: 2px solid var(--color-teal);
    outline-offset: 2px;
  }

  /* Image */
  .news-card__img-wrap {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--color-fog);
  }

  .news-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .news-card__badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: white;
    background: color-mix(in oklch, var(--color-cat-news) 90%, black);
  }

  /* Body */
  .news-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1rem 1.25rem 1.25rem;
  }

  .news-card__title {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.45;
    margin-bottom: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-card__summary {
    font-size: var(--text-meta);
    color: color-mix(in oklch, var(--color-ink) 60%, transparent);
    line-height: 1.6;
    margin-bottom: auto;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-card__date {
    display: block;
    margin-top: 0.75rem;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: color-mix(in oklch, var(--color-ink) 40%, transparent);
  }

  @media (min-width: 640px) {
    .news-card__title {
      -webkit-line-clamp: 3;
    }
  }
</style>
