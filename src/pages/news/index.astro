---
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';
import { fmtDate } from '@/utils/date';
import { getDisplayTitle, getNewsCategory, getNewsThumbnail } from '@/utils/news';
import { getTopTags } from '@/utils/tag-stats';
import { listSocial } from '@/utils/social-meta.mjs';
import TrendBubbles from '@/components/charts/TrendBubbles.svelte';
import { isPublicEntry } from '@/utils/visibility';

function stripExt(id: string) { return id.replace(/\.[^.]+$/, ''); }

const all = (await getCollection('news', (e) => isPublicEntry(e.data)))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
const topTags = await getTopTags(12);
const social = listSocial('news');
---

<Base title={social.title} description={social.description} ogTitle={social.title} ogDescription={social.description} ogImage={social.image}>
  <main class="container news-list">
    <header class="news-list__header">
      <h1>趨勢</h1>
      <p class="news-list__desc">替你追蹤最新健康研究與公共衛生消息，用白話整理真正值得注意的重點。</p>
    </header>

    {topTags.length > 0 && (
      <section class="trend-section" aria-label="熱門健康話題">
        <h2 class="trend-section__title">熱門健康話題</h2>
        <div class="trend-section__chart">
          <TrendBubbles tags={topTags} client:visible />
        </div>
      </section>
    )}

    <section class="news-grid">
      {all.map((n) => {
        const d = n.data;
        const title = getDisplayTitle(d.titleDisplay, d.title);
        const category = getNewsCategory(d.tags, d.category);
        const thumb = getNewsThumbnail(d.thumbnail, d.heroImage, d.tags, d.category, {
          title: d.title,
          titleDisplay: d.titleDisplay,
          subtitle: d.subtitle,
          summary: d.summary,
        });
        const href = `/news/${stripExt(n.id)}/`;
        return (
          <a href={href} class="news-card">
            <div class="news-card__img-wrap">
              <img src={thumb} alt="" loading="lazy" class="news-card__img" />
              <span class="news-card__badge">{category}</span>
            </div>
            <div class="news-card__body">
              <h2 class="news-card__title">{title}</h2>
              <p class="news-card__summary">{d.summary}</p>
              <time class="news-card__date">{fmtDate(d.publishDate)}</time>
            </div>
          </a>
        );
      })}
    </section>
  </main>
</Base>

<style>
  .news-list {
    padding-block: var(--space-page-y);
  }

  .news-list__header {
    margin-bottom: 2rem;
  }

  .news-list__header h1 {
    font-family: var(--font-serif);
    font-size: var(--text-h1);
    color: var(--color-ink);
    margin-bottom: 0.5rem;
  }

  .news-list__desc {
    font-size: var(--text-body);
    color: color-mix(in oklch, var(--color-ink) 60%, transparent);
    max-width: 48ch;
    line-height: 1.7;
  }

  /* ---- Grid ---- */
  .news-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-card-gap);
  }

  @media (min-width: 640px) {
    .news-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .news-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ---- Trend bubbles ---- */
  .trend-section {
    margin-bottom: 2.5rem;
    padding: clamp(1.25rem, 1rem + 1.5vw, 2rem);
    background: white;
    border: 1px solid color-mix(in oklch, var(--color-fog) 80%, transparent);
    border-radius: var(--radius-card);
    min-height: 22rem;
  }

  .trend-section__title {
    font-family: var(--font-sans);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-ink);
    margin-bottom: 1rem;
  }

  /* 圖表高度用 clamp，手機 280px、桌機可達 380px；不用 vh 避免被 header 裁切。 */
  .trend-section__chart {
    height: clamp(18rem, 38vh, 28rem);
    padding-block: 0.25rem;
  }

  .trend-section__chart > :global(astro-island) {
    display: contents;
  }

  /* ---- Card ---- */
  .news-card {
    display: flex;
    flex-direction: column;
    background: white;
    border: 1px solid color-mix(in oklch, var(--color-fog) 80%, transparent);
    border-radius: var(--radius-card);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .news-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }

  .news-card:focus-visible {
    outline: 2px solid var(--color-teal);
    outline-offset: 2px;
  }

  /* Image */
  .news-card__img-wrap {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background:
      radial-gradient(circle at 72% 28%, color-mix(in oklch, var(--color-teal) 10%, transparent), transparent 38%),
      color-mix(in oklch, var(--color-fog) 55%, white);
  }

  .news-card__img-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(180deg, var(--overlay-white-08), transparent 46%),
      radial-gradient(circle at 65% 22%, var(--overlay-white-22), transparent 34%);
    mix-blend-mode: soft-light;
  }

  .news-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.01);
    transition: transform 0.25s ease;
  }

  .news-card:hover .news-card__img {
    transform: scale(1.035);
  }

  .news-card__badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.7rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: white;
    background: color-mix(in oklch, var(--color-cat-news) 90%, black);
    box-shadow: var(--shadow-news-card);
    z-index: 1;
  }

  /* Body */
  .news-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.15rem 1.35rem 1.35rem;
  }

  .news-card__title {
    font-family: var(--font-sans);
    font-size: clamp(1.125rem, 1rem + 0.3vw, 1.25rem);
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.5;
    margin-bottom: 0.6rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-card__summary {
    font-size: 0.98rem;
    color: color-mix(in oklch, var(--color-ink) 60%, transparent);
    line-height: 1.7;
    margin-bottom: auto;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-card__date {
    display: block;
    margin-top: 0.85rem;
    font-family: var(--font-ui);
    font-size: 0.86rem;
    color: color-mix(in oklch, var(--color-ink) 40%, transparent);
  }

  @media (min-width: 1024px) {
    .news-card__title {
      font-size: 1.2rem;
    }
  }
  @media (max-width: 639px) {
    .trend-section__chart { height: 17rem; }
  }
</style>
