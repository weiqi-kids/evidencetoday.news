---
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import Base from '@/layouts/Base.astro';
import Button from '@/components/ui/Button.astro';
import ArticleCard from '@/components/blocks/ArticleCard.astro';
import MythCard from '@/components/blocks/MythCard.astro';
import IngredientCard from '@/components/blocks/IngredientCard.astro';
import PodcastCard from '@/components/blocks/PodcastCard.astro';
import VideoCard from '@/components/blocks/VideoCard.astro';
import NewsItem from '@/components/blocks/NewsItem.astro';
import HeroParticles from '@/components/charts/HeroParticles.svelte';
import TrendBubbles from '@/components/charts/TrendBubbles.svelte';
import { getTopTags } from '@/utils/tag-stats';
import { STATIC_SOCIAL } from '@/utils/social-meta.mjs';
import { getCollection } from 'astro:content';
import { fmtDate } from '@/utils/date';
import { getPublishedPodcasts, stripPodcastSlug } from '@/utils/podcasts';
import { getPublishedArticles } from '@/utils/articles';
import { isPublicEntry } from '@/utils/visibility';
import { TOPICS } from '@/data/topics';
import { getNewsThumbnail } from '@/utils/news';
import { resolveTopicCover } from '@/utils/topic-cover';
import shortsData from '@/data/youtube-shorts.json';
import { videoItemsSchema } from '@/lib/youtube';
import type { MythVerdict } from '@/utils/myths/schema';

function stripExt(id: string): string {
  return id.replace(/\.[^.]+$/, '');
}

// 封面安全守衛（同 IngredientCard）：外連 http(s) 直接採用；本地 `/…` 須確認 public 下存在，
// 缺圖或路徑非法時回 undefined（讓呼叫端退回品牌佔位，不開天窗、不出破圖）。
function safeCover(cover?: string): string | undefined {
  if (typeof cover !== 'string') return undefined;
  if (cover.startsWith('http://') || cover.startsWith('https://')) return cover;
  if (cover.startsWith('/') && existsSync(join(process.cwd(), 'public', cover))) return cover;
  return undefined;
}

/* ------------------------------------------------------------------ */
/*  Fetch all non-draft content                                        */
/* ------------------------------------------------------------------ */
const allArticles = await getPublishedArticles();

const allMyths = (await getCollection('myths', (e) => isPublicEntry(e.data)))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const allIngredients = (await getCollection('ingredients', (e) => isPublicEntry(e.data)))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const allPodcasts = getPublishedPodcasts(await getCollection('podcasts'));

const allVideos = videoItemsSchema.safeParse(shortsData).success ? videoItemsSchema.parse(shortsData) : [];

const allNews = (await getCollection('news', (e) => isPublicEntry(e.data)))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

// 健康專題卡片縮圖：從各主題自動歸入的文章／成分解析取代表封面（缺圖退回品牌佔位）。
const topicCards = TOPICS.map((topic) => ({
  topic,
  cover: resolveTopicCover(topic, [allArticles, allIngredients]),
}));

/* ------------------------------------------------------------------ */
/*  Featured items for Hero (featured: true)                           */
/* ------------------------------------------------------------------ */
type FeaturedItem = {
  type: 'article' | 'myth' | 'ingredient' | 'podcast' | 'video';
  slug: string;
  title: string;
  description: string;
  date: Date;
  href: string;
  cover?: string;
  extra?: Record<string, unknown>;
};

const featuredItems: FeaturedItem[] = [
  ...allArticles.filter((a) => a.data.featured).map((a) => ({
    type: 'article' as const,
    slug: a.id,
    title: a.data.title,
    description: a.data.description,
    date: a.data.publishDate,
    href: `/articles/${stripExt(a.id)}/`,
    cover: a.data.coverImage,
    extra: { author: a.data.author, editorReviewed: a.data.editorReviewed },
  })),
  ...allMyths.filter((m) => m.data.featured).map((m) => ({
    type: 'myth' as const,
    slug: m.id,
    title: m.data.title,
    description: m.data.verdictSummary,
    date: m.data.publishDate,
    href: `/myths/${stripExt(m.id)}/`,
    cover: m.data.coverImage,
    extra: { verdict: m.data.verdict },
  })),
  ...allIngredients.filter((i) => i.data.featured).map((i) => ({
    type: 'ingredient' as const,
    slug: i.id,
    title: i.data.title,
    description: i.data.description,
    date: i.data.publishDate,
    href: `/ingredients/${stripExt(i.id)}/`,
    cover: i.data.coverImage,
  })),
  ...allPodcasts.filter((p) => p.data.featured).map((p) => ({
    type: 'podcast' as const,
    slug: p.id,
    title: p.data.title,
    description: p.data.description,
    date: p.data.publishDate,
    href: `/podcasts/${stripPodcastSlug(p.id)}/`,
    cover: p.data.coverImage,
    extra: { episodeNumber: p.data.episodeNumber, duration: p.data.duration },
  })),
].sort((a, b) => b.date.getTime() - a.date.getTime()).slice(0, 3);

const typeLabel = (t: FeaturedItem['type']) =>
  t === 'article' ? '文章' : t === 'myth' ? '闢謠' : t === 'ingredient' ? '成分解析' : t === 'podcast' ? 'Podcast' : '短影音';
const primaryFeatured = featuredItems[0];
const secondaryFeatured = featuredItems.slice(1, 3);

/* ------------------------------------------------------------------ */
/*  Latest 4 items across ALL collections for "Latest Content"         */
/* ------------------------------------------------------------------ */
type LatestItem = {
  collection: 'articles' | 'myths' | 'ingredients' | 'podcasts' | 'videos' | 'news';
  id: string;
  date: Date;
  data: Record<string, unknown>;
};

const latestAll: LatestItem[] = [
  ...allArticles.map((a) => ({ collection: 'articles' as const, id: a.id, date: a.data.publishDate, data: a.data as unknown as Record<string, unknown> })),
  ...allMyths.map((m) => ({ collection: 'myths' as const, id: m.id, date: m.data.publishDate, data: m.data as unknown as Record<string, unknown> })),
  ...allIngredients.map((i) => ({ collection: 'ingredients' as const, id: i.id, date: i.data.publishDate, data: i.data as unknown as Record<string, unknown> })),
  ...allPodcasts.map((p) => ({ collection: 'podcasts' as const, id: p.id, date: p.data.publishDate, data: p.data as unknown as Record<string, unknown> })),
  ...allNews.map((n) => ({ collection: 'news' as const, id: n.id, date: n.data.publishDate, data: n.data as unknown as Record<string, unknown> })),
].sort((a, b) => b.date.getTime() - a.date.getTime()).slice(0, 4);

/* ------------------------------------------------------------------ */
/*  Section-specific slices                                            */
/* ------------------------------------------------------------------ */
const latestMyths = allMyths.slice(0, 3);
const latestIngredients = allIngredients.slice(0, 4);
const latestPodcasts = allPodcasts.slice(0, 2);
const latestNews = allNews.slice(0, 5);

/* ------------------------------------------------------------------ */
/*  Category grid data                                                 */
/* ------------------------------------------------------------------ */
const topTags = await getTopTags();

// 分類磚的代表圖：取該類最新一篇的封面照片（讓導覽磚有真實圖像、更像內容型網站），
// 缺照片時退回該類的品牌橫幅 /og-thumb/<name>.webp。
function firstCover(entries: Array<{ data?: Record<string, unknown> }>, field: string, ogName: string): string {
  for (const e of entries ?? []) {
    const v = e?.data?.[field];
    if (typeof v === 'string' && (v.startsWith('http://') || v.startsWith('https://') || v.startsWith('/'))) {
      return v;
    }
  }
  return `/og-thumb/${ogName}.webp`;
}
const firstVideo = allVideos[0] as { youtubeId?: string } | undefined;
const categoryCovers = {
  article: firstCover(allArticles, 'coverImage', 'articles'),
  myth: firstCover(allMyths, 'coverImage', 'myths'),
  ingredient: firstCover(allIngredients, 'coverImage', 'ingredients'),
  podcast: firstCover(allPodcasts, 'coverImage', 'podcasts'),
  video: firstVideo?.youtubeId
    ? `https://i.ytimg.com/vi/${firstVideo.youtubeId}/hqdefault.jpg`
    : '/og-thumb/videos.webp',
  news: firstCover(allNews, 'heroImage', 'news'),
} as const;

const categories = [
  {
    key: 'article',
    en: 'Article',
    zh: '文章',
    desc: '整理健康議題、研究脈絡與日常判斷，依主題標示可查證來源。',
    count: allArticles.length,
    href: '/articles/',
    color: 'var(--color-cat-article)',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  },
  {
    key: 'myth',
    en: 'Myth',
    zh: '闢謠',
    desc: '破解常見健康迷思，用證據說清楚真相。',
    count: allMyths.length,
    href: '/myths/',
    color: 'var(--color-cat-myth)',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><circle cx="12" cy="12" r="10"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
  },
  {
    key: 'ingredient',
    en: 'Ingredient',
    zh: '成分解析',
    desc: '整理營養素、食物成分與研究常討論的用途、可能機制與安全性。',
    count: allIngredients.length,
    href: '/ingredients/',
    color: 'var(--color-cat-ingredient)',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/><path d="M8.5 2h7"/></svg>`,
  },
  {
    key: 'podcast',
    en: 'Podcast',
    zh: 'Podcast',
    desc: '用耳朵吸收健康知識，通勤路上也能學。',
    count: allPodcasts.length,
    href: '/podcasts/',
    color: 'var(--color-cat-podcast)',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>`,
  },
  {
    key: 'video',
    en: 'Video',
    zh: '短影音',
    desc: '三到十分鐘的影片，快速掌握一個健康主題。',
    count: allVideos.length,
    href: '/videos/',
    color: 'var(--color-cat-video)',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>`,
  },
  {
    key: 'news',
    en: 'News',
    zh: '趨勢',
    desc: '每週健康新聞雷達，追蹤最新研究動態。',
    count: allNews.length,
    href: '/news/',
    color: 'var(--color-cat-news)',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
  },
];
---

<Base title={STATIC_SOCIAL.home.title} description={STATIC_SOCIAL.home.description} ogTitle={STATIC_SOCIAL.home.title} ogDescription={STATIC_SOCIAL.home.description} ogImage={STATIC_SOCIAL.home.ogPath}>
  <!-- 站台實體圖（Organization + WebSite）由 Base layout 全站輸出，首頁不另重複。 -->

  <!-- ============================================================== -->
  <!--  1. Hero                                                        -->
  <!-- ============================================================== -->
  <section id="hero" class="hero">
    <div class="hero__dot-grid"></div>
    <HeroParticles client:media="(min-width: 768px)" />
    <div class="hero__inner container">
      <div class="hero__left">
        <span class="hero__badge">健康研究 ・ 白話解釋</span>
        <h1 class="hero__title">
          <span class="hero__title-line">把健康議題講得有根據</span>
          <span class="hero__title-line">也講得讓人看得懂</span>
        </h1>
        <p class="hero__subtitle">
          本日有據整理健康研究、新聞與常見迷思，保留來源與脈絡，說清楚證據能支持什麼，也說清楚哪些說法需要保留判斷。
        </p>
        <div class="hero__buttons">
          <Button variant="primary" href="/articles/">最新文章 →</Button>
          <Button variant="secondary" href="/myths/" class="hero-btn-secondary">迷思破解</Button>
          <Button variant="secondary" href="/authors/luo-yang/">認識主編</Button>
        </div>
        <div class="hero__trust">
          <div class="hero__trust-card">
            <span class="hero__trust-number">來源透明</span>
            <span class="hero__trust-label">盡量附上研究、新聞來源與資料脈絡</span>
          </div>
          <div class="hero__trust-card">
            <span class="hero__trust-number">白話解讀</span>
            <span class="hero__trust-label">把艱深健康資訊整理成一般人能理解的判斷</span>
          </div>
          <div class="hero__trust-card">
            <span class="hero__trust-number">編輯獨立</span>
            <span class="hero__trust-label">內容與商業合作分開，不讓立場混淆判讀</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================== -->
  <!--  1.5 編輯精選（圖像導向：主圖 + 側欄清單）                        -->
  <!-- ============================================================== -->
  {featuredItems.length > 0 && (
    <section id="editors-pick" class="section-editors-pick">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">編輯精選</h2>
          <Button variant="secondary" href="/all/">看全部內容</Button>
        </div>
        <div class="editors-pick">
          {primaryFeatured && (
            <a href={primaryFeatured.href} class="ep-main">
              <span class="ep-main__media">
                {safeCover(primaryFeatured.cover) ? (
                  <img class="ep-main__img" src={safeCover(primaryFeatured.cover)} alt={primaryFeatured.title} loading="eager" decoding="async" />
                ) : (
                  <span class="ep-main__img ep-main__img--fallback" aria-hidden="true">本日有據</span>
                )}
                <span class="ep-kicker">本週焦點</span>
              </span>
              <span class="ep-main__body">
                <span class="ep-type">{typeLabel(primaryFeatured.type)}</span>
                <span class="ep-main__title">{primaryFeatured.title}</span>
                <span class="ep-main__desc">{primaryFeatured.description}</span>
                <span class="ep-meta">
                  <span>{fmtDate(primaryFeatured.date)}</span>
                  {primaryFeatured.type === 'article' && primaryFeatured.extra?.editorReviewed && <span>・主編把關</span>}
                  {primaryFeatured.type === 'myth' && primaryFeatured.extra?.verdict && <span>・判讀：{String(primaryFeatured.extra.verdict)}</span>}
                </span>
              </span>
            </a>
          )}
          {secondaryFeatured.length > 0 && (
            <div class="ep-side">
              {secondaryFeatured.map((item) => (
                <a href={item.href} class="ep-side__item">
                  <span class="ep-side__thumb">
                    {safeCover(item.cover) ? (
                      <img class="ep-side__img" src={safeCover(item.cover)} alt={item.title} loading="lazy" decoding="async" />
                    ) : (
                      <span class="ep-side__img ep-side__img--fallback" aria-hidden="true"></span>
                    )}
                  </span>
                  <span class="ep-side__body">
                    <span class="ep-type">{typeLabel(item.type)}</span>
                    <span class="ep-side__title">{item.title}</span>
                    <span class="ep-meta">{fmtDate(item.date)}</span>
                  </span>
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- ============================================================== -->
  <!--  2. Category Grid                                               -->
  <!-- ============================================================== -->
  <section id="categories" class="section-categories">
    <div class="container">
      <h2 class="section-title">探索所有內容</h2>
      <div class="category-grid">
        {categories.map((cat) => (
          <a href={cat.href} class="category-card" style={`--cat-color: ${cat.color}`}>
            <div class="category-card__media">
              <img class="category-card__image" src={categoryCovers[cat.key as keyof typeof categoryCovers]} alt="" aria-hidden="true" loading="lazy" />
              <div class="category-card__icon" set:html={cat.icon} />
            </div>
            <div class="category-card__body">
              <span class="category-card__en">{cat.en}</span>
              <h3 class="category-card__title">{cat.zh}</h3>
              <p class="category-card__desc">{cat.desc}</p>
              <div class="category-card__footer">
                <span class="category-card__count">{cat.count} 篇</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================== -->
  <!--  2.5 Health Topics                                             -->
  <!-- ============================================================== -->
  <section id="topics" class="section-topics">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">健康專題</h2>
        <Button variant="secondary" href="/topics/">看全部專題</Button>
      </div>
      <p class="section-subtitle">把同一主題的文章、闢謠、成分解析、Podcast 與短影音整理在一起，幫助讀者快速建立完整理解。</p>
      <div class="topics-home-grid">
        {topicCards.map(({ topic, cover }) => (
          <a href={`/topics/${topic.slug}/`} class="topic-home-card">
            <img class="topic-home-card__image" src={cover.src} alt={cover.alt} aria-hidden={cover.alt === '' ? 'true' : undefined} loading="lazy" />
            <div class="topic-home-card__body">
              <h3>{topic.name}</h3>
              <p>{topic.intro}</p>
              <span class="topic-home-card__cta">查看專題 →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================== -->
  <!--  3. Latest Content                                              -->
  <!-- ============================================================== -->
  <section id="latest" class="section-latest">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">最新內容</h2>
        <Button variant="secondary" href="/all/">看全部內容</Button>
      </div>
      <div class="latest-grid">
        {latestAll.map((item) => {
          const d = item.data;
          if (item.collection === 'articles') {
            return (
              <ArticleCard
                title={d.title as string}
                description={d.description as string}
                href={`/articles/${stripExt(item.id)}/`}
                category="article"
                coverImage={d.coverImage as string | undefined}
                coverAlt={d.coverAlt as string | undefined}
                author={d.author as string}
                date={fmtDate(item.date)}
                editorReviewed={d.editorReviewed as boolean}
              />
            );
          }
          if (item.collection === 'myths') {
            return (
              <MythCard
                title={d.title as string}
                verdictSummary={d.verdictSummary as string}
                href={`/myths/${stripExt(item.id)}/`}
                verdict={d.verdict as MythVerdict}
                date={fmtDate(item.date)}
              />
            );
          }
          if (item.collection === 'ingredients') {
            return (
              <IngredientCard
                title={d.title as string}
                description={d.description as string}
                href={`/ingredients/${stripExt(item.id)}/`}
                uses={d.uses as Array<{ evidenceLevel: string }>}
                coverImage={d.coverImage as string | undefined}
                coverAlt={d.coverAlt as string | undefined}
              />
            );
          }
          if (item.collection === 'podcasts') {
            return (
              <PodcastCard
                title={d.title as string}
                description={d.description as string}
                href={`/podcasts/${stripPodcastSlug(item.id)}/`}
                episodeNumber={d.episodeNumber as number}
                duration={d.duration as string}
                publishDate={item.date}
              />
            );
          }
          if (item.collection === 'videos') {
            return (
              <VideoCard
                title={d.title as string}
                tldr={d.tldr as string}
                href={`/videos/${stripExt(item.id)}/`}
                youtubeId={d.youtubeId as string}
              />
            );
          }
          if (item.collection === 'news') {
            return (
              <NewsItem
                title={d.title as string}
                source={d.source as string}
                date={fmtDate(item.date)}
                summary={d.summary as string}
                href={`/news/${item.id.replace(/\.[^.]+$/, '')}/`}
                sourceUrl={d.sourceUrl as string | undefined}
                tags={d.tags as string[]}
                image={getNewsThumbnail(d.thumbnail as string | undefined, d.heroImage as string | undefined, (d.tags as string[]) ?? [], d.category as string | undefined, { title: d.title as string, titleDisplay: d.titleDisplay as string | undefined, subtitle: d.subtitle as string | undefined, summary: d.summary as string | undefined })}
                imageAlt={d.coverAlt as string | undefined}
              />
            );
          }
          return null;
        })}
      </div>
    </div>
  </section>

  <!-- ============================================================== -->
  <!--  4. Podcast Block                                               -->
  <!-- ============================================================== -->
  <section id="podcasts" class="section-podcast">
    <div class="container">
      <div class="podcast-layout">
        <div class="podcast-layout__left">
          <h2 class="podcast-layout__title">把健康知識，整理成日常能用的養生觀。</h2>
          <p class="podcast-layout__desc">
            《喜聞樂健》以每集約 15 分鐘的篇幅，從一個健康問題切入，整理健康知識、保養觀念與判斷方式。希望讓健康資訊不只是知道，還能在日常生活中更容易理解與使用。
          </p>
