---
import List from '@/layouts/List.astro';
import { getCollection } from 'astro:content';
function stripExt(id:string){return id.replace(/\.[^.]+$/,'');}
const podcasts=(await getCollection('podcasts',(e)=>!e.data.draft && e.data.title && (e.data.audioUrl||e.data.embedUrl))).sort((a,b)=>b.data.publishDate.getTime()-a.data.publishDate.getTime());
const links={firstory:'https://open.firstory.me/user/cm54wunhn07kb01151eda467n/platforms',spotify:'https://open.firstory.me/user/cm54wunhn07kb01151eda467n/platforms',kkbox:'https://open.firstory.me/user/cm54wunhn07kb01151eda467n/platforms',pocket:'https://open.firstory.me/user/cm54wunhn07kb01151eda467n/platforms'};
---
<List title="Podcast《喜聞樂健》" description="用耳朵聽懂健康，不被行銷話術牽著走。" category="podcast" breadcrumbItems={[{label:'首頁',href:'/'},{label:'Podcast'}]} totalItems={podcasts.length}>
<h2>節目介紹</h2><p>《喜聞樂健》是由羅揚主持的健康知識 Podcast，從保健食品、營養科學、生活健康與常見迷思出發，用一般人聽得懂的方式，整理研究證據與實際判斷。節目不走誇大療效與恐嚇式行銷，而是希望幫助聽眾建立更穩定的健康判斷力。</p>
<p>主持人：羅揚｜節目：喜聞樂健</p>
<p><a href={links.firstory}>Firstory</a> · <a href={links.spotify}>Spotify</a> · <a href={links.kkbox}>KKBOX</a> · <a href={links.pocket}>Pocket Casts</a> · <a href={links.firstory}>全平台收聽</a></p>
<h2>已發布集數</h2><ul>{podcasts.map((p)=><li><a href={`/podcasts/${stripExt(p.id)}/`}>EP{p.data.episodeNumber}｜{p.data.title}</a></li>)}</ul>
</List>
