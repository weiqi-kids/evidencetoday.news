---
import Base from '@/layouts/Base.astro';
---

<Base title="內容已移動 | 本日有據" noindex={true}>
  <main class="container moved-page">
    <h1>此頁已移動</h1>
    <p>此示範頁已下線，請前往正式集數頁。</p>
    <p><a href="/podcasts/ep02/">前往《喜聞樂健》EP02</a></p>
  </main>
  <meta http-equiv="refresh" content="0; url=/podcasts/ep02/" />
</Base>

<style>
  .moved-page {
    padding-block: var(--space-page-y);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
</style>
