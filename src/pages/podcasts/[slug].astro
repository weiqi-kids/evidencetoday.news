---
import { getCollection, getEntry } from 'astro:content';
import Media from '@/layouts/Media.astro';
import ReferenceList from '@/components/blocks/ReferenceList.astro';
import ArticleCard from '@/components/blocks/ArticleCard.astro';
import MythCard from '@/components/blocks/MythCard.astro';
import IngredientCard from '@/components/blocks/IngredientCard.astro';
import VideoCard from '@/components/blocks/VideoCard.astro';

function stripExt(id: string): string {
  return id.replace(/\.[^.]+$/, '');
}

export async function getStaticPaths() {
  const entries = await getCollection('podcasts', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.[^.]+$/, '') },
    props: { entry },
  }));
}

function fmtDate(d: Date): string {
  return d.toISOString().slice(0, 10);
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;

/* Resolve related content */
const relatedArticles = data.relatedArticles
  ? (await Promise.all(data.relatedArticles.map((id) => getEntry('articles', id)))).filter(Boolean)
  : [];
const relatedMyths = data.relatedMyths
  ? (await Promise.all(data.relatedMyths.map((id) => getEntry('myths', id)))).filter(Boolean)
  : [];
const relatedIngredients = data.relatedIngredients
  ? (await Promise.all(data.relatedIngredients.map((id) => getEntry('ingredients', id)))).filter(Boolean)
  : [];
const relatedVideos = data.relatedVideos
  ? (await Promise.all(data.relatedVideos.map((id) => getEntry('videos', id)))).filter(Boolean)
  : [];

const hasRelated = relatedArticles.length > 0 || relatedMyths.length > 0 || relatedIngredients.length > 0 || relatedVideos.length > 0;
---

<Media
  title={data.title}
  description={data.description}
  ogImage={data.coverImage}
  category="podcast"
  publishDate={data.publishDate}
  updatedDate={data.updatedDate}
  tags={data.tags}
  breadcrumbItems={[
    { label: '首頁', href: '/' },
    { label: 'Podcast', href: '/podcasts/' },
    { label: data.title },
  ]}
>
  <Fragment slot="player">
    {data.embedUrl ? (
      <div class="podcast-player">
        <iframe
          src={data.embedUrl}
          width="100%"
          height="232"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy"
          style="border-radius: 12px; border: 0;"
        ></iframe>
      </div>
    ) : (
      <div class="podcast-player-placeholder">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
          <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
          <line x1="12" y1="19" x2="12" y2="23"/>
          <line x1="8" y1="23" x2="16" y2="23"/>
        </svg>
        <span>EP {data.episodeNumber} &middot; {data.duration}</span>
      </div>
    )}
  </Fragment>

  <Content />

  <Fragment slot="after-content">
    {data.chapters && data.chapters.length > 0 && (
      <section class="podcast-chapters">
        <h2>章節</h2>
        <ol class="chapters-list">
          {data.chapters.map((ch) => (
            <li class="chapters-list__item">
              <span class="chapters-list__time">{ch.time}</span>
              <span class="chapters-list__title">{ch.title}</span>
            </li>
          ))}
        </ol>
      </section>
    )}

    {data.showNotes && data.showNotes.length > 0 && (
      <section class="podcast-shownotes">
        <h2>節目筆記</h2>
        <ul class="shownotes-list">
          {data.showNotes.map((note) => (
            <li>{note}</li>
          ))}
        </ul>
      </section>
    )}

    {data.references && data.references.length > 0 && (
      <section class="podcast-references">
        <ReferenceList references={data.references} />
      </section>
    )}

    {hasRelated && (
      <section class="related-content">
        <h2 class="related-content__title">相關內容</h2>
        <div class="related-content__grid">
          {relatedArticles.map((a) => (
            <ArticleCard
              title={a.data.title}
              description={a.data.description}
              href={`/articles/${stripExt(a.id)}/`}
              category="article"
              author={a.data.author}
              date={fmtDate(a.data.publishDate)}
              editorReviewed={a.data.editorReviewed}
            />
          ))}
          {relatedMyths.map((m) => (
            <MythCard
              title={m.data.title}
              verdictSummary={m.data.verdictSummary}
              href={`/myths/${stripExt(m.id)}/`}
              verdict={m.data.verdict}
              date={fmtDate(m.data.publishDate)}
            />
          ))}
          {relatedIngredients.map((i) => (
            <IngredientCard
              title={i.data.title}
              description={i.data.description}
              href={`/ingredients/${stripExt(i.id)}/`}
              uses={i.data.uses}
            />
          ))}
          {relatedVideos.map((v) => (
            <VideoCard
              title={v.data.title}
              tldr={v.data.tldr}
              href={`/videos/${stripExt(v.id)}/`}
              youtubeId={v.data.youtubeId}
            />
          ))}
        </div>
      </section>
    )}
  </Fragment>
</Media>

<style>
  .podcast-player {
    width: 100%;
  }

  .podcast-player-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 2.5rem;
    border-radius: var(--radius-card);
    background-color: var(--color-navy);
    color: var(--color-on-dark-meta);
    text-align: center;
    font-family: var(--font-ui);
    font-size: var(--text-body);
  }

  .podcast-chapters,
  .podcast-shownotes,
  .podcast-references {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .podcast-chapters h2,
  .podcast-shownotes h2 {
    font-family: var(--font-sans);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-ink);
  }

  .chapters-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .chapters-list__item {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-fog);
    font-size: var(--text-body);
    line-height: 1.6;
  }

  .chapters-list__item:last-child {
    border-bottom: none;
  }

  .chapters-list__time {
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    font-weight: 600;
    color: var(--color-teal);
    white-space: nowrap;
    min-width: 3.5rem;
  }

  .chapters-list__title {
    color: var(--color-ink);
  }

  .shownotes-list {
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: var(--text-body);
    line-height: 1.7;
    color: color-mix(in oklch, var(--color-ink) 85%, transparent);
  }

  .related-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .related-content__title {
    font-family: var(--font-sans);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-ink);
  }

  .related-content__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-card-gap);
  }

  @media (max-width: 640px) {
    .related-content__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
