---
import { getCollection, getEntry } from 'astro:content';
import Media from '@/layouts/Media.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import ReferenceList from '@/components/blocks/ReferenceList.astro';
import ArticleCard from '@/components/blocks/ArticleCard.astro';
import MythCard from '@/components/blocks/MythCard.astro';
import IngredientCard from '@/components/blocks/IngredientCard.astro';
import VideoCard from '@/components/blocks/VideoCard.astro';
import { fmtDate } from '@/utils/date';
import { getPublishedPodcasts, parseDurationToIso, stripPodcastSlug } from '@/utils/podcasts';
import { contentSocial } from '@/utils/social-meta.mjs';

function stripExt(id: string): string {
  return id.replace(/\.[^.]+$/, '');
}

function compactJsonLd<T>(value: T): T {
  if (Array.isArray(value)) {
    return value
      .map((item) => compactJsonLd(item))
      .filter((item) => item !== undefined && item !== null) as T;
  }

  if (value && typeof value === 'object') {
    return Object.fromEntries(
      Object.entries(value)
        .map(([key, val]) => [key, compactJsonLd(val)])
        .filter(([, val]) => val !== undefined),
    ) as T;
  }

  return value;
}

export async function getStaticPaths() { const entries = getPublishedPodcasts(await getCollection('podcasts')); return entries.map((entry) => ({ params: { slug: stripPodcastSlug(entry.id) }, props: { entry } })); }
const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;
const social = contentSocial('podcasts', data, stripPodcastSlug(entry.id));
const relatedArticles = data.relatedArticles ? (await Promise.all(data.relatedArticles.map((id) => getEntry('articles', id)))).filter(Boolean) : [];
const relatedMyths = data.relatedMyths ? (await Promise.all(data.relatedMyths.map((id) => getEntry('myths', id)))).filter(Boolean) : [];
const relatedIngredients = data.relatedIngredients ? (await Promise.all(data.relatedIngredients.map((id) => getEntry('ingredients', id)))).filter(Boolean) : [];
const relatedVideos = data.relatedVideos ? (await Promise.all(data.relatedVideos.map((id) => getEntry('videos', id)))).filter(Boolean) : [];
const hasRelated = relatedArticles.length > 0 || relatedMyths.length > 0 || relatedIngredients.length > 0 || relatedVideos.length > 0;
const slug = stripPodcastSlug(entry.id);
const isoDuration = parseDurationToIso(data.duration);
const podcastEpisodeSchema = compactJsonLd({
  '@context': 'https://schema.org',
  '@type': 'PodcastEpisode',
  name: data.title,
  headline: data.title,
  description: data.summary ?? data.description,
  url: `https://evidencetoday.news/podcasts/${slug}/`,
  datePublished: data.publishDate.toISOString(),
  dateModified: (data.updatedDate ?? data.publishDate).toISOString(),
  episodeNumber: data.episodeNumber,
  duration: isoDuration,
  inLanguage: 'zh-TW',
  partOfSeries: {
    '@type': 'PodcastSeries',
    name: '喜聞樂健',
    url: 'https://evidencetoday.news/podcasts/',
  },
  author: {
    '@type': 'Person',
    name: '羅揚',
    url: 'https://evidencetoday.news/authors/luo-yang/',
  },
  creator: {
    '@type': 'Person',
    name: '羅揚',
    url: 'https://evidencetoday.news/authors/luo-yang/',
  },
  publisher: {
    '@type': 'Organization',
    name: '本日有據',
    url: 'https://evidencetoday.news/',
  },
  audio: {
    '@type': 'AudioObject',
    name: data.title,
    description: data.summary ?? data.description,
    duration: isoDuration,
    contentUrl: data.audioUrl ? new URL(data.audioUrl, 'https://evidencetoday.news').href : undefined,
    embedUrl: data.embedUrl,
    url: data.externalUrl,
    encodingFormat: data.audioUrl ? 'audio/mpeg' : undefined,
  },
  sameAs: data.externalUrl ? [data.externalUrl] : undefined,
});
const podcastBreadcrumbSchema = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: '首頁', item: 'https://evidencetoday.news/' }, { '@type': 'ListItem', position: 2, name: 'Podcast', item: 'https://evidencetoday.news/podcasts/' }, { '@type': 'ListItem', position: 3, name: data.title, item: `https://evidencetoday.news/podcasts/${slug}/` }] };
---
<Media title={data.title} description={social.description} socialTitle={social.title} socialDescription={social.description} ogImage={social.image} category="podcast" publishDate={data.publishDate} updatedDate={data.updatedDate} tags={data.tags} breadcrumbItems={[{ label: '首頁', href: '/' }, { label: 'Podcast', href: '/podcasts/' }, { label: data.title }]}>
  <Fragment slot="head"><JsonLd data={podcastEpisodeSchema} /><JsonLd data={podcastBreadcrumbSchema} /></Fragment>
  <Fragment slot="summary"><p class="episode-summary">{data.summary || data.description}</p><p class="episode-meta">EP{data.episodeNumber} · {data.duration} · 喜聞樂健</p></Fragment>
  <Fragment slot="player">{data.embedUrl ? <div class="podcast-player"><iframe src={data.embedUrl} title={`${data.title} Firstory podcast player`} loading="lazy" width="100%" height="180" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" class="podcast-player__iframe"></iframe></div> : <p class="podcast-player-empty">本集音訊尚未上架，請稍後回來收聽。</p>}</Fragment>
  <Content />
  <Fragment slot="after-content">
    {data.keyPoints?.length > 0 && <section class="podcast-section"><h2 class="podcast-section__title">本集重點</h2><ul class="podcast-section__list">{data.keyPoints.map((k)=><li>{k}</li>)}</ul></section>}
    {data.references?.length > 0 && <ReferenceList references={data.references} />}
    {hasRelated && <section class="related-content"><h2 class="related-content__title">延伸閱讀</h2><div class="related-content__grid">{relatedArticles.map((a)=><ArticleCard title={a.data.title} description={a.data.description} href={`/articles/${stripExt(a.id)}/`} category="article" author={a.data.author} date={fmtDate(a.data.publishDate)} editorReviewed={a.data.editorReviewed} />)}{relatedMyths.map((m)=><MythCard title={m.data.title} verdictSummary={m.data.verdictSummary} href={`/myths/${stripExt(m.id)}/`} verdict={m.data.verdict} date={fmtDate(m.data.publishDate)} />)}{relatedIngredients.map((i)=><IngredientCard title={i.data.title} description={i.data.description} href={`/ingredients/${stripExt(i.id)}/`} uses={i.data.uses} />)}{relatedVideos.map((v)=><VideoCard title={v.data.title} tldr={v.data.tldr} href={`/videos/${stripExt(v.id)}/`} youtubeId={v.data.youtubeId} />)}</div></section>}
  </Fragment>
</Media>
<style>.episode-summary{line-height:1.82}.episode-meta{font-family:var(--font-ui);font-size:var(--text-meta);color:color-mix(in oklch,var(--color-ink) 65%,transparent)} .podcast-player{border-radius:var(--radius-card);overflow:hidden;background:white;box-shadow:var(--shadow-card)} .podcast-player__iframe{border:0;display:block} .podcast-section{margin-block:1.5rem 2rem;padding-top:.25rem}.podcast-section__title{margin:0 0 1rem;line-height:1.3;padding-top:.25rem;border:0}.podcast-section__list{display:flex;flex-direction:column;gap:.75rem;margin:0;padding-inline-start:1.25rem} .related-content__grid{display:grid;grid-template-columns:repeat(2,1fr);gap:var(--space-card-gap)}@media (max-width:640px){.related-content__grid{grid-template-columns:1fr}}</style>
