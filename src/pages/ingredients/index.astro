---
import List from '@/layouts/List.astro';
import IngredientCard from '@/components/blocks/IngredientCard.astro';
import { getCollection } from 'astro:content';
import { listSocial } from '@/utils/social-meta.mjs';

function stripExt(id: string): string {
  return id.replace(/\.[^.]+$/, '');
}

const ingredients = (await getCollection('ingredients', (e) => !e.data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
const social = listSocial('ingredients');
---

<List
  title="成分解析"
  description={social.description}
  seoTitle={social.title}
  socialTitle={social.title}
  socialDescription={social.description}
  ogImage={social.image}
  category="ingredient"
  breadcrumbItems={[{ label: '首頁', href: '/' }, { label: '成分解析' }]}
  totalItems={ingredients.length}
>
  <div class="ingredients-grid">
    {ingredients.map((i) => (
      <IngredientCard
        title={i.data.title}
        titleEn={i.data.titleEn}
        description={i.data.description}
        href={`/ingredients/${stripExt(i.id)}/`}
        uses={i.data.uses}
        coverImage={i.data.coverImage}
        coverAlt={i.data.coverAlt}
        tags={i.data.tags}
      />
    ))}
  </div>
</List>

<style>
  .ingredients-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    min-width: 0;
    gap: var(--space-card-gap);
  }

  @media (max-width: 1024px) {
    .ingredients-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .ingredients-grid {
      grid-template-columns: 1fr;
    }
  }
</style>