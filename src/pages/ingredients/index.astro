---
import List from '@/layouts/List.astro';
import IngredientCard from '@/components/blocks/IngredientCard.astro';
import { getCollection } from 'astro:content';

function stripExt(id: string): string {
  return id.replace(/\.[^.]+$/, '');
}

const ingredients = (await getCollection('ingredients', (e) => !e.data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<List
  title="原料知識庫"
  description="營養素與保健成分的實證資料庫，用研究證據說話。"
  category="ingredient"
  breadcrumbItems={[{ label: '首頁', href: '/' }, { label: '原料知識庫' }]}
  totalItems={ingredients.length}
>
  <div class="ingredients-grid">
    {ingredients.map((i) => (
      <IngredientCard
        title={i.data.title}
        titleEn={i.data.titleEn}
        description={i.data.description}
        href={`/ingredients/${stripExt(i.id)}/`}
        uses={i.data.uses}
        coverImage={i.data.coverImage}
        tags={i.data.tags}
      />
    ))}
  </div>
</List>

<style>
  .ingredients-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-card-gap);
  }

  @media (max-width: 1024px) {
    .ingredients-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .ingredients-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
