---
import List from '@/layouts/List.astro';
import IngredientCard from '@/components/blocks/IngredientCard.astro';
import { getCollection } from 'astro:content';
import { listSocial } from '@/utils/social-meta.mjs';
import { isPublicEntry } from '@/utils/visibility';

function stripExt(id: string): string {
  return id.replace(/\.[^.]+$/, '');
}

const ingredients = (await getCollection('ingredients', (e) => isPublicEntry(e.data)))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
const social = listSocial('ingredients');
---

<List
  title="成分解析"
  description={social.description}
  seoTitle={social.title}
  socialTitle={social.title}
  socialDescription={social.description}
  ogImage={social.image}
  category="ingredient"
  breadcrumbItems={[{ label: '首頁', href: '/' }, { label: '成分解析' }]}
  totalItems={ingredients.length}
>
  <p class="ingredients-intro">
    成分解析逐一檢視保健食品裡常見營養素與成分的實證支持程度：目前研究做到哪個程度、建議劑量大概是多少、有哪些交互作用或副作用需要留意，幫助你在選購前先看懂科學根據。
  </p>

  <div class="ingredients-grid">
    {ingredients.map((i) => (
      <IngredientCard
        title={i.data.title}
        titleEn={i.data.titleEn}
        description={i.data.description}
        href={`/ingredients/${stripExt(i.id)}/`}
        uses={i.data.uses}
        coverImage={i.data.coverImage}
        coverAlt={i.data.coverAlt}
        tags={i.data.tags}
      />
    ))}
  </div>
</List>

<style>
  .ingredients-intro {
    max-width: 60ch;
    margin: 0 0 1.25rem;
    font-size: var(--text-body);
    line-height: 1.8;
    color: color-mix(in oklch, var(--color-ink) 72%, transparent);
  }

  .ingredients-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    min-width: 0;
    gap: var(--space-card-gap);
  }

  @media (max-width: 1024px) {
    .ingredients-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .ingredients-grid {
      grid-template-columns: 1fr;
    }
  }
</style>