---
import { getCollection, getEntry } from 'astro:content';
import Article from '@/layouts/Article.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import TableOfContents from '@/components/blocks/TableOfContents.svelte';
import EvidenceScale from '@/components/charts/EvidenceScale.svelte';
import PathwayDiagram from '@/components/charts/PathwayDiagram.svelte';
import ArticleCard from '@/components/blocks/ArticleCard.astro';
import MythCard from '@/components/blocks/MythCard.astro';
import VideoCard from '@/components/blocks/VideoCard.astro';
import PodcastCard from '@/components/blocks/PodcastCard.astro';
import { fmtDate } from '@/utils/date';
import { stripPodcastSlug } from '@/utils/podcasts';

function stripExt(id: string): string {
  return id.replace(/\.[^.]+$/, '');
}

export async function getStaticPaths() {
  const entries = await getCollection('ingredients', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.[^.]+$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();
const data = entry.data;

/* Resolve related content */
const relatedArticles = data.relatedArticles
  ? (await Promise.all(data.relatedArticles.map((id) => getEntry('articles', id)))).filter(Boolean)
  : [];
const relatedMyths = data.relatedMyths
  ? (await Promise.all(data.relatedMyths.map((id) => getEntry('myths', id)))).filter(Boolean)
  : [];
const relatedVideos = data.relatedVideos
  ? (await Promise.all(data.relatedVideos.map((id) => getEntry('videos', id)))).filter(Boolean)
  : [];
const relatedPodcasts = data.relatedPodcasts
  ? (await Promise.all(data.relatedPodcasts.map((id) => getEntry('podcasts', id)))).filter(Boolean)
  : [];

const hasRelated = relatedArticles.length > 0 || relatedMyths.length > 0 || relatedVideos.length > 0 || relatedPodcasts.length > 0;

/* JSON-LD structured data */
const slug = entry.id.replace(/\.[^.]+$/, '');
const ingredientArticleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.title,
  description: data.description,
  datePublished: data.publishDate.toISOString(),
  dateModified: data.updatedDate.toISOString(),
  author: {
    '@type': 'Organization',
    name: '本日有據',
  },
  publisher: {
    '@type': 'Organization',
    name: '本日有據',
  },
  about: {
    '@type': 'Thing',
    name: data.title,
  },
  articleSection: '原料知識庫',
  mainEntityOfPage: `https://evidencetoday.news/ingredients/${slug}/`,
};

const ingredientBreadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: 'https://evidencetoday.news/' },
    { '@type': 'ListItem', position: 2, name: '原料知識庫', item: 'https://evidencetoday.news/ingredients/' },
    { '@type': 'ListItem', position: 3, name: data.title, item: `https://evidencetoday.news/ingredients/${slug}/` },
  ],
};
---

<Article
  title={data.title}
  description={data.description}
  ogImage={data.coverImage || `/og/ingredients/${slug}.png`}
  category="ingredient"
  publishDate={data.publishDate}
  updatedDate={data.updatedDate}
  disclosure={data.disclosure}
  tags={data.tags}
  breadcrumbItems={[
    { label: '首頁', href: '/' },
    { label: '原料知識庫', href: '/ingredients/' },
    { label: data.title },
  ]}
  references={data.references}
  tldr={data.introduction}
>
  <Fragment slot="head">
    <JsonLd data={ingredientArticleSchema} />
    <JsonLd data={ingredientBreadcrumbSchema} />
  </Fragment>

  <section class="ingredient-scope-note" aria-label="原料頁閱讀提醒">
    <h2 class="ingredient-scope-note__title">閱讀這頁前，先說清楚</h2>
    <ul class="ingredient-scope-note__list">
      <li>這頁整理的是研究中常被討論的用途、可能機制與安全性，不是產品推薦。</li>
      <li>文中提到的作用路徑或研究結果，不代表對個人一定有效，也不代表療效宣稱。</li>
      <li>若正在治療疾病、懷孕、哺乳、服藥或有慢性病，請先和醫療專業人員討論。</li>
    </ul>
  </section>

  {data.pathwaySteps && data.pathwaySteps.length > 0 ? (
    <>
      <PathwayDiagram steps={data.pathwaySteps} client:visible aria-hidden="true" />
      <section class="mechanism-text">
        <h3>可能機制摘要</h3>
        <p>{data.pathwaySteps.map((step) => `${step.name}：${step.description}`).join('；')}</p>
      </section>
    </>
  ) : data.mechanism ? (
    <section class="mechanism-text">
      <h3>研究常討論的可能機制</h3>
      <p>{data.mechanism}</p>
    </section>
  ) : null}

  <EvidenceScale uses={data.uses} client:visible />

  {data.safety && (
    <section class="ingredient-safety">
      <h2>安全性與交互作用</h2>
      {data.safety.general && <p>{data.safety.general}</p>}
      {data.safety.interactions && data.safety.interactions.length > 0 && (
        <>
          <h3>可能交互作用</h3>
          <ul>
            {data.safety.interactions.map((item) => (
              <li><strong>{item.substance}</strong>：{item.description}</li>
            ))}
          </ul>
        </>
      )}
      {data.safety.populations && data.safety.populations.length > 0 && (
        <>
          <h3>族群注意</h3>
          <ul>
            {data.safety.populations.map((item) => (
              <li><strong>{item.group}</strong>：{item.note}</li>
            ))}
          </ul>
        </>
      )}
    </section>
  )}

  <Content />

  <Fragment slot="sidebar">
    {headings.length > 0 && (
      <TableOfContents headings={headings} client:idle />
    )}
  </Fragment>

  {hasRelated && (
    <Fragment slot="after-content">
      <section class="related-content">
        <h2 class="related-content__title">相關內容</h2>
        <div class="related-content__grid">
          {relatedArticles.map((a) => (
            <ArticleCard
              title={a.data.title}
              description={a.data.description}
              href={`/articles/${stripExt(a.id)}/`}
              category="article"
              author={a.data.author}
              date={fmtDate(a.data.publishDate)}
              editorReviewed={a.data.editorReviewed}
            />
          ))}
          {relatedMyths.map((m) => (
            <MythCard
              title={m.data.title}
              verdictSummary={m.data.verdictSummary}
              href={`/myths/${stripExt(m.id)}/`}
              verdict={m.data.verdict}
              date={fmtDate(m.data.publishDate)}
            />
          ))}
          {relatedVideos.map((v) => (
            <VideoCard
              title={v.data.title}
              tldr={v.data.tldr}
              href={`/videos/${stripExt(v.id)}/`}
              youtubeId={v.data.youtubeId}
            />
          ))}
          {relatedPodcasts.map((p) => (
            <PodcastCard
              title={p.data.title}
              description={p.data.description}
              href={`/podcasts/${stripPodcastSlug(p.id)}/`}
              episodeNumber={p.data.episodeNumber}
              duration={p.data.duration}
            />
          ))}
        </div>
      </section>
    </Fragment>
  )}
</Article>

<style>
  .related-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .related-content__title {
    font-family: var(--font-sans);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-ink);
  }

  .related-content__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-card-gap);
  }

  @media (min-width: 640px) {
    .related-content__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .mechanism-text {
    padding: 1.5rem;
    border-radius: var(--radius-card);
    border: 1px solid var(--color-fog);
    background-color: white;
  }

  .mechanism-text h3 {
    font-family: var(--font-sans);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-ink);
    margin-bottom: 0.75rem;
  }

  .mechanism-text p {
    font-size: var(--text-body);
    color: var(--color-ink);
    line-height: 1.8;
  }


  .ingredient-scope-note,
  .ingredient-safety {
    padding: clamp(1rem, 0.8rem + 0.8vw, 1.5rem);
    border-radius: var(--radius-card);
    border: 1px solid var(--color-fog);
    background: color-mix(in oklch, var(--color-paper) 70%, white);
  }

  .ingredient-scope-note {
    border-inline-start: 4px solid var(--color-cat-ingredient);
  }

  .ingredient-scope-note__title,
  .ingredient-safety h2,
  .ingredient-safety h3 {
    font-family: var(--font-sans);
    color: var(--color-ink);
  }

  .ingredient-scope-note__title {
    font-size: var(--text-h3);
    margin-bottom: 0.75rem;
  }

  .ingredient-scope-note__list,
  .ingredient-safety ul {
    margin: 0;
    padding-inline-start: 1.25rem;
    display: grid;
    gap: 0.5rem;
  }

  .ingredient-scope-note__list li,
  .ingredient-safety li,
  .ingredient-safety p {
    color: var(--color-ink);
    line-height: 1.8;
    font-size: var(--text-body);
  }

  .ingredient-safety h2 {
    font-size: var(--text-h3);
    margin-bottom: 0.75rem;
  }

  .ingredient-safety h3 {
    font-size: var(--text-h4);
    margin: 1rem 0 0.5rem;
  }
</style>
