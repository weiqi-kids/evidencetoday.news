---
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { getCollection } from 'astro:content';
import { fmtDate } from '@/utils/date';
import { stripPodcastSlug, getPublishedPodcasts } from '@/utils/podcasts';
import { getPublishedArticles } from '@/utils/articles';
import { isPublicEntry } from '@/utils/visibility';
import { WEBSITE_REF, PUBLISHER_REF, SITE_URL } from '@/utils/schema-org';

function stripExt(id: string): string {
  return id.replace(/\.[^.]+$/, '');
}

const byDate = (a: { data: { publishDate: Date } }, b: { data: { publishDate: Date } }) =>
  b.data.publishDate.getTime() - a.data.publishDate.getTime();

const articles = await getPublishedArticles();
const myths = (await getCollection('myths', (e) => isPublicEntry(e.data))).sort(byDate);
const ingredients = (await getCollection('ingredients', (e) => isPublicEntry(e.data))).sort(byDate);
const news = (await getCollection('news', (e) => isPublicEntry(e.data))).sort(byDate);
const podcasts = getPublishedPodcasts(await getCollection('podcasts'));
const videos = (await getCollection('videos', (e) => isPublicEntry(e.data))).sort(byDate);

const sections = [
  {
    key: 'articles',
    title: '文章',
    href: '/articles/',
    items: articles.map((a) => ({ title: a.data.title, href: `/articles/${stripExt(a.id)}/`, date: fmtDate(a.data.publishDate) })),
  },
  {
    key: 'myths',
    title: '闢謠',
    href: '/myths/',
    items: myths.map((m) => ({ title: m.data.title, href: `/myths/${stripExt(m.id)}/`, date: fmtDate(m.data.publishDate) })),
  },
  {
    key: 'ingredients',
    title: '成分解析',
    href: '/ingredients/',
    items: ingredients.map((i) => ({ title: i.data.title, href: `/ingredients/${stripExt(i.id)}/`, date: fmtDate(i.data.publishDate) })),
  },
  {
    key: 'news',
    title: '趨勢',
    href: '/news/',
    items: news.map((n) => ({ title: n.data.titleDisplay || n.data.title, href: `/news/${stripExt(n.id)}/`, date: fmtDate(n.data.publishDate) })),
  },
  {
    key: 'podcasts',
    title: 'Podcast',
    href: '/podcasts/',
    items: podcasts.map((p) => ({ title: p.data.title, href: `/podcasts/${stripPodcastSlug(p.id)}/`, date: fmtDate(p.data.publishDate) })),
  },
  {
    key: 'videos',
    title: '短影音',
    href: '/videos/',
    items: videos.map((v) => ({ title: v.data.title, href: `/videos/${stripExt(v.id)}/`, date: fmtDate(v.data.publishDate) })),
  },
].filter((section) => section.items.length > 0);

const totalCount = sections.reduce((sum, section) => sum + section.items.length, 0);
const title = '全部內容 - 本日有據';
const description = `本日有據目前公開的全部內容索引，涵蓋文章、闢謠、成分解析、趨勢、Podcast 與短影音，共 ${totalCount} 篇。`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: '全部內容', item: `${SITE_URL}/all/` },
  ],
};

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${SITE_URL}/all/#collection`,
  name: '全部內容',
  description,
  url: `${SITE_URL}/all/`,
  isPartOf: WEBSITE_REF,
  publisher: PUBLISHER_REF,
};
---

<Base title={title} description={description} ogTitle="全部內容" ogDescription={description}>
  <Fragment slot="head">
    <JsonLd data={collectionSchema} />
    <JsonLd data={breadcrumbSchema} />
  </Fragment>

  <main class="container all-page">
    <Breadcrumb items={[{ label: '首頁', href: '/' }, { label: '全部內容' }]} />

    <header class="all-header">
      <h1>全部內容</h1>
      <p>本日有據目前公開的全部內容，依類型整理。共 {totalCount} 篇。</p>
    </header>

    {sections.map((section) => (
      <section class="all-section">
        <div class="all-section__head">
          <h2>{section.title} <span class="all-count">{section.items.length}</span></h2>
          <a class="all-section__more" href={section.href}>前往{section.title} →</a>
        </div>
        <ul class="all-list">
          {section.items.map((item) => (
            <li>
              <a href={item.href}>{item.title}</a>
              {item.date && <time class="all-date">{item.date}</time>}
            </li>
          ))}
        </ul>
      </section>
    ))}
  </main>
</Base>

<style>
  .all-page {
    padding-block: var(--space-page-y);
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 1.2rem + 1vw, 2.5rem);
  }

  .all-header h1 {
    font-family: var(--font-serif);
    font-size: var(--text-h1);
    color: var(--color-ink);
    margin: 0.4rem 0 0.5rem;
  }

  .all-header p {
    color: color-mix(in oklch, var(--color-ink) 72%, transparent);
  }

  .all-section {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .all-section__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    border-bottom: 1px solid var(--color-fog);
    padding-bottom: 0.5rem;
  }

  .all-section__head h2 {
    font-family: var(--font-sans);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-ink);
    margin: 0;
  }

  .all-count {
    font-size: var(--text-meta);
    color: color-mix(in oklch, var(--color-ink) 55%, transparent);
    font-weight: 700;
  }

  .all-section__more {
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    font-weight: 600;
    color: var(--color-teal);
    text-decoration: none;
  }

  .all-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
  }

  .all-list li {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    min-width: 0;
  }

  .all-list a {
    color: var(--color-ink);
    text-decoration: none;
    line-height: 1.6;
    text-underline-offset: 0.18em;
  }

  .all-list a:hover {
    text-decoration: underline;
    color: var(--color-teal);
  }

  .all-date {
    flex-shrink: 0;
    font-family: var(--font-ui);
    font-size: var(--text-badge);
    color: color-mix(in oklch, var(--color-ink) 45%, transparent);
  }

  @media (min-width: 768px) {
    .all-list {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.5rem 2rem;
    }
  }
</style>
