{
  "name": "evidencetoday-news",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/check-design.mjs && node scripts/check-content.mjs && astro build",
    "check:myths": "node scripts/check-myth-quality.mjs",
    "check:news": "node scripts/check-news-quality.mjs",
    "og:thumbs": "node scripts/generate-og-thumbs.mjs",
    "postbuild": "node scripts/subset-fonts.mjs && pagefind --site dist",
    "preview": "astro preview",
    "sync:youtube": "node scripts/sync-youtube-shorts.mjs",
    "used-images": "node scripts/used-images.mjs",
    "prebuild": "pnpm run sync:youtube && pnpm run used-images",
    "content:audit": "node scripts/check-content.mjs",
    "check:content": "node scripts/check-content.mjs",
    "check:content:all": "node scripts/check-content.mjs --all",
    "test": "vitest run",
    "test:watch": "vitest",
    "insights": "node scripts/audience-insights.mjs",
    "perf": "node scripts/perf-snapshot.mjs",
    "sitemap:submit": "node scripts/sitemap-submit.mjs",
    "index:coverage": "node scripts/index-coverage.mjs",
    "gnews:watch": "node scripts/googlenews-watch.mjs",
    "check:design": "node scripts/check-design.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/svelte": "^7.2.5",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/noto-sans-tc": "^5.2.9",
    "@fontsource/noto-serif-tc": "^5.2.10",
    "@fontsource/source-serif-4": "^5.2.9",
    "@toast-ui/editor": "^3.2.2",
    "astro": "^5.18.1",
    "d3-array": "^3.2.4",
    "d3-force": "^3.0.0",
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-timer": "^3.0.1",
    "pinyin-pro": "^3.28.1",
    "satori": "^0.26.0",
    "subset-font": "^2.5.0",
    "svelte": "^5.55.5"
  },
  "devDependencies": {
    "@types/d3-array": "^3.2.2",
    "@types/d3-force": "^3.0.10",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-shape": "^3.1.8",
    "@types/d3-timer": "^3.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "js-yaml": "^4.2.0",
    "pagefind": "^1.5.2",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
